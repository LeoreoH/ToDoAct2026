<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reconocer fracciones &middot; Nivel f&aacute;cil &middot; Visual verbal</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Fredoka+One&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
<style>     * { box-sizing: border-box; }      body {       margin: 0;       font-family: 'Nunito', sans-serif;       background: linear-gradient(135deg, #f7f1ff, #ede7f6);       color: #4a148c;       min-height: 100vh;     }      .cabecera {       background: linear-gradient(135deg, #8e24aa, #5e35b1);       color: white;       text-align: center;       padding: 28px 20px;       border-bottom: 6px solid #ffd54f;       box-shadow: 0 8px 20px rgba(0,0,0,0.18);     }      .cabecera h1 {       margin: 0;       font-family: 'Fredoka One', cursive;       font-size: 2.5rem;       text-shadow: 2px 2px 0 rgba(0,0,0,0.15);     }      .cabecera .subtitulo {       margin-top: 10px;       font-size: 1.05rem;       font-weight: 700;     }      .badge-estilo {       display: inline-block;       margin-top: 14px;       background: #ffd54f;       color: #4a148c;       border: 3px solid white;       border-radius: 999px;       padding: 10px 24px;       font-weight: 800;       box-shadow: 0 4px 0 #d39e00;     }      .barra-progreso {       max-width: 920px;       margin: 24px auto 0;       background: white;       border-radius: 999px;       border: 3px solid #7b1fa2;       box-shadow: 0 6px 0 #d1c4e9;       padding: 12px 18px;       display: flex;       gap: 14px;       align-items: center;       flex-wrap: wrap;     }      .progreso-texto {       font-weight: 800;       color: #6a1b9a;       white-space: nowrap;     }      .barra-fondo {       flex: 1;       min-width: 140px;       height: 14px;       background: #ede7f6;       border-radius: 999px;       overflow: hidden;       border: 2px solid #d1c4e9;     }      .barra-relleno {       width: 25%;       height: 100%;       background: linear-gradient(90deg, #ab47bc, #7e57c2);       transition: width 0.3s;     }      .progreso-num {       background: #7b1fa2;       color: white;       padding: 7px 14px;       border-radius: 999px;       font-weight: 800;     }      .contenedor {       max-width: 920px;       margin: 26px auto 42px;       padding: 0 16px;     }      .pagina {       display: none;       animation: aparecer .35s ease;     }      .pagina.activa {       display: block;     }      @keyframes aparecer {       from { opacity: 0; transform: translateY(12px); }       to { opacity: 1; transform: translateY(0); }     }      .tarjeta {       background: white;       border-radius: 28px;       border: 3px solid #7b1fa2;       box-shadow: 0 10px 0 #d1c4e9;       padding: 26px;     }      .titulo-pagina {       font-family: 'Fredoka One', cursive;       font-size: 2rem;       color: #6a1b9a;       margin-bottom: 16px;       border-left: 8px solid #ffd54f;       padding-left: 18px;     }      .texto-destacado {       background: #faf5ff;       border: 2px dashed #ce93d8;       border-radius: 18px;       padding: 16px 18px;       color: #5e35b1;       font-weight: 700;       margin-bottom: 18px;     }      .recuadro {       background: #f7f1ff;       border-radius: 20px;       padding: 18px;       border-left: 7px solid #ffd54f;       margin: 18px 0;     }      .recuadro h4 {       margin-top: 0;       color: #6a1b9a;       font-weight: 800;     }      .modelo-fraccion {       background: white;       border: 2px solid #d1c4e9;       border-radius: 22px;       padding: 18px;       margin: 18px 0;       text-align: center;     }      .barra-fraccion {       display: flex;       justify-content: center;       gap: 8px;       flex-wrap: wrap;       margin: 14px 0;     }      .parte {       width: 84px;       height: 84px;       border-radius: 16px;       border: 3px solid #7b1fa2;       background: white;     }      .parte.coloreada {       background: linear-gradient(135deg, #ab47bc, #7e57c2);     }      .circulo {       border-radius: 50%;     }      .fraccion-grande {       display: inline-block;       font-size: 2rem;       font-weight: 800;       line-height: 1.1;       color: #5e35b1;       min-width: 100px;     }      .fraccion-grande .linea {       display: block;       height: 4px;       background: #5e35b1;       border-radius: 2px;       margin: 5px 0;     }      .lista-explicacion {       margin: 0;       padding-left: 22px;     }      .lista-explicacion li {       margin-bottom: 8px;       font-weight: 700;       color: #5e35b1;     }      .actividad {       background: #faf5ff;       border: 3px dashed #ba68c8;       border-radius: 24px;       padding: 20px;       margin-top: 22px;     }      .actividad h3 {       text-align: center;       color: #6a1b9a;       font-size: 1.35rem;       font-weight: 800;       margin-bottom: 16px;     }      .opciones {       display: grid;       grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));       gap: 14px;       margin-top: 14px;     }      .opcion {       background: white;       border: 3px solid #7b1fa2;       border-radius: 18px;       padding: 16px;       text-align: center;       font-weight: 800;       color: #6a1b9a;       cursor: pointer;       box-shadow: 0 5px 0 #d1c4e9;       transition: .2s;     }      .opcion:hover {       transform: translateY(-2px);       background: #f7f1ff;     }      .opcion.correcta {       background: #e8f5e9;       border-color: #43a047;       color: #2e7d32;     }      .opcion.incorrecta {       background: #ffebee;       border-color: #e53935;       color: #c62828;     }      .mensaje-feedback {       margin-top: 16px;       padding: 12px 16px;       border-radius: 16px;       font-weight: 800;       text-align: center;       display: none;     }      .mensaje-feedback.visible {       display: block;     }      .mensaje-ok {       background: #e8f5e9;       color: #2e7d32;       border: 2px solid #43a047;     }      .mensaje-warn {       background: #fff8e1;       color: #8d6e00;       border: 2px solid #ffd54f;     }      .navegador {       display: flex;       justify-content: space-between;       align-items: center;       gap: 15px;       background: white;       border: 3px solid #7b1fa2;       border-radius: 999px;       padding: 14px 20px;       box-shadow: 0 6px 0 #d1c4e9;       margin-top: 16px;       flex-wrap: wrap;     }      .btn-nav {       background: #7b1fa2;       color: white;       border: none;       border-radius: 999px;       padding: 12px 24px;       font-weight: 800;       transition: .2s;     }      .btn-nav:hover:not(:disabled) {       background: #5e35b1;       transform: translateY(-2px);     }      .btn-nav:disabled {       opacity: .55;       cursor: not-allowed;     }      .contador {       font-weight: 800;       color: #6a1b9a;       background: #f3e5f5;       border: 2px solid #ce93d8;       padding: 8px 16px;       border-radius: 999px;     }      .boton-quiz {       display: inline-block;       margin: 28px auto 0;       text-decoration: none;       background: #ffd54f;       color: #4a148c;       border: 4px solid #7b1fa2;       padding: 16px 34px;       border-radius: 999px;       font-weight: 800;       font-size: 1.2rem;       box-shadow: 0 7px 0 #d39e00;       transition: .2s;     }      .boton-quiz:hover {       transform: translateY(-3px);       background: #fff3c4;     }      @media (max-width: 768px) {       .cabecera h1 { font-size: 2rem; }       .titulo-pagina { font-size: 1.55rem; }       .parte { width: 62px; height: 62px; }     }   </style>
</head>
<body>
  <header class="cabecera"><button class="btn-volver-menu" onclick="volverAlMenu()" title="Volver al men&uacute;"><i class="fas fa-arrow-left"></i></button><h1><i class="fas fa-chart-pie me-2"></i>FRACCIONES</h1><div class="subtitulo">Reconocer fracciones &middot; Nivel f&aacute;cil</div><div class="badge-estilo"><i class="fas fa-book-open me-2"></i>Estilo visual verbal</div></header>
  <div class="progreso"><span class="progreso-texto" id="progresoTexto">P&aacute;gina 1 de 7</span><div class="barra-fondo"><div class="barra-relleno" id="barraRelleno"></div></div><span class="progreso-num" id="progresoNum">14%</span></div>
  <div class="contenedor"><div class="tarjeta" id="pageHost"></div><div class="navegador"><button class="btn-nav" id="btnAnterior" onclick="cambiarPagina(-1)" disabled>&larr; Anterior</button><span class="contador" id="contadorPagina">1/7</span><button class="btn-nav" id="btnSiguiente" onclick="cambiarPagina(1)" disabled>Siguiente &rarr;</button></div></div>
  
  
<script>     let paginaActual = 1;     const totalPaginas = 4;      function cambiarPagina(direccion) {       document.getElementById(`pagina${paginaActual}`).classList.remove('activa');       paginaActual += direccion;       document.getElementById(`pagina${paginaActual}`).classList.add('activa');       actualizarNavegacion();       localStorage.setItem('mate_fracciones_visualverbal_facil', paginaActual);     }      function actualizarNavegacion() {       document.getElementById('progresoTexto').innerText = `Página ${paginaActual} de ${totalPaginas}`;       document.getElementById('contadorPagina').innerText = `${paginaActual}/${totalPaginas}`;        const porcentaje = (paginaActual / totalPaginas) * 100;       document.getElementById('barraRelleno').style.width = `${porcentaje}%`;       document.getElementById('progresoNum').innerText = `${Math.round(porcentaje)}%`;        document.getElementById('btnAnterior').disabled = paginaActual === 1;       document.getElementById('btnSiguiente').disabled = paginaActual === totalPaginas;     }      function cargarProgreso() {       const guardado = localStorage.getItem('mate_fracciones_visualverbal_facil');       if (guardado) {         const pag = parseInt(guardado, 10);         if (pag >= 1 && pag <= totalPaginas) {           document.getElementById(`pagina${paginaActual}`).classList.remove('activa');           paginaActual = pag;           document.getElementById(`pagina${paginaActual}`).classList.add('activa');         }       }       actualizarNavegacion();     }      function inicializarActividad(selector, okId, warnId) {       const opciones = document.querySelectorAll(selector + ' .opcion');       const ok = document.getElementById(okId);       const warn = document.getElementById(warnId);        opciones.forEach(op => {         op.addEventListener('click', () => {           if (op.dataset.correcta === 'true') {             opciones.forEach(x => x.style.pointerEvents = 'none');             op.classList.add('correcta');             warn.classList.remove('visible');             ok.classList.add('visible');           } else {             op.classList.add('incorrecta');             warn.classList.add('visible');             setTimeout(() => op.classList.remove('incorrecta'), 700);           }         });       });     }      window.addEventListener('DOMContentLoaded', () => {       cargarProgreso();       inicializarActividad('#opcionesPagina2', 'feedback2ok', 'feedback2warn');       inicializarActividad('#opcionesPagina3', 'feedback3ok', 'feedback3warn');       inicializarActividad('#opcionesPagina4', 'feedback4ok', 'feedback4warn');     });   </script>
</body>
</html>
