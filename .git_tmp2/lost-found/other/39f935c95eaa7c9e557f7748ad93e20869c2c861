  <title>La Tierra &middot; Nivel Normal &middot; Auditivo</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Fredoka+One&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  
<style>     * { margin: 0; padding: 0; box-sizing: border-box; }      body {       font-family: 'Nunito', sans-serif;       background: #e3f2fd;       color: #01579b;       min-height: 100vh;     }      .cabecera {       background: #1976d2;       padding: 25px 20px;       border-bottom: 6px solid #ffd600;       text-align: center;       box-shadow: 0 10px 20px rgba(0,0,0,0.2);     }      .cabecera h1 {       font-family: 'Fredoka One', cursive;       font-size: 3rem;       color: white;       text-shadow: 3px 3px 0 #01579b;     }      .badge-estilo {       background: #ffd600;       color: #01579b;       padding: 12px 35px;       border-radius: 50px;       font-weight: 800;       font-size: 1.3rem;       display: inline-block;       border: 4px solid white;       margin-top: 10px;       box-shadow: 0 4px 0 #b26a00;     }      .badge-nivel {       background: #01579b;       color: white;       padding: 8px 25px;       border-radius: 40px;       font-weight: 700;       font-size: 1.1rem;       display: inline-block;       margin-left: 15px;       border: 2px solid #ffd600;     }      .progreso-contenedor {       background: white;       border-radius: 60px;       margin: 20px auto;       max-width: 700px;       padding: 12px 25px;       display: flex;       align-items: center;       gap: 15px;       border: 3px solid #1976d2;       box-shadow: 0 5px 0 #0d47a1;     }      .puntos {       display: flex;       gap: 10px;       flex: 1;       justify-content: center;     }      .punto {       width: 35px;       height: 35px;       border-radius: 50%;       background: #bbdefb;       border: 3px solid #1976d2;       display: flex;       align-items: center;       justify-content: center;       font-weight: 800;       color: #01579b;       transition: all 0.3s;     }      .punto.activo {       background: #ffd600;       transform: scale(1.15);     }      .punto.completado {       background: #4caf50;       color: white;       border-color: white;     }      .contenedor {       max-width: 900px;       margin: 0 auto 40px;       padding: 0 20px;     }      .pagina {       display: none;       animation: fadeIn 0.4s ease;     }      .pagina.activa {       display: block;     }      @keyframes fadeIn {       from { opacity: 0; transform: translateY(10px); }       to { opacity: 1; transform: translateY(0); }     }      .tarjeta-audio {       background: white;       border-radius: 30px;       padding: 25px;       margin-bottom: 20px;       border: 3px solid #1976d2;       box-shadow: 0 8px 0 #0d47a1;     }      .audio-header {       display: flex;       align-items: center;       gap: 15px;       margin-bottom: 15px;     }      .audio-icono {       background: #ffd600;       color: #01579b;       width: 60px;       height: 60px;       border-radius: 50%;       display: flex;       align-items: center;       justify-content: center;       font-size: 2rem;       border: 3px solid #1976d2;       box-shadow: 0 4px 0 #b26a00;     }      .audio-titulo {       font-size: 1.5rem;       font-weight: 800;       color: #01579b;     }      .audio-control {       width: 100%;       margin: 15px 0;     }      audio {       width: 100%;       border-radius: 30px;       border: 2px solid #1976d2;     }      /* IMÁGENES GRANDES */     .imagen-grande {       background: #e3f2fd;       border: 3px dashed #1976d2;       border-radius: 20px;       padding: 20px;       margin: 15px 0;       text-align: center;       transition: all 0.3s;     }      .imagen-grande:hover {       transform: scale(1.02) rotate(1deg);       box-shadow: 0 10px 20px rgba(25,118,210,0.3);     }      .imagen-geo {       width: 100%;       max-height: 250px;       object-fit: contain;       border-radius: 15px;       border: 3px solid white;     }      .pie-imagen {       color: #01579b;       font-size: 1rem;       margin-top: 10px;       font-weight: 700;       font-style: italic;     }      /* MINI PREGUNTAS */     .mini-pregunta {       background: #fff3e0;       border: 4px solid #ffd600;       border-radius: 30px;       padding: 20px;       margin: 20px 0;       text-align: center;     }      .mini-pregunta p {       font-size: 1.3rem;       font-weight: 700;       color: #01579b;       margin-bottom: 15px;     }      .opciones-mini {       display: flex;       justify-content: center;       gap: 15px;       flex-wrap: wrap;     }      .btn-mini {       background: #ffd600;       color: #01579b;       border: 4px solid #1976d2;       padding: 10px 25px;       border-radius: 50px;       font-weight: 800;       cursor: pointer;       transition: all 0.2s;       box-shadow: 0 4px 0 #b26a00;     }      .btn-mini:hover {       transform: scale(1.05);       background: white;     }      .btn-mini.correcto {       background: #4caf50;       color: white;       border-color: white;       box-shadow: 0 4px 0 #1b5e20;     }      .navegador {       display: flex;       justify-content: space-between;       align-items: center;       background: white;       padding: 15px 25px;       border-radius: 60px;       border: 3px solid #1976d2;       box-shadow: 0 5px 0 #0d47a1;       margin: 30px 0;     }      .btn-nav {       background: #ffd600;       color: #01579b;       border: none;       padding: 10px 25px;       border-radius: 40px;       font-weight: 800;       border: 3px solid #1976d2;       transition: all 0.2s;       box-shadow: 0 4px 0 #b26a00;     }      .btn-nav:hover:not(:disabled) {       background: white;       transform: translateY(-2px);     }      .btn-nav:disabled {       background: #e0e0e0;       color: #9e9e9e;       border-color: #bdbdbd;       box-shadow: none;     }      .indicador {       background: #bbdefb;       color: #01579b;       padding: 8px 30px;       border-radius: 40px;       font-weight: 800;       font-size: 1.3rem;       border: 3px solid #1976d2;     }      .btn-quiz {       display: block;       width: fit-content;       margin: 0 auto;       background: #ffd600;       color: #01579b;       border: none;       padding: 15px 45px;       border-radius: 60px;       font-weight: 800;       font-size: 1.5rem;       text-decoration: none;       border: 4px solid #1976d2;       box-shadow: 0 6px 0 #0d47a1;       transition: all 0.2s;     }      .btn-quiz:hover {       transform: translateY(-4px);       box-shadow: 0 10px 0 #0d47a1;       background: white;     }      .btn-subir {       position: fixed;       bottom: 80px;       right: 20px;       background: #ffd600;       color: #01579b;       width: 50px;       height: 50px;       border-radius: 50%;       display: flex;       align-items: center;       justify-content: center;       font-size: 1.5rem;       border: 3px solid #1976d2;       box-shadow: 0 4px 0 #0d47a1;       cursor: pointer;       transition: all 0.2s;       z-index: 1000;     }      .btn-subir:hover {       transform: translateY(-5px);       box-shadow: 0 8px 0 #0d47a1;     }   </style>
</head>
<body>

<div class="btn-subir" onclick="window.scrollTo({top: 0, behavior: 'smooth'});">
  <i class="fas fa-arrow-up"></i>
</div>

<div class="cabecera">
  <h1>&#127911; LA TIERRA</h1>
  <p class="lead text-white">Bloque I &middot; Nivel Normal</p>
  <div>
    <span class="badge-estilo">&#127925; Auditivo</span>
    <span class="badge-nivel">&#9889; Intermedio</span>
  </div>
</div>

<div class="progreso-contenedor">
  <i class="fas fa-headphones fa-2x" style="color: #1976d2;"></i>
  <div class="puntos" id="puntosProgreso">
    <div class="punto activo">1</div>
    <div class="punto">2</div>
    <div class="punto">3</div>
    <div class="punto">4</div>
  </div>
  <span class="badge" style="background:#1976d2;color:white;padding:8px 20px;">P&aacute;gina <span id="paginaActualNum">1</span>/4</span>
</div>

<audio id="audP1" src="audios/01-pregunta.mp3"></audio>
<audio id="audP2" src="audios/02-pregunta.mp3"></audio>
<audio id="audP3" src="audios/03-pregunta.mp3"></audio>
<audio id="audP4" src="audios/04-pregunta.mp3"></audio>

<div class="contenedor">

  <div class="pagina activa" id="pagina1">
    <div class="tarjeta-audio">
      <div class="audio-header">
        <div class="audio-icono"><i class="fas fa-sync-alt"></i></div>
        <div class="audio-titulo">Movimiento de rotaci&oacute;n</div>
      </div>
      <div class="audio-control">
        <audio controls><source src="audios/01-rotacion.mp3" type="audio/mpeg"></audio>
      </div>
      <div class="imagen-grande" onclick="ampliarImagen(this.querySelector('img'))">
        <img src="/contenidos/geografia/recursos/imagenes/libro/rotacion-tierra.jpg"
             alt="Rotaci&oacute;n" class="imagen-geo"
             onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/9/9d/Earth_rotation.svg/800px-Earth_rotation.svg.png'">
        <div class="pie-imagen">&#127757; La Tierra gira sobre su propio eje</div>
      </div>
    </div>

    <div class="reforzamiento-auditivo">
      <div class="ref-titulo"><i class="fas fa-headphones"></i> Comprueba lo que aprendiste</div>
      <p class="ref-instruccion">Escucha las instrucciones y responde las dos preguntas sobre la rotaci&oacute;n.</p>
      <div style="text-align:center;">
        <button class="btn-play-pregunta" id="btnP1" onclick="reproducirPregunta(1)">
          <div class="icono-play"><i class="fas fa-play"></i></div>
          Escuchar instrucciones
        </button>
      </div>

      <p style="color:#ffd600;font-weight:800;margin-bottom:10px;">1. &iquest;Cu&aacute;nto dura una rotaci&oacute;n completa?</p>
      <div class="opciones-respuesta" id="ops1a">
        <button class="btn-respuesta" onclick="responderParte('1a', false, this)">12 horas</button>
        <button class="btn-respuesta" onclick="responderParte('1a', true, this)">24 horas</button>
        <button class="btn-respuesta" onclick="responderParte('1a', false, this)">365 d&iacute;as</button>
      </div>

      <div id="bloque1b" style="display:none;margin-top:20px;">
        <p style="color:#ffd600;font-weight:800;margin-bottom:10px;">2. &iquest;Qu&eacute; fen&oacute;meno produce la rotaci&oacute;n?</p>
        <div class="opciones-respuesta" id="ops1b">
          <button class="btn-respuesta" onclick="responderParte('1b', false, this)">Las estaciones del a&ntilde;o</button>
          <button class="btn-respuesta" onclick="responderParte('1b', true, this)">El d&iacute;a y la noche</button>
          <button class="btn-respuesta" onclick="responderParte('1b', false, this)">El a&ntilde;o bisiesto</button>
        </div>
      </div>

      <div class="feedback-auditivo" id="fb1"></div>
    </div>
  </div>

  <div class="pagina" id="pagina2">
    <div class="tarjeta-audio">
      <div class="audio-header">
        <div class="audio-icono"><i class="fas fa-orbit"></i></div>
        <div class="audio-titulo">Movimiento de traslaci&oacute;n</div>
      </div>
      <div class="audio-control">
        <audio controls><source src="audios/02-traslacion.mp3" type="audio/mpeg"></audio>
      </div>
      <div class="imagen-grande" onclick="ampliarImagen(this.querySelector('img'))">
        <img src="/contenidos/geografia/recursos/imagenes/libro/traslacion-tierra.jpg"
             alt="Traslaci&oacute;n" class="imagen-geo"
             onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/9/94/Earth_orbit.svg/800px-Earth_orbit.svg.png'">
        <div class="pie-imagen">&#9728; La Tierra orbita alrededor del Sol</div>
      </div>
    </div>

    <div class="reforzamiento-auditivo">
      <div class="ref-titulo"><i class="fas fa-headphones"></i> Identifica y marca</div>
      <p class="ref-instruccion">Escucha la instrucci&oacute;n. Ver&aacute;s una l&iacute;nea de tiempo con cuatro a&ntilde;os seguidos. Haz clic en el que es a&ntilde;o bisiesto.</p>
      <div style="text-align:center;">
        <button class="btn-play-pregunta" id="btnP2" onclick="reproducirPregunta(2)">
          <div class="icono-play"><i class="fas fa-play"></i></div>
          Escuchar instrucci&oacute;n
        </button>
      </div>
      <div class="anios-grid" id="aniosGrid">
        <div class="card-anio" onclick="responderAnio(2021, false, this)">
          <div class="num-anio">2021</div>
          <div class="lbl-anio">A&ntilde;o 1</div>
        </div>
        <div class="card-anio" onclick="responderAnio(2022, false, this)">
          <div class="num-anio">2022</div>
          <div class="lbl-anio">A&ntilde;o 2</div>
        </div>
        <div class="card-anio" onclick="responderAnio(2023, false, this)">
          <div class="num-anio">2023</div>
          <div class="lbl-anio">A&ntilde;o 3</div>
        </div>
        <div class="card-anio" onclick="responderAnio(2024, true, this)">
          <div class="num-anio">2024</div>
          <div class="lbl-anio">A&ntilde;o 4</div>
        </div>
      </div>
      <div class="feedback-auditivo" id="fb2"></div>
    </div>
  </div>

  <div class="pagina" id="pagina3">
    <div class="tarjeta-audio">
      <div class="audio-header">
        <div class="audio-icono"><i class="fas fa-seedling"></i></div>
        <div class="audio-titulo">Las estaciones del a&ntilde;o</div>
      </div>
      <div class="audio-control">
        <audio controls><source src="audios/03-estaciones.mp3" type="audio/mpeg"></audio>
      </div>
      <div class="imagen-grande" onclick="ampliarImagen(this.querySelector('img'))">
        <img src="/contenidos/geografia/recursos/imagenes/libro/estaciones.jpg"
             alt="Estaciones" class="imagen-geo"
             onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/8/8b/Seasons.svg/800px-Seasons.svg.png'">
        <div class="pie-imagen">&#127777; Primavera, verano, oto&ntilde;o, invierno</div>
      </div>
    </div>

    <div class="reforzamiento-auditivo">
      <div class="ref-titulo"><i class="fas fa-headphones"></i> Piensa y responde</div>
      <p class="ref-instruccion">Escucha la situaci&oacute;n. Los hemisferios Norte y Sur siempre tienen estaciones contrarias. Elige qu&eacute; estaci&oacute;n tiene Argentina en ese momento.</p>
      <div style="text-align:center;">
        <button class="btn-play-pregunta" id="btnP3" onclick="reproducirPregunta(3)">
          <div class="icono-play"><i class="fas fa-play"></i></div>
          Escuchar situaci&oacute;n
        </button>
      </div>

      <div style="background:#283593;border-radius:16px;padding:16px;margin-bottom:18px;text-align:center;">
        <p style="color:#ffd600;font-weight:800;font-size:1.1rem;margin-bottom:6px;">&#127474;&#127485; M&eacute;xico (Hemisferio Norte)</p>
        <p style="color:white;font-size:1.4rem;font-weight:800;">&#9728; VERANO</p>
        <p style="color:#b3c5f7;font-size:.95rem;margin-top:6px;">&#8595; Al mismo tiempo, en el otro lado del mundo&#8230;</p>
        <p style="color:#ffd600;font-weight:800;font-size:1.1rem;margin-top:8px;">&#127462;&#127479; Argentina (Hemisferio Sur) tiene&#8230; &iquest;?</p>
      </div>

      <div class="globo-hemisferios">
        <div class="hemi-card" onclick="responderHemi('primavera', false, this)">
          <div class="hemi-icono">&#127807;</div>
          <div class="hemi-nombre">Primavera</div>
        </div>
        <div class="hemi-card" onclick="responderHemi('verano', false, this)">
          <div class="hemi-icono">&#9728;</div>
          <div class="hemi-nombre">Verano</div>
        </div>
        <div class="hemi-card" onclick="responderHemi('invierno', true, this)">
          <div class="hemi-icono">&#10052;</div>
          <div class="hemi-nombre">Invierno</div>
        </div>
        <div class="hemi-card" onclick="responderHemi('otono', false, this)">
          <div class="hemi-icono">&#127810;</div>
          <div class="hemi-nombre">Oto&ntilde;o</div>
        </div>
      </div>
      <div class="feedback-auditivo" id="fb3"></div>
    </div>
  </div>

  <div class="pagina" id="pagina4">
    <div class="tarjeta-audio">
      <div class="audio-header">
        <div class="audio-icono"><i class="fas fa-map"></i></div>
        <div class="audio-titulo">Elementos de los mapas</div>
      </div>
      <div class="audio-control">
        <audio controls><source src="audios/04-mapas.mp3" type="audio/mpeg"></audio>
      </div>
      <div class="imagen-grande" onclick="ampliarImagen(this.querySelector('img'))">
        <img src="/contenidos/geografia/recursos/imagenes/libro/elementos-mapa.jpg"
             alt="Elementos del mapa" class="imagen-geo"
             onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/8/8e/Map_elements.svg/800px-Map_elements.svg.png'">
        <div class="pie-imagen">&#128506; Orientaci&oacute;n, escala, simbolog&iacute;a, coordenadas</div>
      </div>
    </div>

    <div class="reforzamiento-auditivo">
      <div class="ref-titulo"><i class="fas fa-headphones"></i> Escucha e identifica</div>
      <p class="ref-instruccion">Escucha la descripci&oacute;n de un elemento del mapa. Despu&eacute;s haz clic en la tarjeta que corresponde a ese elemento.</p>
      <div style="text-align:center;">
        <button class="btn-play-pregunta" id="btnP4" onclick="reproducirPregunta(4)">
          <div class="icono-play"><i class="fas fa-play"></i></div>
          Escuchar descripci&oacute;n
        </button>
      </div>
      <div class="elementos-grid">
        <div class="elem-card" onclick="responderElemento('orientacion', true, this)">
          <i class="fas fa-compass"></i>
          <div class="elem-nombre">Orientaci&oacute;n</div>
        </div>
        <div class="elem-card" onclick="responderElemento('escala', false, this)">
          <i class="fas fa-ruler"></i>
          <div class="elem-nombre">Escala</div>
        </div>
        <div class="elem-card" onclick="responderElemento('simbologia', false, this)">
          <i class="fas fa-map-signs"></i>
          <div class="elem-nombre">Simbolog&iacute;a</div>
        </div>
        <div class="elem-card" onclick="responderElemento('coordenadas', false, this)">
          <i class="fas fa-map-pin"></i>
          <div class="elem-nombre">Coordenadas</div>
        </div>
      </div>
      <div class="feedback-auditivo" id="fb4"></div>
    </div>
  </div>

  <div class="navegador">
    <button class="btn-nav" id="btnAnterior" onclick="cambiarPagina(-1)" disabled>&#8592; ANTERIOR</button>
    <span class="indicador" id="contadorPagina">1/4</span>
    <button class="btn-nav" id="btnSiguiente" onclick="cambiarPagina(1)">SIGUIENTE &#8594;</button>
  </div>

  <a href="quiz.html" class="btn-quiz" id="btnQuiz" style="display: none;"><i class="fas fa-puzzle-piece me-3"></i> IR AL QUIZ</a>

</div>




<script>   // ===== SISTEMA DE SONIDOS =====   const sonidos = {     pasarPagina: new Audio('/contenidos/geografia/recursos/sonidos/whoosh.mp3'),     click: new Audio('/contenidos/geografia/recursos/sonidos/click.mp3'),     completar: new Audio('/contenidos/geografia/recursos/sonidos/ding.mp3')   };    Object.values(sonidos).forEach(s => {     if (s.src) s.volume = 0.2;   });    function reproducirSonido(nombre) {     if (sonidos[nombre] && sonidos[nombre].src) {       sonidos[nombre].currentTime = 0;       sonidos[nombre].play().catch(() => {});     }   }    // ===== NAVEGACIÓN =====   let paginaActual = 1;   const totalPaginas = 4;    function cambiarPagina(direccion) {     reproducirSonido('pasarPagina');          document.getElementById(`pagina${paginaActual}`).classList.remove('activa');     paginaActual += direccion;     document.getElementById(`pagina${paginaActual}`).classList.add('activa');     actualizarUI();     window.scrollTo({ top: 0, behavior: 'smooth' });     localStorage.setItem('progreso_normal_auditivo', paginaActual);   }    function actualizarUI() {     document.querySelectorAll('.punto').forEach((punto, index) => {       punto.classList.remove('activo', 'completado');       if (index + 1 === paginaActual) punto.classList.add('activo');       else if (index + 1 < paginaActual) punto.classList.add('completado');     });          document.getElementById('paginaActualNum').innerText = paginaActual;     document.getElementById('contadorPagina').innerText = `${paginaActual}/${totalPaginas}`;     document.getElementById('btnAnterior').disabled = (paginaActual === 1);     document.getElementById('btnSiguiente').disabled = (paginaActual === totalPaginas);   }    // ===== MINI PREGUNTAS =====   function responderMini(boton, esCorrecto) {     reproducirSonido('click');          const opciones = boton.parentElement.querySelectorAll('.btn-mini');     opciones.forEach(opt => opt.classList.remove('correcto'));          if (esCorrecto) {       boton.classList.add('correcto');       reproducirSonido('completar');     } else {       boton.style.background = '#f44336';       boton.style.color = 'white';       setTimeout(() => {         boton.style.background = '#ffd600';         boton.style.color = '#01579b';       }, 500);     }   }    // ===== CONTROL DE AUDIOS =====   document.addEventListener('play', function(e) {     if (e.target.tagName === 'AUDIO') {       document.querySelectorAll('audio').forEach(audio => {         if (audio !== e.target && !audio.paused) {           audio.pause();         }       });     }   }, true);    // ===== CARGAR PROGRESO =====   window.addEventListener('DOMContentLoaded', () => {     const guardado = localStorage.getItem('progreso_normal_auditivo');     if (guardado) {       const pag = parseInt(guardado);       if (pag >= 1 && pag <= totalPaginas) {         document.getElementById(`pagina${paginaActual}`).classList.remove('activa');         paginaActual = pag;         document.getElementById(`pagina${paginaActual}`).classList.add('activa');       }     }     actualizarUI();   }); </script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
