        <div class="audio-box"><button type="button" class="audio-btn" data-audio="audio_p2_intro"><i class="fas fa-play"></i></button><div class="audio-label"><i class="fas fa-volume-up me-2"></i>Audio del contenido de la p&aacute;gina 2</div></div>
