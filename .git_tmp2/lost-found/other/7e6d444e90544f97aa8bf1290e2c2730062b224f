<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quiz - Componentes Naturales (Nivel Difícil)</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Fredoka+One&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
</head>
<body>
  <div class="quiz-container">
    <div class="quiz-header">
      <h1>QUIZ · BLOQUE II</h1>
      <div class="quiz-subtitle">Regiones naturales y recursos hídricos</div>
      <div class="badge-level"><i class="fas fa-compass"></i> Nivel Difícil</div>
    </div>

    <div class="quiz-meta">
      <div class="meta-pill"><i class="fas fa-question-circle me-2"></i> 5 preguntas</div>
      <div class="meta-pill"><i class="fas fa-check-circle me-2"></i> Necesitas 4 correctas</div>
      <div class="meta-pill"><i class="fas fa-clock me-2"></i> <span id="timerDisplay">00:00</span></div>
    </div>

    <div class="progress-row" id="progressArea">
      <div class="progress-label" id="questionLabel">Pregunta 1/5</div>
      <div class="progress-track"><div class="progress-fill" id="progressFill"></div></div>
      <div class="meta-pill"><i class="fas fa-star me-2"></i> <span id="scoreBadge">0/5</span></div>
    </div>

    <div class="dots" id="progressDots"></div>

    <div class="question-card" id="questionCard">
      <div class="question-number" id="questionNumber">PREGUNTA 1 DE 5</div>
      <div class="question-text" id="questionText"></div>
      <div class="options" id="options"></div>
      <div class="feedback" id="feedback"></div>
    </div>

    <div class="action-row" id="navRow">
      <button class="btn-quiz btn-alt" id="btnPrev" onclick="anteriorPregunta()" style="display:none;">
        <i class="fas fa-arrow-left me-2"></i> Anterior
      </button>
      <button class="btn-quiz" id="btnNext" onclick="siguientePregunta()">
        Siguiente <i class="fas fa-arrow-right ms-2"></i>
      </button>
      <button class="btn-quiz" id="btnSubmit" onclick="enviarQuiz()" style="display:none;">
        <i class="fas fa-check me-2"></i> Enviar
      </button>
    </div>

    <div class="result" id="result">
      <div class="result-emoji" id="resultEmoji">🎯</div>
      <div class="result-title" id="resultTitle"></div>
      <div class="result-score" id="resultScore"></div>
      <div class="result-message" id="resultMessage"></div>
      <div class="result-time" id="resultTime"></div>
      <div class="action-row" style="margin-top:20px;">
        <button class="btn-quiz" onclick="volverAlContenido()">
          <i class="fas fa-arrow-left me-2"></i> Volver al menú</button>
        <button class="btn-quiz btn-alt" id="btnNextLevel" onclick="irSiguienteNivel()" style="display:none;">
          Siguiente nivel <i class="fas fa-arrow-right ms-2"></i>
        </button>
        <button class="btn-quiz btn-danger" id="btnRetry" onclick="reiniciarQuiz()" style="display:none;">
          <i class="fas fa-redo me-2"></i> Reintentar
        </button>
      </div>
    </div>
  </div>

  

</body>
</html>
