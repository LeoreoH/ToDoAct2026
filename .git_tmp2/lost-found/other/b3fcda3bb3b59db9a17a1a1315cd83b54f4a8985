<style>     * { box-sizing: border-box; }      body {       margin: 0;       font-family: 'Nunito', sans-serif;       background: linear-gradient(135deg, #ede7f6, #f3e5f5);       color: #4a148c;       min-height: 100vh;     }      .cabecera {       background: linear-gradient(135deg, #7b1fa2, #512da8);       color: white;       text-align: center;       padding: 28px 20px;       border-bottom: 6px solid #ffd54f;       box-shadow: 0 8px 20px rgba(0,0,0,0.2);     }      .cabecera h1 {       margin: 0;       font-family: 'Fredoka One', cursive;       font-size: 2.6rem;       text-shadow: 3px 3px 0 rgba(0,0,0,0.15);     }      .cabecera .subtitulo {       margin-top: 8px;       font-weight: 700;       font-size: 1.05rem;     }      .badge-estilo {       display: inline-block;       margin-top: 14px;       background: #ffd54f;       color: #4a148c;       border: 3px solid white;       border-radius: 999px;       padding: 10px 24px;       font-weight: 800;       box-shadow: 0 4px 0 #d39e00;     }      .progreso {       max-width: 920px;       margin: 24px auto 0;       background: white;       border: 3px solid #7b1fa2;       border-radius: 999px;       box-shadow: 0 6px 0 #d1c4e9;       padding: 14px 18px;       display: flex;       align-items: center;       gap: 14px;       flex-wrap: wrap;     }      .progreso .texto {       font-weight: 800;       color: #6a1b9a;       white-space: nowrap;     }      .barra-fondo {       flex: 1;       min-width: 150px;       height: 14px;       background: #ede7f6;       border-radius: 999px;       overflow: hidden;       border: 2px solid #d1c4e9;     }      .barra-relleno {       width: 12.5%;       height: 100%;       background: linear-gradient(90deg, #ab47bc, #7e57c2);       transition: .3s;     }      .porcentaje {       background: #7b1fa2;       color: white;       padding: 7px 14px;       border-radius: 999px;       font-weight: 800;     }      .contenedor {       max-width: 950px;       margin: 26px auto 42px;       padding: 0 16px;     }      .pagina {       display: none;       animation: aparecer .35s ease;     }      .pagina.activa {       display: block;     }      @keyframes aparecer {       from { opacity: 0; transform: translateY(12px); }       to { opacity: 1; transform: translateY(0); }     }      .tarjeta {       background: white;       border: 3px solid #7b1fa2;       border-radius: 30px;       box-shadow: 0 10px 0 #d1c4e9;       padding: 24px;       margin-bottom: 18px;     }      .titulo-pagina {       font-family: 'Fredoka One', cursive;       color: #6a1b9a;       font-size: 2rem;       margin-bottom: 18px;       border-left: 8px solid #ffd54f;       padding-left: 18px;     }      .intro {       background: #faf5ff;       border: 2px dashed #ce93d8;       border-radius: 20px;       padding: 14px 16px;       margin-bottom: 18px;       color: #6a1b9a;       font-weight: 700;     }      .audio-bloque {       background: #faf5ff;       border: 2px dashed #ce93d8;       border-radius: 20px;       padding: 16px;       margin-bottom: 18px;     }      .audio-bloque h4 {       color: #6a1b9a;       font-weight: 800;       margin-top: 0;       margin-bottom: 10px;     }      audio {       width: 100%;       margin-top: 8px;       border-radius: 12px;     }      .apoyo-visual {       background: white;       border: 2px solid #d1c4e9;       border-radius: 20px;       padding: 18px;       text-align: center;       margin-top: 16px;     }      .fila-partes {       display: flex;       justify-content: center;       gap: 8px;       flex-wrap: wrap;       margin: 14px 0;     }      .parte {       width: 76px;       height: 76px;       background: white;       border: 3px solid #7b1fa2;       border-radius: 14px;     }      .parte.coloreada {       background: linear-gradient(135deg, #ab47bc, #7e57c2);     }      .parte.circulo {       border-radius: 50%;     }      .fraccion-chip {       display: inline-block;       background: #ffd54f;       color: #4a148c;       border: 3px solid #7b1fa2;       border-radius: 999px;       padding: 10px 18px;       font-weight: 800;       box-shadow: 0 4px 0 #d39e00;       margin-top: 6px;     }      .recuadro-explica {       background: #fff8e1;       border: 2px solid #ffd54f;       color: #6a1b9a;       border-radius: 16px;       padding: 12px 16px;       font-weight: 700;       margin-top: 16px;     }      .tarjetas-grid {       display: grid;       grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));       gap: 16px;       margin-top: 16px;     }      .mini-tarjeta {       background: #faf5ff;       border: 2px solid #d1c4e9;       border-radius: 20px;       padding: 18px;       text-align: center;       height: 100%;     }      .mini-tarjeta h5 {       color: #6a1b9a;       font-weight: 800;       margin-bottom: 10px;     }      .mini-tarjeta p {       margin: 0;       color: #5e35b1;       font-weight: 700;     }      .comparacion-grid {       display: grid;       grid-template-columns: 1fr auto 1fr;       gap: 18px;       align-items: center;       margin-top: 18px;     }      .signo-compara {       width: 70px;       height: 70px;       border-radius: 50%;       background: #ffd54f;       border: 3px solid #7b1fa2;       display: flex;       align-items: center;       justify-content: center;       font-size: 2rem;       font-weight: 900;       color: #4a148c;       box-shadow: 0 5px 0 #d39e00;       margin: 0 auto;     }      .linea-box {       background: #faf5ff;       border: 2px solid #d1c4e9;       border-radius: 20px;       padding: 18px;       margin-top: 18px;       overflow-x: auto;     }      .linea-numerica {       position: relative;       width: 100%;       min-width: 620px;       height: 120px;     }      .linea-base {       position: absolute;       left: 5%;       right: 5%;       top: 56px;       height: 6px;       background: #7b1fa2;       border-radius: 4px;     }      .marca {       position: absolute;       top: 28px;       transform: translateX(-50%);       text-align: center;       font-weight: 800;       color: #6a1b9a;     }      .marca .punto-linea {       display: block;       font-size: 1.2rem;       margin-top: 4px;     }      .navegador {       display: flex;       justify-content: space-between;       align-items: center;       gap: 15px;       background: white;       border: 3px solid #7b1fa2;       border-radius: 999px;       padding: 14px 20px;       box-shadow: 0 6px 0 #d1c4e9;       flex-wrap: wrap;     }      .btn-nav {       background: #7b1fa2;       color: white;       border: none;       border-radius: 999px;       padding: 12px 24px;       font-weight: 800;       transition: .2s;     }      .btn-nav:hover:not(:disabled) {       background: #5e35b1;       transform: translateY(-2px);     }      .btn-nav:disabled {       opacity: .55;       cursor: not-allowed;     }      .contador {       font-weight: 800;       color: #6a1b9a;       background: #f3e5f5;       border: 2px solid #ce93d8;       padding: 8px 16px;       border-radius: 999px;     }      .boton-quiz {       display: inline-block;       margin: 28px auto 0;       text-decoration: none;       background: #ffd54f;       color: #4a148c;       border: 4px solid #7b1fa2;       padding: 16px 34px;       border-radius: 999px;       font-weight: 800;       font-size: 1.2rem;       box-shadow: 0 7px 0 #d39e00;       transition: .2s;     }      .boton-quiz:hover {       transform: translateY(-3px);       background: #fff3c4;     }      @media (max-width: 768px) {       .cabecera h1 { font-size: 2rem; }       .titulo-pagina { font-size: 1.55rem; }       .parte { width: 60px; height: 60px; }       .comparacion-grid { grid-template-columns: 1fr; }     }   </style>
