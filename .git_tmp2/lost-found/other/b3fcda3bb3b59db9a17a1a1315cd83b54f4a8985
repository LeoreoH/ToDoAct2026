<script>     let paginaActual = 1;     const totalPaginas = 8;      function cambiarPagina(direccion) {       document.getElementById(`pagina${paginaActual}`).classList.remove('activa');       paginaActual += direccion;       document.getElementById(`pagina${paginaActual}`).classList.add('activa');       actualizarNavegacion();       localStorage.setItem('mate_fracciones_auditivo_dificil', paginaActual);     }      function actualizarNavegacion() {       document.getElementById('progresoTexto').innerText = `Página ${paginaActual} de ${totalPaginas}`;       document.getElementById('contadorPagina').innerText = `${paginaActual}/${totalPaginas}`;        const porcentaje = (paginaActual / totalPaginas) * 100;       document.getElementById('barraRelleno').style.width = `${porcentaje}%`;       document.getElementById('progresoPorcentaje').innerText = `${Math.round(porcentaje)}%`;        document.getElementById('btnAnterior').disabled = paginaActual === 1;       document.getElementById('btnSiguiente').disabled = paginaActual === totalPaginas;     }      function cargarProgreso() {       const guardado = localStorage.getItem('mate_fracciones_auditivo_dificil');       if (guardado) {         const pag = parseInt(guardado, 10);         if (pag >= 1 && pag <= totalPaginas) {           document.getElementById(`pagina${paginaActual}`).classList.remove('activa');           paginaActual = pag;           document.getElementById(`pagina${paginaActual}`).classList.add('activa');         }       }       actualizarNavegacion();     }      window.addEventListener('DOMContentLoaded', () => {       cargarProgreso();     });   </script>
