            <path d="M 84 28 Q 108 22 134 32 L 134 54 Q 112 58 90 54 Q 80 46 84 28Z" fill="#4a6fa5" opacity="0.85"/>
          </svg>
          <span>Mapa B</span>
        </div>

        <div class="mapa-opcion" id="mpC" onclick="responderProyeccion('C',true)">
          <svg width="148" height="118" viewBox="0 0 148 118">
            <rect width="148" height="118" fill="#283593" rx="10"/>
            <rect x="5" y="5" width="138" height="108" fill="#1a3a6e" rx="5"/>
            <path d="M 12 12 Q 24 8 36 14 L 38 50 Q 28 58 16 54 Q 8 44 12 12Z" fill="#4a6fa5" opacity="0.85"/>
            <path d="M 14 62 Q 26 58 36 66 L 34 110 Q 24 116 14 112 Q 6 102 14 62Z" fill="#4a6fa5" opacity="0.85"/>
            <path d="M 52 36 Q 82 28 96 40 L 94 112 Q 76 120 58 116 Q 44 106 52 36Z" fill="#4a6fa5" opacity="0.9"/>
            <path d="M 52 18 Q 72 12 88 20 L 86 32 Q 70 36 54 32 Q 48 26 52 18Z" fill="#4a6fa5" opacity="0.85"/>
            <path d="M 52 6 Q 62 4 70 8 L 70 16 Q 62 20 54 16 Q 48 12 52 6Z" fill="#4a6fa5" opacity="0.85"/>
            <path d="M 100 12 Q 130 6 146 16 L 146 50 Q 128 54 106 50 Q 96 42 100 12Z" fill="#4a6fa5" opacity="0.85"/>
            <text x="74" y="80" text-anchor="middle" font-family="Nunito" font-size="8" font-weight="800" fill="#ffd600">AFRICA</text>
            <text x="62" y="10" text-anchor="middle" font-family="Nunito" font-size="6" font-weight="700" fill="#b3c5f7">Groen.</text>
          </svg>
          <span>Mapa C</span>
        </div>

      </div>
      <div class="feedback-auditivo" id="fb4"></div>
    </div>
  </div>

  <div class="navegador">
    <button class="btn-nav" id="btnAnterior" onclick="cambiarPagina(-1)" disabled>&#8592; ANTERIOR</button>
    <span class="indicador" id="contadorPagina">1/4</span>
    <button class="btn-nav" id="btnSiguiente" onclick="cambiarPagina(1)">SIGUIENTE &#8594;</button>
  </div>

  <a href="quiz.html" class="btn-quiz" id="btnQuiz" style="display: none;"><i class="fas fa-puzzle-piece me-3"></i> IR AL QUIZ</a>

