            <path d="M 58 14 Q 72 10 80 18 L 78 32 Q 68 36 60 32 Q 54 24 58 14Z" fill="#4a6fa5" opacity="0.85"/>
            <path d="M 58 36 Q 74 32 82 40 L 80 76 Q 70 84 60 80 Q 50 70 58 36Z" fill="#4a6fa5" opacity="0.85"/>
            <path d="M 86 16 Q 112 10 142 18 L 142 46 Q 122 50 98 46 Q 84 40 86 16Z" fill="#4a6fa5" opacity="0.85"/>
            <text x="110" y="28" text-anchor="middle" font-family="Nunito" font-size="6" font-weight="700" fill="#ffd600">Groenlandia</text>
          </svg>
          <span>Mapa A</span>
        </div>

        <div class="mapa-opcion" id="mpB" onclick="responderProyeccion('B',false)">
          <svg width="148" height="118" viewBox="0 0 148 118">
            <rect width="148" height="118" fill="#283593" rx="10"/>
            <ellipse cx="74" cy="59" rx="68" ry="52" fill="#1a3a6e" stroke="#4a6fa5" stroke-width="2"/>
            <path d="M 16 34 Q 28 28 40 34 L 42 56 Q 34 64 22 60 Q 12 52 16 34Z" fill="#4a6fa5" opacity="0.85"/>
            <path d="M 18 64 Q 30 60 40 68 L 38 94 Q 28 102 18 98 Q 10 88 18 64Z" fill="#4a6fa5" opacity="0.85"/>
