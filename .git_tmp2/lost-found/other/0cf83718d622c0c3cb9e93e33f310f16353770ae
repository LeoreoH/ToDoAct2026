<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>La Tierra &middot; Nivel Dif&iacute;cil &middot; Auditivo</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Fredoka+One&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  
</head>
<body>

<div class="btn-subir" onclick="window.scrollTo({top: 0, behavior: 'smooth'});">
  <i class="fas fa-arrow-up"></i>
</div>

<div class="cabecera">
  <h1>&#127911; LA TIERRA</h1>
  <p class="lead text-white">Bloque I &middot; Nivel Dif&iacute;cil</p>
  <div>
    <span class="badge-estilo">&#127925; Auditivo</span>
    <span class="badge-nivel">&#128293; Avanzado</span>
  </div>
</div>

<div class="progreso-contenedor">
  <i class="fas fa-headphones fa-2x" style="color: #1976d2;"></i>
  <div class="puntos" id="puntosProgreso">
    <div class="punto activo">1</div>
    <div class="punto">2</div>
    <div class="punto">3</div>
    <div class="punto">4</div>
  </div>
  <span class="badge" style="background:#1976d2;color:white;padding:8px 20px;">P&aacute;gina <span id="paginaActualNum">1</span>/4</span>
</div>

<audio id="audP1" src="audios/01-pregunta.mp3"></audio>
<audio id="audP2" src="audios/02-pregunta.mp3"></audio>
<audio id="audP3" src="audios/03-pregunta.mp3"></audio>
<audio id="audP4" src="audios/04-pregunta.mp3"></audio>

<div class="contenedor">

  <div class="pagina activa" id="pagina1">
    <div class="tarjeta-audio">
      <div class="audio-header">
        <div class="audio-icono"><i class="fas fa-globe-americas"></i></div>
        <div class="audio-titulo">Coordenadas geogr&aacute;ficas</div>
      </div>
      <div class="audio-control">
        <audio controls><source src="audios/01-coordenadas.mp3" type="audio/mpeg"></audio>
      </div>
      <div class="imagen-grande" onclick="ampliarImagen(this.querySelector('img'))">
        <img src="/contenidos/geografia/recursos/imagenes/libro/coordenadas.jpg" alt="Coordenadas" class="imagen-geo"
             onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/8/82/World_map_with_latitude_and_longitude.svg/800px-World_map_with_latitude_and_longitude.svg.png'">
        <div class="pie-imagen">&#127758; LATITUD y LONGITUD</div>
      </div>
    </div>

    <div class="reforzamiento-auditivo">
      <div class="ref-titulo"><i class="fas fa-headphones"></i> Escucha y asigna</div>
      <p class="ref-instruccion">
        Escucha la coordenada. Luego haz clic en el valor que corresponde a la <strong style="color:#ffd600;">LATITUD</strong>
        y en el que corresponde a la <strong style="color:#ffd600;">LONGITUD</strong>.
      </p>
      <div style="text-align:center;">
        <button class="btn-play-pregunta" id="btnP1" onclick="reproducirPregunta(1)">
          <div class="icono-play"><i class="fas fa-play"></i></div>
          Escuchar coordenada
        </button>
      </div>

      <div style="background:#283593;border-radius:16px;padding:14px;text-align:center;margin-bottom:20px;">
        <p style="color:#b3c5f7;font-weight:700;font-size:.95rem;margin-bottom:6px;">Coordenada de Ciudad de M&eacute;xico:</p>
        <p style="font-family:'Fredoka One',cursive;font-size:1.6rem;color:white;">19&deg; N &nbsp;&nbsp; 99&deg; O</p>
      </div>

      <p style="color:#ffd600;font-weight:800;text-align:center;margin-bottom:12px;" id="inst1">
        &#8594; Haz clic en el valor que es la <strong>LATITUD</strong>
      </p>
      <div style="display:flex;gap:20px;justify-content:center;flex-wrap:wrap;" id="valores1">
        <div class="asignacion-valor" id="v1-lat" onclick="asignarCoord('lat')">
          19&deg; N
        </div>
        <div class="asignacion-valor" id="v1-lon" onclick="asignarCoord('lon')">
          99&deg; O
        </div>
      </div>
      <div class="feedback-auditivo" id="fb1"></div>
    </div>
  </div>

  <div class="pagina" id="pagina2">
    <div class="tarjeta-audio">
      <div class="audio-header">
        <div class="audio-icono"><i class="fas fa-arrows-alt-h"></i></div>
        <div class="audio-titulo">LATITUD y paralelos</div>
      </div>
      <div class="audio-control">
        <audio controls><source src="audios/02-paralelos.mp3" type="audio/mpeg"></audio>
      </div>
      <div class="imagen-grande" onclick="ampliarImagen(this.querySelector('img'))">
        <img src="/contenidos/geografia/recursos/imagenes/libro/paralelos-detalle.jpg" alt="Paralelos" class="imagen-geo"
             onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/1/14/Latitude_lines.svg/800px-Latitude_lines.svg.png'">
        <div class="pie-imagen">&#128207; Principales paralelos</div>
      </div>
    </div>

    <div class="reforzamiento-auditivo">
      <div class="ref-titulo"><i class="fas fa-headphones"></i> Escucha y se&ntilde;ala</div>
      <p class="ref-instruccion">
        Escucha la descripci&oacute;n de un paralelo. Luego haz clic directamente sobre esa l&iacute;nea en el globo.
      </p>
      <div style="text-align:center;">
        <button class="btn-play-pregunta" id="btnP2" onclick="reproducirPregunta(2)">
          <div class="icono-play"><i class="fas fa-play"></i></div>
          Escuchar descripci&oacute;n
        </button>
      </div>
      <div style="display:flex;justify-content:center;">
        <svg width="280" height="300" viewBox="0 0 280 300">
          <defs>
            <radialGradient id="gPaud" cx="38%" cy="38%" r="60%">
              <stop offset="0%" stop-color="#5c9bd6"/>
              <stop offset="100%" stop-color="#1a3a6e"/>
            </radialGradient>
            <clipPath id="cPaud"><circle cx="140" cy="148" r="108"/></clipPath>
          </defs>
          <circle cx="140" cy="148" r="108" fill="url(#gPaud)" stroke="#4a6fa5" stroke-width="2"/>
          <ellipse cx="108" cy="112" rx="24" ry="30" fill="#3d7a3d" opacity="0.65" clip-path="url(#cPaud)"/>
          <ellipse cx="166" cy="138" rx="28" ry="20" fill="#3d7a3d" opacity="0.65" clip-path="url(#cPaud)"/>
          <ellipse cx="130" cy="184" rx="22" ry="13" fill="#3d7a3d" opacity="0.55" clip-path="url(#cPaud)"/>
          <g class="paralelo-linea-aud" id="pa1" onclick="responderParalelo('pa1',false)">
            <ellipse cx="140" cy="78" rx="58" ry="14" fill="none" stroke="#4a6fa5" stroke-width="4" clip-path="url(#cPaud)" style="pointer-events:stroke;"/>
            <text x="248" y="82" font-family="Nunito" font-size="11" font-weight="700" fill="#7a9cc5">P1</text>
          </g>
          <g class="paralelo-linea-aud" id="pa2" onclick="responderParalelo('pa2',true)">
            <ellipse cx="140" cy="108" rx="98" ry="22" fill="none" stroke="#4a6fa5" stroke-width="4" clip-path="url(#cPaud)" style="pointer-events:stroke;"/>
            <text x="242" y="112" font-family="Nunito" font-size="11" font-weight="700" fill="#7a9cc5">P2</text>
          </g>
          <g class="paralelo-linea-aud" id="pa3" onclick="responderParalelo('pa3',false)">
            <ellipse cx="140" cy="148" rx="108" ry="28" fill="none" stroke="#4a6fa5" stroke-width="4" clip-path="url(#cPaud)" style="pointer-events:stroke;"/>
            <text x="252" y="152" font-family="Nunito" font-size="11" font-weight="700" fill="#7a9cc5">P3</text>
          </g>
          <g class="paralelo-linea-aud" id="pa4" onclick="responderParalelo('pa4',false)">
            <ellipse cx="140" cy="188" rx="98" ry="22" fill="none" stroke="#4a6fa5" stroke-width="4" clip-path="url(#cPaud)" style="pointer-events:stroke;"/>
            <text x="242" y="193" font-family="Nunito" font-size="11" font-weight="700" fill="#7a9cc5">P4</text>
          </g>
          <g class="paralelo-linea-aud" id="pa5" onclick="responderParalelo('pa5',false)">
            <ellipse cx="140" cy="218" rx="58" ry="14" fill="none" stroke="#4a6fa5" stroke-width="4" clip-path="url(#cPaud)" style="pointer-events:stroke;"/>
            <text x="202" y="222" font-family="Nunito" font-size="11" font-weight="700" fill="#7a9cc5">P5</text>
          </g>
          <text x="140" y="16" text-anchor="middle" font-family="Fredoka One" font-size="13" fill="#7a9cc5">Norte</text>
          <text x="140" y="292" text-anchor="middle" font-family="Fredoka One" font-size="13" fill="#7a9cc5">Sur</text>
        </svg>
      </div>
      <div class="feedback-auditivo" id="fb2"></div>
    </div>
  </div>

  <div class="pagina" id="pagina3">
    <div class="tarjeta-audio">
      <div class="audio-header">
        <div class="audio-icono"><i class="fas fa-arrows-alt-v"></i></div>
        <div class="audio-titulo">LONGITUD y meridianos</div>
      </div>
      <div class="audio-control">
        <audio controls><source src="audios/03-meridianos.mp3" type="audio/mpeg"></audio>
      </div>
      <div class="imagen-grande" onclick="ampliarImagen(this.querySelector('img'))">
        <img src="/contenidos/geografia/recursos/imagenes/libro/meridianos-detalle.jpg" alt="Meridianos" class="imagen-geo"
             onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/3/3b/Longitude_lines.svg/800px-Longitude_lines.svg.png'">
        <div class="pie-imagen">&#128205; Meridianos y husos horarios</div>
