    </div>

    <div class="reforzamiento-auditivo">
      <div class="ref-titulo"><i class="fas fa-headphones"></i> Escucha y elige el reloj</div>
      <p class="ref-instruccion">
        Escucha el problema de husos horarios. Luego haz clic en el reloj que muestra la hora correcta.
      </p>
      <div style="text-align:center;">
        <button class="btn-play-pregunta" id="btnP3" onclick="reproducirPregunta(3)">
          <div class="icono-play"><i class="fas fa-play"></i></div>
          Escuchar problema
        </button>
      </div>
      <div style="background:#283593;border-radius:14px;padding:14px;margin-bottom:20px;text-align:center;">
        <p style="color:#b3c5f7;font-size:.95rem;font-weight:700;">
          Son las <strong style="color:#ffd600;">12:00</strong> en Greenwich (0&deg;).<br>
          &iquest;Qu&eacute; hora es en un lugar a <strong style="color:#ffd600;">45&deg; al Este</strong>?
        </p>
      </div>
      <div class="relojes-wrap">

        <div class="reloj-opcion" id="relA" onclick="responderReloj('A',false)">
          <svg width="130" height="130" viewBox="0 0 130 130">
            <defs>
              <radialGradient id="gRA" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#3949ab"/>
                <stop offset="100%" stop-color="#1a237e"/>
              </radialGradient>
            </defs>
            <circle cx="65" cy="65" r="62" fill="url(#gRA)" stroke="#4a6fa5" stroke-width="2.5"/>
            <line x1="65" y1="6"  x2="65" y2="16" stroke="#7a9cc5" stroke-width="2"/>
            <line x1="65" y1="114" x2="65" y2="124" stroke="#7a9cc5" stroke-width="2"/>
            <line x1="6"  y1="65" x2="16" y2="65" stroke="#7a9cc5" stroke-width="2"/>
            <line x1="114" y1="65" x2="124" y2="65" stroke="#7a9cc5" stroke-width="2"/>
            <line x1="65" y1="65" x2="65" y2="20" stroke="#b3c5f7" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="65" y1="65" x2="36" y2="38" stroke="#ffd600" stroke-width="4" stroke-linecap="round"/>
            <circle cx="65" cy="65" r="5" fill="#b3c5f7"/>
          </svg>
          <span>11:00</span>
        </div>

        <div class="reloj-opcion" id="relB" onclick="responderReloj('B',false)">
          <svg width="130" height="130" viewBox="0 0 130 130">
            <defs>
              <radialGradient id="gRB" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#3949ab"/>
                <stop offset="100%" stop-color="#1a237e"/>
              </radialGradient>
            </defs>
            <circle cx="65" cy="65" r="62" fill="url(#gRB)" stroke="#4a6fa5" stroke-width="2.5"/>
            <line x1="65" y1="6"  x2="65" y2="16" stroke="#7a9cc5" stroke-width="2"/>
            <line x1="65" y1="114" x2="65" y2="124" stroke="#7a9cc5" stroke-width="2"/>
            <line x1="6"  y1="65" x2="16" y2="65" stroke="#7a9cc5" stroke-width="2"/>
            <line x1="114" y1="65" x2="124" y2="65" stroke="#7a9cc5" stroke-width="2"/>
            <line x1="65" y1="65" x2="65" y2="20" stroke="#b3c5f7" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="65" y1="65" x2="65" y2="32" stroke="#ffd600" stroke-width="4" stroke-linecap="round"/>
            <circle cx="65" cy="65" r="5" fill="#b3c5f7"/>
          </svg>
          <span>12:00</span>
        </div>

        <div class="reloj-opcion" id="relC" onclick="responderReloj('C',true)">
          <svg width="130" height="130" viewBox="0 0 130 130">
            <defs>
              <radialGradient id="gRC" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#3949ab"/>
                <stop offset="100%" stop-color="#1a237e"/>
              </radialGradient>
            </defs>
            <circle cx="65" cy="65" r="62" fill="url(#gRC)" stroke="#4a6fa5" stroke-width="2.5"/>
            <line x1="65" y1="6"  x2="65" y2="16" stroke="#7a9cc5" stroke-width="2"/>
            <line x1="65" y1="114" x2="65" y2="124" stroke="#7a9cc5" stroke-width="2"/>
            <line x1="6"  y1="65" x2="16" y2="65" stroke="#7a9cc5" stroke-width="2"/>
            <line x1="114" y1="65" x2="124" y2="65" stroke="#7a9cc5" stroke-width="2"/>
            <line x1="65" y1="65" x2="65" y2="20" stroke="#b3c5f7" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="65" y1="65" x2="94" y2="65" stroke="#ffd600" stroke-width="4" stroke-linecap="round"/>
            <circle cx="65" cy="65" r="5" fill="#b3c5f7"/>
          </svg>
          <span>15:00</span>
        </div>

      </div>
      <div class="feedback-auditivo" id="fb3"></div>
    </div>
  </div>

  <div class="pagina" id="pagina4">
    <div class="tarjeta-audio">
      <div class="audio-header">
        <div class="audio-icono"><i class="fas fa-map"></i></div>
        <div class="audio-titulo">Proyecciones cartogr&aacute;ficas</div>
      </div>
      <div class="audio-control">
        <audio controls><source src="audios/04-proyecciones.mp3" type="audio/mpeg"></audio>
      </div>
      <div class="grid-3-imagenes">
        <div class="imagen-pequena" onclick="ampliarImagen(this.querySelector('img'))">
          <img src="/contenidos/geografia/recursos/imagenes/libro/proyeccion-mercator.jpg" alt="Mercator" class="imagen-geo"
               onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/f/fa/Mercator_projection_SW.jpg/800px-Mercator_projection_SW.jpg'">
          <div class="pie-imagen">Mercator</div>
        </div>
        <div class="imagen-pequena" onclick="ampliarImagen(this.querySelector('img'))">
          <img src="/contenidos/geografia/recursos/imagenes/libro/proyeccion-robinson.jpg" alt="Robinson" class="imagen-geo"
               onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/2/2a/Robinson_projection_SW.jpg/800px-Robinson_projection_SW.jpg'">
          <div class="pie-imagen">Robinson</div>
        </div>
        <div class="imagen-pequena" onclick="ampliarImagen(this.querySelector('img'))">
          <img src="/contenidos/geografia/recursos/imagenes/libro/proyeccion-peters.jpg" alt="Peters" class="imagen-geo"
               onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/9/9a/Peters_projection%2C_Japan.jpg/800px-Peters_projection%2C_Japan.jpg'">
          <div class="pie-imagen">Peters</div>
        </div>
      </div>
    </div>

    <div class="reforzamiento-auditivo">
      <div class="ref-titulo"><i class="fas fa-headphones"></i> Escucha y se&ntilde;ala el mapa</div>
      <p class="ref-instruccion">
        Escucha la descripci&oacute;n de una proyecci&oacute;n. Luego haz clic en el mapa que corresponde.
      </p>
      <div style="text-align:center;">
        <button class="btn-play-pregunta" id="btnP4" onclick="reproducirPregunta(4)">
          <div class="icono-play"><i class="fas fa-play"></i></div>
          Escuchar descripci&oacute;n
        </button>
      </div>
      <div class="proyecciones-wrap">

        <div class="mapa-opcion" id="mpA" onclick="responderProyeccion('A',false)">
          <svg width="148" height="118" viewBox="0 0 148 118">
            <rect width="148" height="118" fill="#283593" rx="10"/>
            <rect x="5" y="5" width="138" height="108" fill="#1a3a6e" rx="5"/>
