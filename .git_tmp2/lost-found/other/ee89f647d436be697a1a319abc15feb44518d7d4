<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reconocer fracciones &middot; Nivel normal &middot; Visual verbal</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Fredoka+One&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
<style>     * { margin: 0; padding: 0; box-sizing: border-box; }      body {       font-family: 'Nunito', sans-serif;       background: linear-gradient(135deg, #f3e5f5, #ede7f6);       color: #4a148c;       min-height: 100vh;     }      .cabecera-normal {       background: linear-gradient(135deg, #8e24aa, #5e35b1);       padding: 30px 20px;       border-bottom: 6px solid #ffd54f;       text-align: center;       box-shadow: 0 10px 20px rgba(0,0,0,0.2);       color: white;     }      .cabecera-normal h1 {       font-family: 'Fredoka One', cursive;       font-size: 3rem;       color: white;       text-shadow: 3px 3px 0 rgba(0,0,0,0.15);       margin-bottom: 6px;     }      .badge-estilo {       background: #ffd54f;       color: #4a148c;       padding: 12px 35px;       border-radius: 50px;       font-weight: 800;       font-size: 1.15rem;       display: inline-block;       border: 4px solid white;       margin-top: 10px;     }      .badge-nivel {       background: #4a148c;       color: white;       padding: 8px 25px;       border-radius: 40px;       font-weight: 700;       font-size: 1rem;       display: inline-block;       margin-left: 15px;       border: 2px solid #ffd54f;     }      .barra-progreso {       background: white;       border-radius: 60px;       margin: 25px auto;       max-width: 950px;       padding: 15px 26px;       display: flex;       align-items: center;       gap: 20px;       border: 3px solid #7b1fa2;       box-shadow: 0 5px 0 #d1c4e9;       flex-wrap: wrap;     }      .puntos-progreso {       display: flex;       gap: 12px;       flex: 1;       justify-content: center;       flex-wrap: wrap;     }      .punto {       width: 40px;       height: 40px;       border-radius: 50%;       background: #e1bee7;       border: 3px solid #7b1fa2;       display: flex;       align-items: center;       justify-content: center;       font-weight: 800;       font-size: 1.1rem;       color: #4a148c;       transition: all 0.3s;     }      .punto.activo {       background: #ffd54f;       border-color: #7b1fa2;       color: #4a148c;       transform: scale(1.15);     }      .punto.completado {       background: #4caf50;       border-color: white;       color: white;     }      .contenedor-paginas {       max-width: 1000px;       margin: 0 auto 40px;       padding: 0 20px;     }      .pagina {       display: none;       animation: aparecer 0.5s ease;     }      .pagina.activa {       display: block;     }      @keyframes aparecer {       from { opacity: 0; transform: translateY(20px); }       to { opacity: 1; transform: translateY(0); }     }      .tarjeta-contenido {       background: white;       border-radius: 30px;       padding: 30px;       margin-bottom: 25px;       border: 3px solid #7b1fa2;       box-shadow: 0 8px 0 #d1c4e9;     }      .titulo-pagina {       font-family: 'Fredoka One', cursive;       font-size: 2rem;       color: #6a1b9a;       margin-bottom: 22px;       border-left: 8px solid #ffd54f;       padding-left: 20px;     }      .subtitulo {       font-size: 1.35rem;       font-weight: 700;       color: #7b1fa2;       margin: 24px 0 14px;     }      .recuadro-datos {       background: #faf5ff;       border-radius: 20px;       padding: 20px;       margin: 20px 0;       border-left: 8px solid #ffd54f;     }      .recuadro-datos h4 {       color: #6a1b9a;       font-weight: 800;       margin-bottom: 15px;     }      .lista-iconos {       list-style: none;       padding: 0;       margin: 0;     }      .lista-iconos li {       padding: 8px 0;       display: flex;       align-items: flex-start;       gap: 15px;       border-bottom: 1px solid #e1bee7;     }      .lista-iconos li:last-child {       border-bottom: none;     }      .lista-iconos i {       color: #ffd54f;       font-size: 1.2rem;       width: 28px;       margin-top: 2px;       flex-shrink: 0;     }      .texto-destacado {       background: #fff8e1;       border: 2px solid #ffd54f;       border-radius: 15px;       padding: 15px 20px;       font-weight: 700;       margin: 20px 0;       color: #5e35b1;     }      .modelo-fraccion {       background: #faf5ff;       border: 2px solid #d1c4e9;       border-radius: 22px;       padding: 20px;       margin-top: 18px;       text-align: center;     }      .fila-partes {       display: flex;       justify-content: center;       gap: 8px;       flex-wrap: wrap;       margin: 18px 0 12px;     }      .parte {       width: 70px;       height: 70px;       background: white;       border: 3px solid #7b1fa2;       border-radius: 14px;     }      .parte.coloreada {       background: linear-gradient(135deg, #ab47bc, #7e57c2);     }      .parte.circulo {       border-radius: 50%;     }      .fraccion-grande {       display: inline-block;       font-size: 2.1rem;       font-weight: 800;       color: #6a1b9a;       line-height: 1.1;       min-width: 95px;       text-align: center;     }      .fraccion-grande .linea {       display: block;       height: 4px;       background: #6a1b9a;       border-radius: 2px;       margin: 6px 0;     }      .mini-card {       background: #faf5ff;       border: 2px solid #d1c4e9;       border-radius: 18px;       padding: 18px;       text-align: center;       height: 100%;     }      .mini-card h5 {       color: #6a1b9a;       font-weight: 800;       margin-bottom: 10px;     }      .mini-card p {       margin-bottom: 0;       font-weight: 700;       color: #5e35b1;     }      .tabla-compara {       width: 100%;       border-collapse: collapse;       overflow: hidden;       border-radius: 18px;       margin-top: 15px;     }      .tabla-compara th,     .tabla-compara td {       border: 2px solid #d1c4e9;       padding: 12px;       text-align: center;       font-weight: 700;     }      .tabla-compara th {       background: #f3e5f5;       color: #6a1b9a;     }      .tabla-compara td {       background: white;       color: #5e35b1;     }      .linea-numerica {       position: relative;       height: 120px;       margin-top: 18px;     }      .linea-base {       height: 6px;       background: #7b1fa2;       position: absolute;       top: 52px;       left: 5%;       right: 5%;       border-radius: 4px;     }      .marca {       position: absolute;       top: 38px;       transform: translateX(-50%);       text-align: center;       font-weight: 800;       color: #6a1b9a;     }      .marca .punto-linea {       display: block;       font-size: 1.2rem;       margin-top: 4px;     }      .navegador {       display: flex;       justify-content: space-between;       align-items: center;       margin: 40px 0 20px;       background: white;       padding: 15px 30px;       border-radius: 60px;       border: 3px solid #7b1fa2;       box-shadow: 0 5px 0 #d1c4e9;       gap: 15px;       flex-wrap: wrap;     }      .btn-nav {       background: #ffd54f;       color: #4a148c;       border: none;       padding: 12px 30px;       border-radius: 40px;       font-weight: 800;       font-size: 1.15rem;       border: 3px solid #7b1fa2;       transition: all 0.2s;     }      .btn-nav:hover:not(:disabled) {       background: white;       transform: scale(1.05);     }      .btn-nav:disabled {       background: #e0e0e0;       color: #9e9e9e;       border-color: #bdbdbd;     }      .indicador-pagina {       font-size: 1.35rem;       font-weight: 800;       background: #f3e5f5;       color: #6a1b9a;       padding: 8px 26px;       border-radius: 40px;       border: 3px solid #7b1fa2;     }      .boton-quiz {       display: block;       width: fit-content;       margin: 30px auto 0;       background: #ffd54f;       color: #4a148c;       border: none;       padding: 18px 42px;       border-radius: 60px;       font-weight: 800;       font-size: 1.45rem;       text-decoration: none;       border: 4px solid #7b1fa2;       box-shadow: 0 8px 0 #d39e00;       transition: all 0.2s;     }      .boton-quiz:hover {       transform: translateY(-4px);       box-shadow: 0 12px 0 #d39e00;       background: white;     }      @media (max-width: 768px) {       .cabecera-normal h1 { font-size: 2rem; }       .navegador { flex-direction: column; }       .parte { width: 58px; height: 58px; }       .titulo-pagina { font-size: 1.5rem; }       .badge-nivel { margin-left: 0; margin-top: 10px; }     }   </style>
</head>
<body>
  <header class="cabecera"><button class="btn-volver-menu" onclick="volverAlMenu()" title="Volver al men&uacute;"><i class="fas fa-arrow-left"></i></button><h1><i class="fas fa-chart-pie me-2"></i>FRACCIONES</h1><div class="subtitulo">Reconocer fracciones &middot; Nivel normal</div><div class="badge-estilo"><i class="fas fa-book-open me-2"></i>Estilo visual verbal</div></header>
  <div class="progreso"><span class="progreso-texto" id="progresoTexto">P&aacute;gina 1 de 8</span><div class="barra-fondo"><div class="barra-relleno" id="barraRelleno"></div></div><span class="progreso-num" id="progresoNum">13%</span></div>
  <div class="contenedor"><div class="tarjeta" id="pageHost"></div><div class="navegador"><button class="btn-nav" id="btnAnterior" onclick="cambiarPagina(-1)" disabled>&larr; Anterior</button><span class="contador" id="contadorPagina">1/8</span><button class="btn-nav" id="btnSiguiente" onclick="cambiarPagina(1)" disabled>Siguiente &rarr;</button></div></div>
  
  
<script>   let paginaActual = 1;   const totalPaginas = 6;    function cambiarPagina(direccion) {     document.getElementById(`pagina${paginaActual}`).classList.remove('activa');     paginaActual += direccion;     document.getElementById(`pagina${paginaActual}`).classList.add('activa');     actualizarUI();     localStorage.setItem('progreso_normal_visualverbal_fracciones', paginaActual);   }    function actualizarUI() {     document.querySelectorAll('.punto').forEach((punto, index) => {       const numPagina = index + 1;       punto.classList.remove('activo', 'completado');       if (numPagina === paginaActual) punto.classList.add('activo');       else if (numPagina < paginaActual) punto.classList.add('completado');     });      document.getElementById('paginaActualNum').innerText = paginaActual;     document.getElementById('contadorPagina').innerText = `${paginaActual}/${totalPaginas}`;     document.getElementById('btnAnterior').disabled = (paginaActual === 1);     document.getElementById('btnSiguiente').disabled = (paginaActual === totalPaginas);   }    window.addEventListener('DOMContentLoaded', () => {     const guardado = localStorage.getItem('progreso_normal_visualverbal_fracciones');     if (guardado) {       const pag = parseInt(guardado, 10);       if (pag >= 1 && pag <= totalPaginas) {         document.getElementById(`pagina${paginaActual}`).classList.remove('activa');         paginaActual = pag;         document.getElementById(`pagina${paginaActual}`).classList.add('activa');       }     }     actualizarUI();   }); </script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
