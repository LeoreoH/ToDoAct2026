    function placeCard(zone, card) { clearOrigin(card); removePlaceholder(zone); zone.appendChild(card); if (zone.classList.contains('rank-slot') || zone.classList.contains('bucket-drop') || zone.classList.contains('compare-slot')) zone.classList.add('has-card'); }
    function makeTrayDroppable(trayId) { const tray = document.getElementById(trayId); tray.addEventListener('dragover', (event) => { event.preventDefault(); handleGlobalDragOver(event); }); tray.addEventListener('drop', (event) => { event.preventDefault(); if (!fichaArrastrada) return; placeCard(tray, fichaArrastrada); stopAutoScroll(); }); }
    function zoneValue(id) { const card = document.getElementById(id).querySelector('.ficha'); return card ? card.dataset.value : ''; }
    function allZonesFilled(zoneIds) { return zoneIds.every((id) => document.getElementById(id).querySelector('.ficha')); }
    function evaluateFormPage(page, zoneIds, errorKey) { hideFeedback(page); if (!allZonesFilled(zoneIds)) return; const wrong = zoneIds.filter((id) => { const accepted = (document.getElementById(id).dataset.acceptList || '').split('|').filter(Boolean); return !accepted.includes(zoneValue(id)); }).map((id) => document.getElementById(id)); if (!wrong.length) { zoneIds.forEach((id) => document.getElementById(id).classList.add('correcta')); showFeedback(page, true); resolverPagina(page); } else { registrarError(page, errorKey); markIncorrect(wrong); showFeedback(page, false); } }
    function setupFormPage(page, trayId, zoneIds, errorKey) { makeTrayDroppable(trayId); zoneIds.forEach((id) => { const zone = document.getElementById(id); zone.addEventListener('dragover', (event) => { event.preventDefault(); handleGlobalDragOver(event); }); zone.addEventListener('drop', (event) => { event.preventDefault(); if (actividadesResueltas[page] || !fichaArrastrada) return; if (zone.querySelector('.ficha') && zone.querySelector('.ficha') !== fichaArrastrada) return; placeCard(zone, fichaArrastrada); evaluateFormPage(page, zoneIds, errorKey); stopAutoScroll(); }); }); }
    function evaluateComparePage5() { hideFeedback(5); const zoneIds = ['zoneP5Val1','zoneP5Sign','zoneP5Val2','zoneP5Winner']; if (!allZonesFilled(zoneIds)) return; const left = zoneValue('zoneP5Val1'); const sign = zoneValue('zoneP5Sign'); const right = zoneValue('zoneP5Val2'); const winner = zoneValue('zoneP5Winner'); const validDirect = left === 'dec_060' && sign === 'sign_greater' && right === 'dec_058_j' && winner === 'winner_left'; const validReverse = left === 'dec_058_j' && sign === 'sign_less' && right === 'dec_060' && winner === 'winner_left'; if (validDirect || validReverse) { zoneIds.forEach((id) => document.getElementById(id).classList.add('correcta')); showFeedback(5, true); resolverPagina(5); } else { registrarError(5, 'comparar_jugos'); markIncorrect(zoneIds.map((id) => document.getElementById(id))); showFeedback(5, false); } }
    function setupComparePage5() { const trayId = 'trayP5'; const zoneIds = ['zoneP5Val1','zoneP5Sign','zoneP5Val2','zoneP5Winner']; makeTrayDroppable(trayId); zoneIds.forEach((id) => { const zone = document.getElementById(id); zone.addEventListener('dragover', (event) => { event.preventDefault(); handleGlobalDragOver(event); }); zone.addEventListener('drop', (event) => { event.preventDefault(); if (actividadesResueltas[5] || !fichaArrastrada) return; if (zone.querySelector('.ficha') && zone.querySelector('.ficha') !== fichaArrastrada) return; placeCard(zone, fichaArrastrada); evaluateComparePage5(); stopAutoScroll(); }); }); }
    function evaluateBucketPage(page, trayId, keepId, reviewId, keepExpected, reviewExpected, errorKey) { hideFeedback(page); if (document.getElementById(trayId).querySelector('.ficha')) return; const keepValues = Array.from(document.getElementById(keepId).querySelectorAll('.ficha')).map((card) => card.dataset.value); const reviewValues = Array.from(document.getElementById(reviewId).querySelectorAll('.ficha')).map((card) => card.dataset.value); const keepOk = keepValues.length === keepExpected.length && keepExpected.every((value) => keepValues.includes(value)); const reviewOk = reviewValues.length === reviewExpected.length && reviewExpected.every((value) => reviewValues.includes(value)); if (keepOk && reviewOk) { document.getElementById(keepId).classList.add('correcta'); document.getElementById(reviewId).classList.add('correcta'); showFeedback(page, true); resolverPagina(page); } else { const wrongCards = []; document.getElementById(keepId).querySelectorAll('.ficha').forEach((card) => { if (!keepExpected.includes(card.dataset.value)) wrongCards.push(card); }); document.getElementById(reviewId).querySelectorAll('.ficha').forEach((card) => { if (!reviewExpected.includes(card.dataset.value)) wrongCards.push(card); }); registrarError(page, errorKey); markIncorrect([document.getElementById(keepId), document.getElementById(reviewId), ...wrongCards]); showFeedback(page, false); } }
    function setupBucketPage(page, trayId, keepId, reviewId, keepExpected, reviewExpected, errorKey) { makeTrayDroppable(trayId); [keepId, reviewId].forEach((id) => { const zone = document.getElementById(id); zone.addEventListener('dragover', (event) => { event.preventDefault(); handleGlobalDragOver(event); }); zone.addEventListener('drop', (event) => { event.preventDefault(); if (actividadesResueltas[page] || !fichaArrastrada) return; placeCard(zone, fichaArrastrada); evaluateBucketPage(page, trayId, keepId, reviewId, keepExpected, reviewExpected, errorKey); stopAutoScroll(); }); }); }
    function renderPage1() { document.getElementById('demoP1Pizza').innerHTML = buildPizza(4, 3); document.getElementById('caseP1Pizza').innerHTML = buildPizza(8, 5); renderTray('trayP1', ['num_5','den_8','dec_0625','pct_625','num_6','den_10','dec_058','pct_58'], 'num_5|den_8|dec_0625|pct_625|num_6|den_10|dec_058|pct_58'); }
    function renderPage2() { document.getElementById('demoP2Grid').innerHTML = buildGrid(45); document.getElementById('caseP2Grid').innerHTML = buildGrid(68); renderTray('trayP2', ['frac_17_25','dec_068','pct_68','frac_17_20','dec_086','pct_86'], 'frac_17_25|dec_068|pct_68|frac_17_20|dec_086|pct_86'); }
    function renderPage3() { renderTray('trayP3', ['good_pct375','wrong_pct38','wrong_pct30','wrong_pct36'], 'good_pct375|wrong_pct38|wrong_pct30|wrong_pct36'); attachDragCard(document.getElementById('chipP3Bad')); }
    function renderPage4() { document.getElementById('demoP4Line').innerHTML = buildLine(4, 3); document.getElementById('caseP4Line').innerHTML = buildLine(10, 7); renderTray('trayP4', ['frac_7_10','dec_070','pct_70','frac_7_100','dec_007','pct_17'], 'frac_7_10|dec_070|pct_70|frac_7_100|dec_007|pct_17'); }
    function renderPage5() { document.getElementById('caseP5Left').innerHTML = buildStrip(5, 3); document.getElementById('caseP5Right').innerHTML = buildGrid(58); renderTray('trayP5', ['dec_060','dec_058_j','sign_greater','sign_less','winner_left','winner_right'], 'dec_060|dec_058_j|sign_greater|sign_less|winner_left|winner_right'); }
    function renderPage6() { renderTray('trayP6', ['pct_35','frac_3_8','dec_040','frac_1_2'], 'pct_35|frac_3_8|dec_040|frac_1_2'); }
    function buildPosterCard(offer) { return `<div class="poster-card offer-${offer.accent}"><div class="offer-head"><div class="offer-icon">${offer.icon}</div><div class="offer-meta"><div class="poster-badge">${offer.badge}</div><div class="offer-store">${offer.title}</div></div></div><div class="offer-value">${offer.body}</div><div class="poster-note">${offer.note}</div></div>`; }
    function renderPage7() { const tray = document.getElementById('trayP7'); const values = shuffleArray(['offer_quarter','offer_30','offer_three_eighths','offer_040'], ['offer_quarter|offer_30|offer_three_eighths|offer_040']); tray.innerHTML = values.map((value) => `<div class="ficha offer-piece offer-${p7Offers.find((offer) => offer.value === value).accent}" draggable="true" data-value="${value}">${buildPosterCard(p7Offers.find((offer) => offer.value === value))}</div>`).join(''); document.querySelectorAll('#trayP7 .ficha').forEach(attachDragCard); ['rankP7A','rankP7B','rankP7C','rankP7D'].forEach((id) => { const zone = document.getElementById(id); zone.innerHTML = ''; zone.classList.remove('has-card', 'correcta', 'incorrecta'); restorePlaceholder(zone); }); hideFeedback(7); }
    function reiniciarPagina7() { if (actividadesResueltas[7]) return; renderPage7(); }
    function renderPage8() { renderTray('trayP8', ['pair_3_5','pair_125','pair_075','pair_35'], 'pair_3_5|pair_125|pair_075|pair_35'); }
    function bindMiniQuiz() { const btn = document.getElementById('btnMiniQuiz'); btn.addEventListener('click', async (event) => { event.preventDefault(); if (!actividadesResueltas[8]) return; if (session) await session.complete({ eventoCierre: 'quiz' }); window.location.href = 'quiz.html'; }); }
    window.addEventListener('dragover', handleGlobalDragOver); window.addEventListener('drop', stopAutoScroll);
    window.addEventListener('DOMContentLoaded', () => { rememberPlaceholders(); renderPage1(); renderPage2(); renderPage3(); renderPage4(); renderPage5(); renderPage6(); renderPage7(); renderPage8(); setupFormPage(1, 'trayP1', ['zoneP1Num','zoneP1Den','zoneP1Dec','zoneP1Pct'], 'ticket_pizza'); setupBucketPage(2, 'trayP2', 'binP2Keep', 'binP2Review', ['frac_17_25','dec_068','pct_68'], ['frac_17_20','dec_086','pct_86'], 'clasificar_semillero'); setupFormPage(3, 'trayP3', ['zoneP3Trash','zoneP3Fix'], 'reparar_etiqueta'); setupBucketPage(4, 'trayP4', 'binP4Keep', 'binP4Review', ['frac_7_10','dec_070','pct_70'], ['frac_7_100','dec_007','pct_17'], 'clasificar_recta'); setupComparePage5(); setupFormPage(6, 'trayP6', ['zoneP6A','zoneP6B','zoneP6C','zoneP6D'], 'ordenar_laboratorio'); setupFormPage(7, 'trayP7', ['rankP7A','rankP7B','rankP7C','rankP7D'], 'ordenar_descuentos'); setupFormPage(8, 'trayP8', ['zoneP8A','zoneP8B','zoneP8C','zoneP8D'], 'rescate_final'); bindMiniQuiz(); if (session) session.start(); registrarVisible(); actualizarNavegacion(); });
  </script>
