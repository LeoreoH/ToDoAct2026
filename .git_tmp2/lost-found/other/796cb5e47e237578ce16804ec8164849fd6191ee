    function renderTray(id, values, forbidden) { const tray = document.getElementById(id); const shuffled = shuffleArray(values, forbidden ? [forbidden] : []); tray.innerHTML = shuffled.map((value) => buildCard(value)).join(''); tray.querySelectorAll('.ficha').forEach(attachDragCard); }
