<script>   // ===== SISTEMA DE SONIDOS =====   const sonidos = {     pasarPagina: new Audio('/contenidos/geografia/recursos/sonidos/whoosh.mp3'),     click: new Audio('/contenidos/geografia/recursos/sonidos/click.mp3'),     completar: new Audio('/contenidos/geografia/recursos/sonidos/ding.mp3')   };    Object.values(sonidos).forEach(s => {     if (s.src) s.volume = 0.2;   });    function reproducirSonido(nombre) {     if (sonidos[nombre] && sonidos[nombre].src) {       sonidos[nombre].currentTime = 0;       sonidos[nombre].play().catch(() => {});     }   }    // ===== NAVEGACIÓN =====   let paginaActual = 1;   const totalPaginas = 4;    function cambiarPagina(direccion) {     reproducirSonido('pasarPagina');          document.getElementById(`pagina${paginaActual}`).classList.remove('activa');     paginaActual += direccion;     document.getElementById(`pagina${paginaActual}`).classList.add('activa');     actualizarUI();     window.scrollTo({ top: 0, behavior: 'smooth' });     localStorage.setItem('progreso_normal_visualverbal', paginaActual);   }    function actualizarUI() {     document.querySelectorAll('.punto').forEach((punto, index) => {       punto.classList.remove('activo', 'completado');       if (index + 1 === paginaActual) punto.classList.add('activo');       else if (index + 1 < paginaActual) punto.classList.add('completado');     });          document.getElementById('paginaActualNum').innerText = paginaActual;     document.getElementById('contadorPagina').innerText = `${paginaActual}/${totalPaginas}`;     document.getElementById('btnAnterior').disabled = (paginaActual === 1);     document.getElementById('btnSiguiente').disabled = (paginaActual === totalPaginas);   }    // ===== MINI PREGUNTAS =====   function responderMini(boton, esCorrecto) {     reproducirSonido('click');          const opciones = boton.parentElement.querySelectorAll('.btn-mini');     opciones.forEach(opt => opt.classList.remove('correcto'));          if (esCorrecto) {       boton.classList.add('correcto');       reproducirSonido('completar');     } else {       boton.style.background = '#f44336';       boton.style.color = 'white';       setTimeout(() => {         boton.style.background = 'white';         boton.style.color = '#01579b';       }, 500);     }   }    window.addEventListener('DOMContentLoaded', () => {     const guardado = localStorage.getItem('progreso_normal_visualverbal');     if (guardado) {       const pag = parseInt(guardado);       if (pag >= 1 && pag <= totalPaginas) {         document.getElementById(`pagina${paginaActual}`).classList.remove('activa');         paginaActual = pag;         document.getElementById(`pagina${paginaActual}`).classList.add('activa');       }     }     actualizarUI();   }); </script>
