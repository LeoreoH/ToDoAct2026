        <p class="frase-clave">Partes marcadas &rarr; numerador &bull; Partes totales &rarr; denominador.</p>
        <div class="audio-box">
          <button type="button" class="audio-btn" data-audio="audio_p5_intro"><i class="fas fa-play"></i></button>
          <div class="audio-label"><i class="fas fa-volume-up me-2"></i>Escucha la explicaci&oacute;n</div>
        </div>
        <div class="frac-display">
          <div class="frac-card">
            <div style="width:210px"><div class="strip"><div class="strip-seg fill"></div><div class="strip-seg fill"></div><div class="strip-seg fill"></div><div class="strip-seg"></div></div></div>
            <div class="frac-label">3 partes de 4 iguales</div>
          </div>
          <div class="frac-card">
            <div class="frac-big"><span>3</span><span class="frac-line"></span><span>4</span></div>
            <div class="frac-label">La fracci&oacute;n es 3/4</div>
