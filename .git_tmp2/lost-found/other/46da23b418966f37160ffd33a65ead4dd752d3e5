  <div class="hero">
    <h1><i class="fas fa-chart-pie me-2"></i>FRACCIONES</h1>
    <p class="lead text-white mb-0">Nivel F&aacute;cil &middot; Reconocer fracciones</p>
    <div>
      <span class="pill estilo"><i class="fas fa-headphones"></i> Auditivo</span>
      <span class="pill nivel"><i class="fas fa-seedling"></i> Principiante</span>
    </div>
  </div>

  <div class="progress-shell">
    <i class="fas fa-chart-pie fa-2x" style="color:var(--morado)"></i>
    <div class="progress-dots">
      <div class="dot active" data-page="1">1</div>
      <div class="dot" data-page="2">2</div>
      <div class="dot" data-page="3">3</div>
      <div class="dot" data-page="4">4</div>
      <div class="dot" data-page="5">5</div>
      <div class="dot" data-page="6">6</div>
      <div class="dot" data-page="7">7</div>
    </div>
    <div class="page-pill">P&aacute;gina <span id="paginaActualNum">1</span>/7</div>
  </div>

  <div class="wrap">

    <div class="page active" id="pagina1">
      <div class="card-main">
        <h2 class="title"><i class="fas fa-cookie-bite me-3"></i>Primero vemos la unidad</h2>
        <p class="frase-clave">Toda fracci&oacute;n sale de una unidad completa.</p>
        <div class="audio-box">
          <button type="button" class="audio-btn" data-audio="audio_p1_intro"><i class="fas fa-play"></i></button>
          <div class="audio-label"><i class="fas fa-volume-up me-2"></i>Escucha la explicaci&oacute;n</div>
        </div>
        <div class="strip-wrap">
          <div style="width:100%;max-width:520px">
            <div class="strip"><div class="strip-seg fill"></div></div>
            <div class="strip-label">1 unidad completa</div>
          </div>
        </div>
        <div class="exercise" id="card-p1e1">
          <div class="ex-head"><span class="ex-badge">Ejercicio</span><span class="ex-sub">Escucha y toca</span></div>
          <div class="audio-box">
            <button type="button" class="audio-btn" data-audio="audio_p1_ej1"><i class="fas fa-play"></i></button>
            <div class="audio-label">Escucha el reto y responde con el apoyo visual.</div>
          </div>
          <div class="options" id="p1e1-options">
            <button type="button" class="opt visual" data-value="parte">
              <div class="mini-strip"><div class="part fill"></div><div class="part"></div><div class="part"></div><div class="part"></div></div>
              <span class="caption">Le faltan partes</span>
            </button>
            <button type="button" class="opt visual" data-value="unidad">
              <div class="whole-unit"></div>
              <span class="caption">Unidad</span>
            </button>
            <button type="button" class="opt visual" data-value="numero">
              <div style="display:flex;gap:8px">
                <div class="whole-unit" style="max-width:54px;height:42px"></div>
                <div class="whole-unit" style="max-width:54px;height:42px"></div>
              </div>
              <span class="caption">Dos unidades</span>
            </button>
            <button type="button" class="opt visual" data-value="nada">
              <div class="mini-strip"><div class="part"></div><div class="part"></div><div class="part"></div><div class="part"></div></div>
              <span class="caption">Sin colorear</span>
            </button>
          </div>
          <div class="actions">
            <button type="button" class="btnx main" data-action="verify">Verificar</button>
            <button type="button" class="btnx alt" data-action="clear">Borrar selecci&oacute;n</button>
          </div>
          <div class="feedback" id="p1e1-feedback"></div>
        </div>
      </div>
    </div>

    <div class="page" id="pagina2">
      <div class="card-main">
        <h2 class="title"><i class="fas fa-cut me-3"></i>La misma unidad se puede dividir</h2>
        <p class="frase-clave">Las partes de una fracci&oacute;n deben ser <strong>iguales en tama&ntilde;o</strong>.</p>
        <div class="audio-box">
          <button type="button" class="audio-btn" data-audio="audio_p2_intro"><i class="fas fa-play"></i></button>
          <div class="audio-label"><i class="fas fa-volume-up me-2"></i>Escucha la explicaci&oacute;n</div>
        </div>
        <div class="frac-display">
          <div class="frac-card">
            <div style="width:190px"><div class="strip"><div class="strip-seg"></div><div class="strip-seg"></div><div class="strip-seg"></div><div class="strip-seg"></div></div></div>
            <div class="frac-label">Partes iguales</div>
          </div>
          <div class="frac-card">
            <div class="mini-strip uneven" style="max-width:190px;height:62px">
              <div class="part"></div><div class="part"></div><div class="part"></div><div class="part"></div>
            </div>
            <div class="frac-label">Partes desiguales</div>
          </div>
        </div>
        <div class="exercise" id="card-p2e1">
          <div class="ex-head"><span class="ex-badge">Ejercicio</span><span class="ex-sub">Escucha y toca</span></div>
          <div class="audio-box">
            <button type="button" class="audio-btn" data-audio="audio_p2_ej1"><i class="fas fa-play"></i></button>
            <div class="audio-label">Escucha el reto y responde con el apoyo visual.</div>
          </div>
          <div class="options" id="p2e1-options">
            <button type="button" class="opt visual" data-value="color">
              <div class="mini-strip"><div class="part"></div><div class="part"></div><div class="part"></div></div>
              <span class="caption">3 partes iguales</span>
            </button>
            <button type="button" class="opt visual" data-value="iguales">
              <div class="mini-strip"><div class="part"></div><div class="part"></div><div class="part"></div><div class="part"></div></div>
              <span class="caption">4 partes iguales</span>
            </button>
            <button type="button" class="opt visual" data-value="forma">
              <div class="mini-strip uneven"><div class="part"></div><div class="part"></div><div class="part"></div><div class="part"></div></div>
              <span class="caption">4 partes desiguales</span>
            </button>
            <button type="button" class="opt visual" data-value="muchas">
              <div class="mini-strip"><div class="part"></div><div class="part"></div></div>
              <span class="caption">2 partes iguales</span>
            </button>
          </div>
          <div class="actions">
            <button type="button" class="btnx main" data-action="verify">Verificar</button>
            <button type="button" class="btnx alt" data-action="clear">Borrar selecci&oacute;n</button>
          </div>
          <div class="feedback" id="p2e1-feedback"></div>
        </div>
      </div>
    </div>

    <div class="page" id="pagina3">
      <div class="card-main">
        <h2 class="title"><i class="fas fa-bread-slice me-3"></i>Tomamos partes del todo</h2>
        <p class="frase-clave">El numerador dice cu&aacute;ntas partes tomamos.</p>
        <div class="audio-box">
          <button type="button" class="audio-btn" data-audio="audio_p3_intro"><i class="fas fa-play"></i></button>
          <div class="audio-label"><i class="fas fa-volume-up me-2"></i>Escucha la explicaci&oacute;n</div>
        </div>
        <div class="frac-display">
          <div class="frac-card">
            <div style="width:210px"><div class="strip"><div class="strip-seg fill"></div><div class="strip-seg fill"></div><div class="strip-seg"></div><div class="strip-seg"></div></div></div>
            <div class="frac-label">2 partes de 4 iguales</div>
          </div>
          <div class="frac-card">
            <div class="frac-big"><span>2</span><span class="frac-line"></span><span>4</span></div>
            <div class="frac-label">Dos cuartos</div>
          </div>
        </div>
        <div class="exercise" id="card-p3e1">
          <div class="ex-head"><span class="ex-badge">Ejercicio</span><span class="ex-sub">Escucha y toca</span></div>
          <div class="audio-box">
            <button type="button" class="audio-btn" data-audio="audio_p3_ej1"><i class="fas fa-play"></i></button>
            <div class="audio-label">Escucha el reto y responde con el apoyo visual.</div>
          </div>
          <div class="options" id="p3e1-options">
            <button type="button" class="opt visual" data-value="1/4">
              <div class="mini-strip"><div class="part fill"></div><div class="part"></div><div class="part"></div><div class="part"></div></div>
              <span class="caption">1 de 4</span>
            </button>
            <button type="button" class="opt visual" data-value="2/4">
              <div class="mini-strip"><div class="part fill"></div><div class="part fill"></div><div class="part"></div><div class="part"></div></div>
              <span class="caption">2 de 4</span>
            </button>
            <button type="button" class="opt visual" data-value="3/4">
              <div class="mini-strip"><div class="part fill"></div><div class="part fill"></div><div class="part fill"></div><div class="part"></div></div>
              <span class="caption">3 de 4</span>
            </button>
            <button type="button" class="opt visual" data-value="4/4">
              <div class="mini-strip"><div class="part fill"></div><div class="part fill"></div><div class="part fill"></div><div class="part fill"></div></div>
              <span class="caption">4 de 4</span>
            </button>
          </div>
          <div class="actions">
            <button type="button" class="btnx main" data-action="verify">Verificar</button>
            <button type="button" class="btnx alt" data-action="clear">Borrar selecci&oacute;n</button>
          </div>
          <div class="feedback" id="p3e1-feedback"></div>
        </div>
      </div>
    </div>

    <div class="page" id="pagina4">
      <div class="card-main">
        <h2 class="title"><i class="fas fa-layer-group me-3"></i>Arriba y abajo en la fracci&oacute;n</h2>
        <p class="frase-clave">Numerador arriba &bull; Denominador abajo.</p>
        <div class="audio-box">
          <button type="button" class="audio-btn" data-audio="audio_p4_intro"><i class="fas fa-play"></i></button>
          <div class="audio-label"><i class="fas fa-volume-up me-2"></i>Escucha la explicaci&oacute;n</div>
        </div>
        <div class="frac-display">
          <div class="frac-card" style="min-width:240px">
            <div style="display:flex;align-items:center;justify-content:center;gap:20px">
              <div class="frac-big"><span>2</span><span class="frac-line"></span><span>5</span></div>
              <div style="text-align:left;display:flex;flex-direction:column;gap:18px">
                <div style="font-weight:800;color:#6a1b9a;font-size:.9rem">&#8592; <strong>Numerador</strong><br><span style="color:#5e35b1;font-weight:700">Partes tomadas</span></div>
                <div style="font-weight:800;color:#6a1b9a;font-size:.9rem">&#8592; <strong>Denominador</strong><br><span style="color:#5e35b1;font-weight:700">Total de partes</span></div>
              </div>
            </div>
          </div>
        </div>
        <div class="exercise" id="card-p4e1">
          <div class="ex-head"><span class="ex-badge">Ejercicio</span><span class="ex-sub">Escucha y toca</span></div>
          <div class="audio-box">
            <button type="button" class="audio-btn" data-audio="audio_p4_ej1"><i class="fas fa-play"></i></button>
