<script>     let paginaActual = 1;     const totalPaginas = 4;      function cambiarPagina(direccion) {       document.getElementById(`pagina${paginaActual}`).classList.remove('activa');       paginaActual += direccion;       document.getElementById(`pagina${paginaActual}`).classList.add('activa');       actualizarNavegacion();       localStorage.setItem('mate_fracciones_auditivo_facil', paginaActual);     }      function actualizarNavegacion() {       document.getElementById('progresoTexto').innerText = `Página ${paginaActual} de ${totalPaginas}`;       document.getElementById('contadorPagina').innerText = `${paginaActual}/${totalPaginas}`;        const porcentaje = (paginaActual / totalPaginas) * 100;       document.getElementById('barraRelleno').style.width = `${porcentaje}%`;       document.getElementById('progresoPorcentaje').innerText = `${Math.round(porcentaje)}%`;        document.getElementById('btnAnterior').disabled = paginaActual === 1;       document.getElementById('btnSiguiente').disabled = paginaActual === totalPaginas;     }      function cargarProgreso() {       const guardado = localStorage.getItem('mate_fracciones_auditivo_facil');       if (guardado) {         const pag = parseInt(guardado, 10);         if (pag >= 1 && pag <= totalPaginas) {           document.getElementById(`pagina${paginaActual}`).classList.remove('activa');           paginaActual = pag;           document.getElementById(`pagina${paginaActual}`).classList.add('activa');         }       }       actualizarNavegacion();     }      function reproducirAudio(id) {       const audio = document.getElementById(id);       if (!audio) return;        document.querySelectorAll('audio').forEach(a => {         if (a !== audio) {           a.pause();           a.currentTime = 0;         }       });        audio.play();     }      function inicializarActividad(selector, okId, warnId) {       const opciones = document.querySelectorAll(selector + ' .opcion');       const ok = document.getElementById(okId);       const warn = document.getElementById(warnId);        opciones.forEach(op => {         op.addEventListener('click', () => {           if (op.dataset.correcta === 'true') {             opciones.forEach(x => x.style.pointerEvents = 'none');             op.classList.add('correcta');             warn.classList.remove('visible');             ok.classList.add('visible');           } else {             op.classList.add('incorrecta');             warn.classList.add('visible');             setTimeout(() => op.classList.remove('incorrecta'), 700);           }         });       });     }      window.addEventListener('DOMContentLoaded', () => {       cargarProgreso();       inicializarActividad('#opcionesPagina2', 'feedback2ok', 'feedback2warn');       inicializarActividad('#opcionesPagina3', 'feedback3ok', 'feedback3warn');       inicializarActividad('#opcionesPagina4', 'feedback4ok', 'feedback4warn');     });   </script>
