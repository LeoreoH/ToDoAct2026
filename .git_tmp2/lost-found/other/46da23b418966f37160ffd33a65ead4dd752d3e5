            </button>
            <button type="button" class="opt visual" data-value="numerador">
              <div class="frac-stack">
                <div class="mini-frac"><span>3</span><span class="linea"></span><span>5</span></div>
                <div class="tag-stack"><span class="tag-mini">3 = total</span><span class="tag-mini">5 = tomadas</span></div>
              </div>
            </button>
            <button type="button" class="opt visual" data-value="total">
              <div class="frac-stack">
                <div class="mini-frac"><span>5</span><span class="linea"></span><span>3</span></div>
                <div class="tag-stack"><span class="tag-mini">5 = total</span><span class="tag-mini">3 = tomadas</span></div>
              </div>
            </button>
            <button type="button" class="opt visual" data-value="nada">
              <div class="frac-stack">
                <div class="mini-frac"><span>3</span><span class="linea"></span><span>5</span></div>
                <div class="tag-stack"><span class="tag-mini">3 = tomadas</span><span class="tag-mini">5 = tomadas</span></div>
              </div>
