<style>     * { box-sizing: border-box; }      body {       margin: 0;       font-family: 'Nunito', sans-serif;       background: linear-gradient(135deg, #ede7f6, #f3e5f5);       color: #4a148c;       min-height: 100vh;     }      .cabecera {       background: linear-gradient(135deg, #7b1fa2, #512da8);       color: white;       text-align: center;       padding: 28px 20px;       border-bottom: 6px solid #ffd54f;       box-shadow: 0 8px 20px rgba(0,0,0,0.2);     }      .cabecera h1 {       margin: 0;       font-family: 'Fredoka One', cursive;       font-size: 2.6rem;       text-shadow: 3px 3px 0 rgba(0,0,0,0.15);     }      .cabecera .subtitulo {       margin-top: 8px;       font-weight: 700;       font-size: 1.05rem;     }      .badge-estilo {       display: inline-block;       margin-top: 14px;       background: #ffd54f;       color: #4a148c;       border: 3px solid white;       border-radius: 999px;       padding: 10px 24px;       font-weight: 800;       box-shadow: 0 4px 0 #d39e00;     }      .progreso {       max-width: 920px;       margin: 24px auto 0;       background: white;       border: 3px solid #7b1fa2;       border-radius: 999px;       box-shadow: 0 6px 0 #d1c4e9;       padding: 14px 18px;       display: flex;       align-items: center;       gap: 14px;       flex-wrap: wrap;     }      .progreso .texto {       font-weight: 800;       color: #6a1b9a;       white-space: nowrap;     }      .barra-fondo {       flex: 1;       min-width: 150px;       height: 14px;       background: #ede7f6;       border-radius: 999px;       overflow: hidden;       border: 2px solid #d1c4e9;     }      .barra-relleno {       width: 25%;       height: 100%;       background: linear-gradient(90deg, #ab47bc, #7e57c2);       transition: width .3s;     }      .porcentaje {       background: #7b1fa2;       color: white;       padding: 7px 14px;       border-radius: 999px;       font-weight: 800;     }      .contenedor {       max-width: 950px;       margin: 26px auto 42px;       padding: 0 16px;     }      .pagina {       display: none;       animation: aparecer .35s ease;     }      .pagina.activa {       display: block;     }      @keyframes aparecer {       from { opacity: 0; transform: translateY(12px); }       to { opacity: 1; transform: translateY(0); }     }      .tarjeta {       background: white;       border: 3px solid #7b1fa2;       border-radius: 30px;       box-shadow: 0 10px 0 #d1c4e9;       padding: 24px;       margin-bottom: 18px;     }      .titulo-pagina {       font-family: 'Fredoka One', cursive;       color: #6a1b9a;       font-size: 2rem;       margin-bottom: 18px;       border-left: 8px solid #ffd54f;       padding-left: 18px;     }      .audio-bloque {       background: #faf5ff;       border: 2px dashed #ce93d8;       border-radius: 20px;       padding: 16px;       margin-bottom: 18px;     }      .audio-bloque h4 {       color: #6a1b9a;       font-weight: 800;       margin-top: 0;       margin-bottom: 10px;     }      audio {       width: 100%;       margin-top: 8px;       border-radius: 12px;     }      .apoyo-visual {       background: white;       border: 2px solid #d1c4e9;       border-radius: 20px;       padding: 18px;       text-align: center;       margin-top: 16px;     }      .fila-partes {       display: flex;       justify-content: center;       gap: 8px;       flex-wrap: wrap;       margin: 14px 0;     }      .parte {       width: 76px;       height: 76px;       background: white;       border: 3px solid #7b1fa2;       border-radius: 14px;     }      .parte.coloreada {       background: linear-gradient(135deg, #ab47bc, #7e57c2);     }      .parte.circulo {       border-radius: 50%;     }      .actividad {       background: #faf5ff;       border: 3px dashed #ba68c8;       border-radius: 24px;       padding: 20px;       margin-top: 20px;     }      .actividad h3 {       text-align: center;       color: #6a1b9a;       font-size: 1.35rem;       font-weight: 800;       margin-bottom: 16px;     }      .btn-reproducir {       display: inline-block;       background: #7b1fa2;       color: white;       border: none;       border-radius: 999px;       padding: 12px 22px;       font-weight: 800;       margin: 0 auto 16px;       cursor: pointer;       box-shadow: 0 5px 0 #5e35b1;     }      .btn-reproducir:hover {       background: #5e35b1;     }      .opciones {       display: grid;       grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));       gap: 14px;     }      .opcion {       background: white;       border: 3px solid #7b1fa2;       border-radius: 18px;       padding: 16px;       text-align: center;       font-weight: 800;       color: #6a1b9a;       cursor: pointer;       box-shadow: 0 5px 0 #d1c4e9;       transition: .2s;     }      .opcion:hover {       transform: translateY(-2px);       background: #f7f1ff;     }      .opcion.correcta {       background: #e8f5e9;       border-color: #43a047;       color: #2e7d32;     }      .opcion.incorrecta {       background: #ffebee;       border-color: #e53935;       color: #c62828;     }      .mensaje-feedback {       margin-top: 16px;       padding: 12px 16px;       border-radius: 16px;       font-weight: 800;       text-align: center;       display: none;     }      .mensaje-feedback.visible {       display: block;     }      .mensaje-ok {       background: #e8f5e9;       color: #2e7d32;       border: 2px solid #43a047;     }      .mensaje-warn {       background: #fff8e1;       color: #8d6e00;       border: 2px solid #ffd54f;     }      .navegador {       display: flex;       justify-content: space-between;       align-items: center;       gap: 15px;       background: white;       border: 3px solid #7b1fa2;       border-radius: 999px;       padding: 14px 20px;       box-shadow: 0 6px 0 #d1c4e9;       flex-wrap: wrap;     }      .btn-nav {       background: #7b1fa2;       color: white;       border: none;       border-radius: 999px;       padding: 12px 24px;       font-weight: 800;       transition: .2s;     }      .btn-nav:hover:not(:disabled) {       background: #5e35b1;       transform: translateY(-2px);     }      .btn-nav:disabled {       opacity: .55;       cursor: not-allowed;     }      .contador {       font-weight: 800;       color: #6a1b9a;       background: #f3e5f5;       border: 2px solid #ce93d8;       padding: 8px 16px;       border-radius: 999px;     }      .boton-quiz {       display: inline-block;       margin: 28px auto 0;       text-decoration: none;       background: #ffd54f;       color: #4a148c;       border: 4px solid #7b1fa2;       padding: 16px 34px;       border-radius: 999px;       font-weight: 800;       font-size: 1.2rem;       box-shadow: 0 7px 0 #d39e00;       transition: .2s;     }      .boton-quiz:hover {       transform: translateY(-3px);       background: #fff3c4;     }      @media (max-width: 768px) {       .cabecera h1 { font-size: 2rem; }       .titulo-pagina { font-size: 1.55rem; }       .parte { width: 60px; height: 60px; }     }   </style>
