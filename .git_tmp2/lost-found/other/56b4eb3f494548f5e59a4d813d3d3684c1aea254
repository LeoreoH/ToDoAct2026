<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fracciones: reconocer partes</title>
<link rel="stylesheet" href="menu.css">
</head>

<body>

<header class="bloque-header">
    <button class="boton-volver" onclick="volver()">← Volver</button>
    <h1 id="nombre-bloque">Fracciones: reconocer partes</h1>
</header>

<div class="contenedor-actividad">

    <h2>Elige una opción</h2>

    <div class="contenedor-niveles">

        <button id="btn-diagnostico" onclick="irADiagnostico()">
            <span>Examen diagnóstico</span>
            <span class="descripcion-nivel">
                Descubre tu nivel inicial sobre fracciones
            </span>
        </button>

        <button onclick="mostrarContenidos()">
            <span>Contenidos</span>
            <span class="descripcion-nivel">
                Accede a los niveles del tema
            </span>
        </button>

    </div>

    <div id="bloque-contenidos" style="display:none">

        <h3>Niveles del contenido</h3>

        <div class="contenedor-niveles">
            <button id="btn-facil" onclick="abrirNivel('facil')" disabled>
                <span>Fácil</span>
                <span class="descripcion-nivel">
                    Identifica fracciones simples como 1/2, 1/3 y 1/4
                </span>
            </button>

            <button id="btn-normal" onclick="abrirNivel('normal')" disabled>
                <span>Normal</span>
                <span class="descripcion-nivel">
                    Reconoce fracciones con más partes y distintas representaciones
                </span>
            </button>

            <button id="btn-dificil" onclick="abrirNivel('dificil')" disabled>
                <span>Difícil</span>
                <span class="descripcion-nivel">
                    Interpreta fracciones con mayor precisión y complejidad
                </span>
            </button>
        </div>

    </div>

</div>



    <script src="menu.js"></script>
</body>
</html>
