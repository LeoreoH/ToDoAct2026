<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reconocer fracciones &middot; Nivel dif&iacute;cil &middot; Visual verbal</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Fredoka+One&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    *{box-sizing:border-box} :root{--morado:#7b1fa2;--lila:#ede7f6;--lila2:#faf5ff;--amarillo:#ffd54f;--verde:#43a047;--texto:#4a148c;--sombra:#d1c4e9;--borde:#ce93d8}
    body{margin:0;min-height:100vh;font-family:'Nunito',sans-serif;background:linear-gradient(135deg,#f7f1ff,#ede7f6);color:var(--texto)}
    .cabecera{position:relative;text-align:center;color:#fff;padding:28px 18px;background:linear-gradient(135deg,#8e24aa,#5e35b1);border-bottom:6px solid var(--amarillo);box-shadow:0 10px 24px rgba(0,0,0,.16)}
    .cabecera h1{margin:0;font-family:'Fredoka One',cursive;font-size:2.45rem;text-shadow:3px 3px 0 rgba(0,0,0,.14)} .subtitulo{margin-top:8px;font-size:1.08rem;font-weight:800}
    .badge-estilo{display:inline-block;margin-top:12px;padding:10px 22px;border-radius:999px;background:var(--amarillo);color:var(--texto);border:3px solid white;font-weight:800;box-shadow:0 4px 0 #d39e00}
    .btn-volver-menu{position:absolute;top:16px;left:16px;width:54px;height:54px;border:3px solid white;border-radius:50%;background:var(--amarillo);color:var(--texto);font-size:1.2rem;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 4px 0 #d39e00}
    .progreso{max-width:1040px;margin:22px auto 0;padding:12px 16px;display:flex;gap:14px;align-items:center;flex-wrap:wrap;background:white;border:3px solid var(--morado);border-radius:999px;box-shadow:0 6px 0 var(--sombra)}
    .progreso-texto{font-weight:800;color:#6a1b9a;white-space:nowrap}.barra-fondo{flex:1;min-width:160px;height:14px;background:var(--lila);border-radius:999px;overflow:hidden;border:2px solid var(--sombra)}
    .barra-relleno{width:12.5%;height:100%;background:linear-gradient(90deg,#ab47bc,#7e57c2);transition:width .3s}.progreso-num{padding:7px 14px;border-radius:999px;background:var(--morado);color:white;font-weight:800}
    .contenedor{max-width:1080px;margin:24px auto 42px;padding:0 16px}.tarjeta{background:white;border-radius:28px;border:3px solid var(--morado);box-shadow:0 10px 0 var(--sombra);padding:26px}
    .titulo-pagina{margin-bottom:14px;padding-left:18px;border-left:8px solid var(--amarillo);font-family:'Fredoka One',cursive;font-size:1.85rem;color:#6a1b9a}.texto-destacado{margin-bottom:18px;padding:16px 18px;border-radius:18px;background:var(--lila2);border:2px dashed var(--borde);color:#5e35b1;font-weight:700;line-height:1.66}
    .mini-etiqueta{display:inline-block;margin-bottom:16px;padding:7px 14px;border-radius:999px;background:var(--lila);border:2px solid var(--sombra);color:#6a1b9a;font-weight:800;font-size:.94rem}.modelo-box{background:white;border:2px solid var(--sombra);border-radius:24px;padding:18px;margin-bottom:20px}
    .modelo-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:16px}.model-card{background:var(--lila2);border:2px solid var(--borde);border-radius:22px;padding:16px;text-align:center;box-shadow:0 5px 0 #ead9f8}.model-label{margin-top:10px;font-weight:900;color:#6a1b9a}.model-note{margin-top:8px;color:#7b1fa2;font-size:.92rem;font-weight:700;line-height:1.5}
    .strip{display:grid;grid-template-columns:repeat(var(--parts),1fr);min-height:62px;overflow:hidden;border-radius:16px;border:3px solid var(--morado);background:white}.seg{border-right:3px solid var(--morado);background:white}.seg:last-child{border-right:none}.seg.fill{background:linear-gradient(135deg,#ba68c8,#7e57c2)}
    .fraction-big{display:inline-block;min-width:84px;font-size:2rem;font-weight:900;color:#5e35b1;line-height:1.05}.fraction-big .line{display:block;height:4px;background:#5e35b1;border-radius:2px;margin:6px 0}
    .line-box{position:relative;height:150px}.line-track{position:absolute;left:10%;right:10%;top:78px;height:6px;border-radius:999px;background:#7b1fa2}.tick{position:absolute;top:54px;width:0;height:42px;border-left:3px solid #7b1fa2;transform:translateX(-50%)}.tick span{position:absolute;top:44px;left:50%;transform:translateX(-50%);font-size:.85rem;font-weight:800;color:#6a1b9a;white-space:nowrap}.line-point{position:absolute;top:12px;transform:translateX(-50%);padding:10px 14px;border-radius:999px;background:var(--amarillo);border:3px solid var(--morado);font-weight:900;color:var(--texto);box-shadow:0 4px 0 #d39e00}
    .pizza{width:110px;height:110px;margin:0 auto;border-radius:50%;position:relative;border:4px solid #6d4c41;background:#ffe0b2;box-shadow:inset 0 0 0 6px #ffcc80;overflow:hidden}.pizza .slice{position:absolute;inset:0;background:transparent}.pizza::after{content:'';position:absolute;inset:0;border-radius:50%;background:radial-gradient(circle at center, transparent 0 9px, rgba(109,76,65,.85) 9px 10px, transparent 10px)}
    .jar{width:72px;height:94px;margin:0 auto;border:4px solid var(--morado);border-radius:14px 14px 10px 10px;position:relative;background:white;overflow:hidden}.jar-fill{position:absolute;left:0;right:0;bottom:0;background:#81d4fa}.jar::after{content:'';position:absolute;right:-14px;top:18px;width:14px;height:28px;border:4px solid var(--morado);border-left:none;border-radius:0 12px 12px 0;background:#fff}.jar-line{position:absolute;left:0;right:0;height:2px;background:#ce93d8}.jar-line.l1{top:25%}.jar-line.l2{top:50%}.jar-line.l3{top:75%}
    .actividad{background:var(--lila2);border:3px dashed #ba68c8;border-radius:24px;padding:20px;margin-top:12px}.actividad h3{margin:0 0 12px;text-align:center;color:#6a1b9a;font-size:1.3rem;font-weight:900}.consigna{margin:0 0 16px;color:#6a1b9a;font-weight:700;line-height:1.6}
    .option-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:14px}.opcion-card{width:100%;background:white;border:3px solid var(--morado);border-radius:18px;padding:16px;text-align:left;font-weight:800;color:#6a1b9a;box-shadow:0 5px 0 var(--sombra);cursor:pointer}.opcion-card.selected{background:#f3e5f5;border-color:#ab47bc}
    .order-bank{display:flex;gap:12px;flex-wrap:wrap;justify-content:center;margin-top:16px}.order-chip{padding:10px 16px;border-radius:999px;border:3px solid var(--morado);background:white;color:#6a1b9a;font-weight:900;box-shadow:0 5px 0 var(--sombra);cursor:pointer}.order-chip.used{opacity:.45;pointer-events:none}.answer-track{margin-top:16px;display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:12px}.answer-slot{min-height:64px;padding:12px;border-radius:18px;border:3px dashed #ba68c8;background:white;display:flex;align-items:center;justify-content:center;text-align:center;font-weight:900;color:#6a1b9a}.answer-slot span{opacity:.6}
    .acciones{display:flex;justify-content:center;gap:12px;flex-wrap:wrap;margin-top:18px}.btn-accion{padding:12px 22px;border-radius:999px;border:none;background:var(--morado);color:white;font-weight:900;box-shadow:0 5px 0 var(--sombra);cursor:pointer}.btn-accion.secundario{background:#9575cd}.feedback{display:none;margin-top:16px;padding:12px 16px;border-radius:16px;text-align:center;font-weight:800}.feedback.visible{display:block}.feedback.ok{background:#e8f5e9;border:2px solid var(--verde);color:#2e7d32}.feedback.warn{background:#fff8e1;border:2px solid var(--amarillo);color:#8d6e00}
    .quiz-wrap{text-align:center;margin-top:26px}.boton-quiz{display:inline-block;padding:16px 34px;text-decoration:none;border-radius:999px;background:var(--amarillo);color:var(--texto);border:4px solid var(--morado);font-weight:900;font-size:1.18rem;box-shadow:0 7px 0 #d39e00}.boton-quiz.bloqueado{opacity:.55;cursor:not-allowed;background:#e0e0e0;color:#777;border-color:#bdbdbd;box-shadow:0 7px 0 #9e9e9e}
    .navegador{margin-top:16px;padding:14px 20px;display:flex;justify-content:space-between;align-items:center;gap:15px;flex-wrap:wrap;background:white;border:3px solid var(--morado);border-radius:999px;box-shadow:0 6px 0 var(--sombra)}.btn-nav{padding:12px 24px;border:none;border-radius:999px;background:var(--morado);color:white;font-weight:900}.btn-nav:disabled{opacity:.55;cursor:not-allowed}.contador{padding:8px 16px;border-radius:999px;background:#f3e5f5;border:2px solid #ce93d8;color:#6a1b9a;font-weight:900}
  </style>
</head>
<body>
  <header class="cabecera"><button class="btn-volver-menu" onclick="volverAlMenu()" title="Volver al men&uacute;"><i class="fas fa-arrow-left"></i></button><h1><i class="fas fa-chart-pie me-2"></i>FRACCIONES</h1><div class="subtitulo">Reconocer fracciones &middot; Nivel dif&iacute;cil</div><div class="badge-estilo"><i class="fas fa-book-open me-2"></i>Estilo visual verbal</div></header>
  <div class="progreso"><span class="progreso-texto" id="progresoTexto">P&aacute;gina 1 de 8</span><div class="barra-fondo"><div class="barra-relleno" id="barraRelleno"></div></div><span class="progreso-num" id="progresoNum">13%</span></div>
  <div class="contenedor"><div class="tarjeta" id="pageHost"></div><div class="navegador"><button class="btn-nav" id="btnAnterior" onclick="cambiarPagina(-1)" disabled>&larr; Anterior</button><span class="contador" id="contadorPagina">1/8</span><button class="btn-nav" id="btnSiguiente" onclick="cambiarPagina(1)" disabled>Siguiente &rarr;</button></div></div>
  <script src="/contenidos/recursos/js/reforzamiento-tracker.js"></script>
  <script>
    function strip(parts, filled, label, note) { return `<div class="model-card"><div class="strip" style="--parts:${parts}">${Array.from({length:parts},(_,i)=>`<span class="seg${i<filled?' fill':''}"></span>`).join('')}</div><div class="model-label">${label}</div><div class="model-note">${note}</div></div>`; }
    function line(parts, point, tag, note) { const ticks = Array.from({length:parts+1},(_,i)=>{ const left=10+(80*i/parts); const lbl=i===0?'0':i===parts?'1':`${i}/${parts}`; return `<div class="tick" style="left:${left}%"><span>${lbl}</span></div>`; }).join(''); const left=10+(80*point/parts); return `<div class="model-card"><div class="line-box"><div class="line-track"></div>${ticks}<div class="line-point" style="left:${left}%">${tag}</div></div><div class="model-note">${note}</div></div>`; }
    function pizza(parts, filled, label, note) { return `<div class="model-card"><div class="pizza" data-parts="${parts}" data-filled="${filled}">${Array.from({length:parts},()=>'<span class="slice"></span>').join('')}</div><div class="model-label">${label}</div><div class="model-note">${note}</div></div>`; }
    function jar(fill, label, note) { return `<div class="model-card"><div class="jar"><div class="jar-fill" style="height:${fill}%"></div><div class="jar-line l1"></div><div class="jar-line l2"></div><div class="jar-line l3"></div></div><div class="model-label">${label}</div><div class="model-note">${note}</div></div>`; }
    const PAGES = [
      { page:1, icon:'fas fa-pizza-slice', title:'Pizzer&iacute;a escolar: leer pedidos y modelos', tag:'Idea clave: una misma cantidad puede verse distinta seg&uacute;n en cu&aacute;ntas partes se dividi&oacute; el entero.', intro:'En este nivel ya no basta con leer una sola barra. Ahora debes comparar modelos diferentes, reconocer equivalencias y decidir cu&aacute;l fracci&oacute;n describe mejor una situaci&oacute;n real.', model:`<div class="modelo-grid">${pizza(8,6,'Pizza A','Se vendieron 6 de 8 rebanadas iguales.')}${pizza(4,3,'Pizza B','Se vendieron 3 de 4 rebanadas iguales.')}${pizza(6,4,'Pizza C','Se vendieron 4 de 6 rebanadas iguales.')}</div>`, activity:{ type:'choice', title:'Lee los pedidos', prompt:'&iquest;Qu&eacute; modelo representa mejor la idea &ldquo;se vendieron 6 de 8 rebanadas iguales&rdquo;?', options:[['a','Pizza A, porque muestra 6 partes vendidas de un total de 8.'],['b','Pizza B, porque 3/4 siempre es mayor que cualquier fracci&oacute;n con 8 abajo.'],['c','Pizza C, porque 4/6 y 6/8 siempre significan lo mismo.'],['d','Ninguna, porque no se puede describir una venta con fracciones.']], correct:'a', ok:'Correcto. La situaci&oacute;n dice exactamente 6 de 8 partes iguales.', warn:'Busca el modelo que respete las dos ideas: se vendieron 6 partes y el entero estaba dividido en 8.' } },
      { page:2, icon:'fas fa-glass-water', title:'Puesto de agua fresca: interpretar jarras', tag:'Idea clave: para comparar fracciones distintas puedes apoyarte en referencias como 1/2 o el entero.', intro:'Las jarras tienen el mismo tama&ntilde;o, as&iacute; que puedes comparar su contenido. Si una fracci&oacute;n queda m&aacute;s arriba que otra, representa una cantidad mayor.', model:`<div class="modelo-grid">${jar(66.6,'2/3','Queda por arriba de la mitad.')}${jar(60,'3/5','Tambi&eacute;n queda por arriba de la mitad, pero un poco m&aacute;s abajo.')}${jar(87.5,'7/8','Est&aacute; muy cerca del entero.')}</div>`, activity:{ type:'choice', title:'Compara las cantidades', prompt:'Si Ana llen&oacute; 2/3 de una jarra y Luis 3/5, &iquest;qui&eacute;n llen&oacute; m&aacute;s?', options:[['ana','Ana, porque 2/3 es mayor que 3/5.'],['luis','Luis, porque 5 es mayor que 3.'],['igual','Los dos llenaron exactamente lo mismo.'],['no','No se pueden comparar porque tienen diferente denominador.']], correct:'ana', ok:'As&iacute; es. 2/3 es mayor que 3/5.', warn:'Ap&oacute;yate en el modelo o compara con una misma referencia. Las dos fracciones se pueden comparar.' } },
      { page:3, icon:'fas fa-road', title:'Carrera escolar: ubicar recorridos en la recta', tag:'Idea clave: la recta num&eacute;rica permite leer y comparar fracciones con claridad.', intro:'En una recta, cada salto vale lo mismo. Por eso, si el tramo del 0 al 1 est&aacute; dividido en 8 partes iguales y un punto cae en la sexta marca, la fracci&oacute;n es 6/8.', model:`<div class="modelo-grid">${line(8,6,'P','Del 0 al 1 hay 8 partes iguales y P est&aacute; en la sexta marca.')}<div class="model-card"><div class="model-label">Lectura verbal</div><div class="model-note">P est&aacute; m&aacute;s cerca de 1 que de 1/2.</div></div></div>`, activity:{ type:'choice', title:'Lee la recta', prompt:'&iquest;Qu&eacute; fracci&oacute;n marca el punto P?', options:[['5/8','5/8'],['6/8','6/8'],['7/8','7/8'],['3/4','3/4']], correct:'6/8', ok:'Muy bien. El punto est&aacute; en la sexta marca de ocho partes iguales.', warn:'Cuenta las marcas desde 0 hasta el punto. Esa cantidad debe coincidir con el numerador.' } },
      { page:4, icon:'fas fa-seedling', title:'Huerto escolar: reconocer equivalencias', tag:'Idea clave: dos fracciones equivalentes representan la misma cantidad aunque se escriban distinto.', intro:'Una fracci&oacute;n equivalente conserva la misma porci&oacute;n del entero. Puede verse con m&aacute;s divisiones o con menos, pero sigue cubriendo la misma cantidad.', model:`<div class="modelo-grid">${strip(4,3,'3/4','Tres de cuatro partes iguales.')}${strip(12,9,'9/12','Nueve de doce partes iguales: cubre la misma cantidad.')}${strip(10,7,'7/10','Esta no cubre la misma cantidad.')}</div>`, activity:{ type:'choice', title:'Busca la equivalencia', prompt:'&iquest;Qu&eacute; fracci&oacute;n es equivalente a 3/4?', options:[['9/12','9/12'],['6/10','6/10'],['7/10','7/10'],['3/8','3/8']], correct:'9/12', ok:'Exacto. 3/4 y 9/12 representan la misma cantidad.', warn:'Busca la opci&oacute;n que cubre la misma porci&oacute;n del entero que 3/4.' } },
      { page:5, icon:'fas fa-sort-amount-down', title:'Mercado de listones: ordenar fracciones', tag:'Idea clave: ordenar fracciones exige decidir cu&aacute;l es menor, cu&aacute;l queda en medio y cu&aacute;l es mayor.', intro:'Cuando las fracciones son distintas, conviene apoyarse en el modelo o pensar qu&eacute; tan cerca queda cada una del entero.', model:`<div class="modelo-grid">${strip(8,5,'5/8','Pasa de la mitad, pero no tanto.')}${strip(3,2,'2/3','Es un poco mayor que 5/8.')}${strip(4,3,'3/4','Es la m&aacute;s cercana al entero de las tres.')}</div>`, activity:{ type:'order', title:'Ordena de menor a mayor', prompt:'Haz clic en las fracciones desde la menor hasta la mayor.', items:[['3/4','3/4'],['5/8','5/8'],['2/3','2/3']], correct:['5/8','2/3','3/4'], ok:'Correcto. Ese es el orden de menor a mayor.', warn:'Piensa cu&aacute;l se acerca menos al entero y cu&aacute;l se acerca m&aacute;s.' } },
      { page:6, icon:'fas fa-balance-scale', title:'Reparto para la excursi&oacute;n: cerca de la mitad', tag:'Idea clave: algunas fracciones quedan por debajo de 1/2, otras son exactamente 1/2 y otras la superan.', intro:'Comparar con 1/2 es una estrategia muy &uacute;til. Por ejemplo, 4/8 vale exactamente 1/2, mientras que 2/8 queda por debajo y 5/8 queda por arriba.', model:`<div class="modelo-grid">${strip(8,2,'2/8','Queda por debajo de 1/2.')}${strip(8,4,'4/8','Representa exactamente 1/2.')}${strip(8,5,'5/8','Queda por arriba de 1/2.')}</div>`, activity:{ type:'choice', title:'Elige la afirmaci&oacute;n correcta', prompt:'&iquest;Qu&eacute; relaci&oacute;n hay entre 4/8 y 1/2?', options:[['igual','Representan la misma cantidad.'],['menor','4/8 es menor que 1/2.'],['mayor','4/8 es mayor que 1/2.'],['ninguna','No se pueden comparar.']], correct:'igual', ok:'Muy bien. 4/8 y 1/2 representan la misma distancia o cantidad.', warn:'Observa el modelo central o piensa cu&aacute;nto vale exactamente la mitad de 8 partes.' } },
      { page:7, icon:'fas fa-utensils', title:'Taller de cocina: elegir el modelo correcto', tag:'Idea clave: una situaci&oacute;n verbal debe coincidir con el modelo que la representa.', intro:'A veces el reto no consiste en comparar dos fracciones, sino en elegir el modelo que s&iacute; representa correctamente una situaci&oacute;n escrita.', model:`<div class="modelo-grid">${strip(10,7,'7/10','Siete partes coloreadas de diez.')}${strip(8,7,'7/8','Siete partes coloreadas de ocho.')}${strip(10,3,'3/10','Tres partes coloreadas de diez.')}</div>`, activity:{ type:'choice', title:'Busca el modelo correcto', prompt:'Una bandeja se dividi&oacute; en 10 porciones iguales y quedaron 3 por servir. &iquest;Qu&eacute; modelo representa lo que falt&oacute; por servir?', options:[['7/10','El modelo de 7/10.'],['7/8','El modelo de 7/8.'],['3/10','El modelo de 3/10.'],['1/3','El modelo de 1/3.']], correct:'3/10', ok:'Correcto. Si quedaron 3 de 10 por servir, la fracci&oacute;n faltante es 3/10.', warn:'Busca la fracci&oacute;n que use 10 partes iguales y deje 3 partes como las que faltan.' } },
      { page:8, icon:'fas fa-book-open', title:'Biblioteca m&oacute;vil: decisiones finales', tag:'Idea clave: ya puedes decidir cu&aacute;l fracci&oacute;n est&aacute; m&aacute;s cerca de 1 entero.', intro:'En el reto final conviene mirar qu&eacute; tan poquito le falta a cada fracci&oacute;n para llegar al entero. La m&aacute;s cercana a 1 es la que deja menos espacio por completar.', model:`<div class="modelo-grid">${strip(8,7,'7/8','Solo le falta 1/8 para llegar a 1.')}${strip(6,5,'5/6','Le falta 1/6 para llegar a 1.')}${strip(4,3,'3/4','Le falta 1/4 para llegar a 1.')}</div>`, activity:{ type:'choice', title:'Decide cu&aacute;l est&aacute; m&aacute;s cerca de 1', prompt:'&iquest;Qu&eacute; fracci&oacute;n est&aacute; m&aacute;s cerca del entero completo?', options:[['7/8','7/8'],['5/6','5/6'],['3/4','3/4'],['2/3','2/3']], correct:'7/8', ok:'Excelente. 7/8 es la fracci&oacute;n m&aacute;s cercana a 1.', warn:'Piensa cu&aacute;nto le falta a cada una para completar el entero.' } }
    ];
    let paginaActual = 1; const totalPaginas = PAGES.length; const actividadesResueltas = Object.fromEntries(PAGES.map(p => [p.page,false])); const paginasRegistradas = {}; const state = {};
    const tracker = window.createReforzamientoTracker ? window.createReforzamientoTracker({ trackTime:false, contenidoId:4, nivel:'dificil', estilo:'visual_verbal', detalleBase:{ bloque:'reconocer_fracciones', motor:'vv_dificil' }, apartados:Object.fromEntries(PAGES.map(p => ['frac_vv_dificil_p' + p.page, { pagina:p.page, apartadoClave:'frac_vv_dificil_p' + p.page, tipoActividad:'reforzamiento' }])) }) : null;
    const session = window.createReforzamientoSessionTracker ? window.createReforzamientoSessionTracker({ contenidoId:4, nivel:'dificil', estilo:'visual_verbal' }) : null;
    const sonidos = { pasarPagina:new Audio('/contenidos/matematicas/recursos/sonidos/whoosh.mp3'), click:new Audio('/contenidos/matematicas/recursos/sonidos/click.mp3'), correcto:new Audio('/contenidos/matematicas/recursos/sonidos/ding.mp3'), incorrecto:new Audio('/contenidos/matematicas/recursos/sonidos/error.mp3') }; Object.values(sonidos).forEach(s=>{ if(s&&s.src) s.volume=.2; });
    function volverAlMenu(){ window.location.href='../../menu.html'; } function reproducirSonido(n){ if(sonidos[n]&&sonidos[n].src){ sonidos[n].currentTime=0; sonidos[n].play().catch(()=>{}); } } function sectionKey(page){ return 'frac_vv_dificil_p' + page; } function registrarVisible(){ if(tracker) tracker.markPageVisibleByNumber(paginaActual,{ motor:'vv_dificil' }); }
    function registrarError(page,tipo){ reproducirSonido('incorrecto'); if(tracker) tracker.addError(sectionKey(page),1,{ ejercicio:tipo||'principal' }); }
    function registrarAcierto(page,tipo){ if(!tracker || paginasRegistradas[page]) return; paginasRegistradas[page]=true; tracker.addCorrect(sectionKey(page),1,{ ejercicio:tipo||'principal' }); tracker.complete(sectionKey(page),{ detalle:{ estado:'resuelto', ejercicio:tipo||'principal' } }); }
    function ensureState(page){ if(state[page]) return state[page]; const act = PAGES.find(p=>p.page===page).activity; state[page] = act.type==='choice' ? { selected:null } : { sequence:[] }; return state[page]; }
    function pintarPizzas(){ document.querySelectorAll('.pizza').forEach(el=>{ const parts=Number(el.dataset.parts||1); const filled=Number(el.dataset.filled||0); const slices=[...el.querySelectorAll('.slice')]; slices.forEach((slice,index)=>{ const start=-90 + ((360/parts)*index); const end=-90 + ((360/parts)*(index+1)); const p1=`${(50 + 50*Math.cos(end*Math.PI/180)).toFixed(2)}% ${(50 + 50*Math.sin(end*Math.PI/180)).toFixed(2)}%`; const p2=`${(50 + 50*Math.cos(start*Math.PI/180)).toFixed(2)}% ${(50 + 50*Math.sin(start*Math.PI/180)).toFixed(2)}%`; slice.style.clipPath=`polygon(50% 50%,50% 0,${p1},${p2})`; slice.style.background=index<filled?'#ff8a65':'#fff3e0'; }); }); }
    function renderCurrentPage(){ const page = PAGES[paginaActual-1]; const pageState = ensureState(page.page); const act = page.activity; let activityHtml=''; if(act.type==='choice'){ activityHtml = `<div class="option-grid">${act.options.map(([value,label])=>`<button type="button" class="opcion-card${pageState.selected===value?' selected':''}" data-value="${value}">${label}</button>`).join('')}</div>`; } else { activityHtml = `<div class="order-bank">${act.items.map(([value,label])=>`<button type="button" class="order-chip${pageState.sequence.includes(value)?' used':''}" data-value="${value}">${label}</button>`).join('')}</div><div class="answer-track">${act.items.map((_,index)=>`<div class="answer-slot">${pageState.sequence[index] ? pageState.sequence[index] : '<span>' + (index+1) + '</span>'}</div>`).join('')}</div>`; }
      document.getElementById('pageHost').innerHTML = `<div class="titulo-pagina"><i class="${page.icon} me-2"></i>${page.title}</div><div class="texto-destacado">${page.intro}</div><div class="mini-etiqueta">${page.tag}</div><div class="modelo-box">${page.model}</div><div class="actividad"><h3>${act.title}</h3><p class="consigna">${act.prompt}</p>${activityHtml}<div class="acciones"><button type="button" class="btn-accion" id="verifyBtn">Verificar</button><button type="button" class="btn-accion secundario" id="clearBtn">${act.type==='choice'?'Borrar selecci&oacute;n':'Borrar'}</button></div><div class="feedback ok" id="okMsg">${act.ok}</div><div class="feedback warn" id="warnMsg">${act.warn}</div></div>${paginaActual===totalPaginas?'<div class="quiz-wrap"><a href="quiz.html" class="boton-quiz' + (actividadesResueltas[totalPaginas]?'':' bloqueado') + '" id="btnMiniQuiz" onclick="return validarMiniQuiz(event)"><i class="fas fa-puzzle-piece me-2"></i>Ir al Mini-Quiz</a></div>':''}`;
      pintarPizzas(); wirePage(); }
    function showFeedback(ok){ document.getElementById('okMsg').classList.toggle('visible', ok); document.getElementById('warnMsg').classList.toggle('visible', !ok); }
    function clearFeedback(){ document.getElementById('okMsg').classList.remove('visible'); document.getElementById('warnMsg').classList.remove('visible'); }
    function wirePage(){ const page = PAGES[paginaActual-1]; const pageState = ensureState(page.page); const act = page.activity; if(act.type==='choice'){ [...document.querySelectorAll('.opcion-card')].forEach(btn=>btn.addEventListener('click',()=>{ if(actividadesResueltas[page.page]) return; reproducirSonido('click'); pageState.selected = btn.dataset.value; clearFeedback(); renderCurrentPage(); })); } else { [...document.querySelectorAll('.order-chip')].forEach(btn=>btn.addEventListener('click',()=>{ if(actividadesResueltas[page.page] || pageState.sequence.includes(btn.dataset.value)) return; reproducirSonido('click'); pageState.sequence.push(btn.dataset.value); clearFeedback(); renderCurrentPage(); })); }
      document.getElementById('verifyBtn').addEventListener('click',()=>{ if(actividadesResueltas[page.page]) return; let ok=false; if(act.type==='choice') ok = pageState.selected===act.correct; else ok = pageState.sequence.join('|')===act.correct.join('|'); if(ok){ showFeedback(true); resolverPagina(page.page); if(paginaActual===totalPaginas) setTimeout(renderCurrentPage,0); } else { showFeedback(false); registrarError(page.page, act.type); } });
      document.getElementById('clearBtn').addEventListener('click',()=>{ if(actividadesResueltas[page.page]) return; if(act.type==='choice') pageState.selected=null; else pageState.sequence=[]; clearFeedback(); renderCurrentPage(); });
      const btnQuiz = document.getElementById('btnMiniQuiz'); if(btnQuiz && session){ btnQuiz.addEventListener('click', async (event)=>{ if(!actividadesResueltas[totalPaginas]) return; event.preventDefault(); await session.complete({ eventoCierre:'quiz' }); window.location.href = btnQuiz.getAttribute('href'); }); }
    }
    function cambiarPagina(dir){ paginaActual += dir; reproducirSonido('pasarPagina'); actualizarNavegacion(); registrarVisible(); renderCurrentPage(); window.scrollTo({top:0, behavior:'smooth'}); }
    function actualizarNavegacion(){ document.getElementById('progresoTexto').innerHTML = 'P&aacute;gina ' + paginaActual + ' de ' + totalPaginas; document.getElementById('contadorPagina').innerText = paginaActual + '/' + totalPaginas; const pct=(paginaActual/totalPaginas)*100; document.getElementById('barraRelleno').style.width = pct + '%'; document.getElementById('progresoNum').innerText = Math.round(pct) + '%'; document.getElementById('btnAnterior').disabled = paginaActual===1; document.getElementById('btnSiguiente').disabled = paginaActual===totalPaginas || !actividadesResueltas[paginaActual]; }
    function resolverPagina(page){ actividadesResueltas[page]=true; reproducirSonido('correcto'); registrarAcierto(page,'principal'); actualizarNavegacion(); }
    function validarMiniQuiz(event){ if(!actividadesResueltas[totalPaginas]){ event.preventDefault(); return false; } return true; }
    window.addEventListener('DOMContentLoaded',()=>{ if(session) session.start(); actualizarNavegacion(); registrarVisible(); renderCurrentPage(); });
  </script>
</body>
</html>

