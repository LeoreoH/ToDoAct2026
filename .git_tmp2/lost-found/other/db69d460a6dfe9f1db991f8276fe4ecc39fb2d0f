<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Equivalencias num&eacute;ricas &middot; Nivel Normal &middot; Auditivo</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Fredoka+One&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
</head>
<body>
  <header class="cabecera">
    <button class="btn-volver-menu" title="Volver al men&uacute;"><i class="fas fa-house"></i></button>
    <h1>PORCENTAJES AUDITIVOS</h1>
    <div class="subtitulo">Equivalencias num&eacute;ricas &middot; Nivel Normal</div>
    <div class="badge-estilo">Auditivo</div>
  </header>

  <div class="barra-progreso">
    <span class="progreso-texto" id="progresoTexto">P&aacute;gina 1 de 6</span>
    <div class="barra-fondo"><div class="barra-relleno" id="barraRelleno"></div></div>
    <span class="progreso-num" id="progresoNum">17%</span>
  </div>

  <div class="contenedor">
    <section class="tarjeta">
      <h2 class="titulo-pagina" id="tituloPagina"></h2>
      <div class="texto-destacado" id="leadPagina"></div>

      <div class="audio-stack">
        <div class="audio-box">
          <button type="button" class="audio-btn" id="btnAudioIntro"><i class="fas fa-play"></i></button>
          <div class="audio-label"><i class="fas fa-volume-up me-2"></i>Escucha la explicaci&oacute;n.</div>
        </div>
      </div>

      <div id="contenidoPagina"></div>

      <div class="exercise-box">
        <div class="audio-box">
          <button type="button" class="audio-btn" id="btnAudioEj"><i class="fas fa-play"></i></button>
          <div class="audio-label">Escucha el reto y responde con el apoyo visual.</div>
        </div>
        <div class="exercise-prompt" id="promptActividad">Escucha el reto y responde con el apoyo visual.</div>
        <div id="supportActividad"></div>
        <div id="rootActividad"></div>
        <div class="action-row">
          <button class="btn-accion" id="btnVerificar">Verificar</button>
          <button class="btn-accion" id="btnBorrar">Borrar selecci&oacute;n</button>
        </div>
        <div id="feedback" class="feedback"></div>
      </div>

      <div class="text-center" id="quizWrap"></div>
    </section>

    <div class="navegador">
      <button class="btn-nav" id="btnAnterior" disabled>&larr; Anterior</button>
      <span class="contador" id="contadorPagina">1/6</span>
      <button class="btn-nav" id="btnSiguiente">Siguiente &rarr;</button>
    </div>
  </div>

  
  
</body>
</html>
