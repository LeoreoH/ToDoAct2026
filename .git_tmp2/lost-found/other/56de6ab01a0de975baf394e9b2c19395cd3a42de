    window.EquivVisualVerbalEngine.boot({
      contenidoId: 6,
      nivel: 'dificil',
      estilo: 'visual_no_verbal',
      sectionPrefix: 'equiv_vnv_dificil',
      pages: pages
    });
  </script>
</body>
</html>
