<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>La Tierra &middot; Nivel F&aacute;cil &middot; Auditivo</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Fredoka+One&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  
<style>     * { margin: 0; padding: 0; box-sizing: border-box; }      body {       font-family: 'Nunito', sans-serif;       background: #e3f2fd;       min-height: 100vh;       color: #01579b;     }      .cabecera-auditivo {       background: #1976d2;       padding: 25px 20px;       border-bottom: 6px solid #ffd600;       text-align: center;       box-shadow: 0 10px 20px rgba(0,0,0,0.2);     }      .cabecera-auditivo h1 {       font-family: 'Fredoka One', cursive;       font-size: 3rem;       color: white;       text-shadow: 3px 3px 0 #01579b;     }      .badge-estilo {       background: #ffd600;       color: #01579b;       padding: 12px 35px;       border-radius: 50px;       font-weight: 800;       font-size: 1.3rem;       display: inline-block;       border: 4px solid white;       margin-top: 10px;       box-shadow: 0 4px 0 #b26a00;     }      .progreso-contenedor {       background: white;       border-radius: 60px;       margin: 20px auto;       max-width: 700px;       padding: 12px 25px;       display: flex;       align-items: center;       gap: 15px;       border: 3px solid #1976d2;       box-shadow: 0 5px 0 #0d47a1;     }      .puntos {       display: flex;       gap: 10px;       flex: 1;       justify-content: center;     }      .punto {       width: 35px;       height: 35px;       border-radius: 50%;       background: #bbdefb;       border: 3px solid #1976d2;       display: flex;       align-items: center;       justify-content: center;       font-weight: 800;       color: #01579b;       transition: all 0.3s;     }      .punto.activo {       background: #ffd600;       transform: scale(1.15);     }      .punto.completado {       background: #4caf50;       color: white;       border-color: white;     }      .contenedor {       max-width: 900px;       margin: 0 auto 40px;       padding: 0 20px;     }      .pagina {       display: none;       animation: fadeIn 0.4s ease;     }      .pagina.activa {       display: block;     }      @keyframes fadeIn {       from { opacity: 0; transform: translateY(10px); }       to { opacity: 1; transform: translateY(0); }     }      .tarjeta-audio {       background: white;       border-radius: 30px;       padding: 25px;       margin-bottom: 20px;       border: 3px solid #1976d2;       box-shadow: 0 8px 0 #0d47a1;       transition: all 0.3s;     }      .tarjeta-audio:hover {       transform: translateY(-3px);     }      .audio-header {       display: flex;       align-items: center;       gap: 15px;       margin-bottom: 15px;     }      .audio-icono {       background: #ffd600;       color: #01579b;       width: 60px;       height: 60px;       border-radius: 50%;       display: flex;       align-items: center;       justify-content: center;       font-size: 2rem;       border: 3px solid #1976d2;       box-shadow: 0 4px 0 #b26a00;     }      .audio-titulo {       font-size: 1.5rem;       font-weight: 800;       color: #01579b;     }      .audio-control {       width: 100%;       margin: 15px 0;     }      audio {       width: 100%;       border-radius: 30px;       border: 2px solid #1976d2;     }      /* IMAGEN GRANDE CON ANIMACIÓN */     .imagen-grande {       background: #e3f2fd;       border-radius: 20px;       padding: 20px;       margin: 15px 0;       text-align: center;       border: 3px dashed #1976d2;       transition: all 0.3s ease;     }      .imagen-grande:hover {       transform: scale(1.02) rotate(1deg);       box-shadow: 0 10px 20px rgba(25,118,210,0.3);     }      .imagen-geo {       width: 100%;       max-height: 250px;       object-fit: contain;       border-radius: 15px;       border: 3px solid white;     }      .pie-imagen {       color: #01579b;       font-size: 1rem;       margin-top: 10px;       font-weight: 700;       text-align: center;     }      /* MINI PREGUNTA (estilo visual no verbal) */     .mini-pregunta {       background: #283593;       border: 4px solid #ffd600;       border-radius: 30px;       padding: 25px;       margin: 30px 0 20px;       text-align: center;     }      .mini-pregunta p {       font-size: 1.4rem;       font-weight: 700;       color: #ffd600;       margin-bottom: 20px;     }      .opciones-mini {       display: flex;       justify-content: center;       gap: 20px;       flex-wrap: wrap;     }      .btn-mini {       background: #ffd600;       color: #0d47a1;       border: 4px solid white;       padding: 12px 35px;       border-radius: 50px;       font-weight: 800;       font-size: 1.2rem;       cursor: pointer;       transition: all 0.2s;     }      .btn-mini:hover {       transform: scale(1.05);       background: white;     }      .btn-mini.correcto {       background: #4caf50;       color: white;     }      .navegador {       display: flex;       justify-content: space-between;       align-items: center;       background: white;       padding: 15px 25px;       border-radius: 60px;       border: 3px solid #1976d2;       box-shadow: 0 5px 0 #0d47a1;       margin: 30px 0;     }      .btn-nav {       background: #ffd600;       color: #01579b;       border: none;       padding: 10px 25px;       border-radius: 40px;       font-weight: 800;       border: 3px solid #1976d2;       transition: all 0.2s;     }      .btn-nav:hover:not(:disabled) {       background: white;       transform: translateY(-2px);     }      .btn-nav:disabled {       background: #e0e0e0;       color: #9e9e9e;       border-color: #bdbdbd;     }      .indicador {       background: #e3f2fd;       color: #01579b;       padding: 8px 30px;       border-radius: 40px;       font-weight: 800;       font-size: 1.3rem;       border: 3px solid #1976d2;     }      .btn-quiz {       display: block;       width: fit-content;       margin: 0 auto;       background: #ffd600;       color: #01579b;       border: none;       padding: 15px 45px;       border-radius: 60px;       font-weight: 800;       font-size: 1.5rem;       text-decoration: none;       border: 4px solid #1976d2;       box-shadow: 0 6px 0 #0d47a1;       transition: all 0.2s;     }      .btn-quiz:hover {       transform: translateY(-4px);       box-shadow: 0 10px 0 #0d47a1;       background: white;     }      .btn-subir {       position: fixed;       bottom: 80px;       right: 20px;       background: #ffd600;       color: #01579b;       width: 50px;       height: 50px;       border-radius: 50%;       display: flex;       align-items: center;       justify-content: center;       font-size: 1.5rem;       border: 3px solid #1976d2;       box-shadow: 0 4px 0 #0d47a1;       cursor: pointer;       transition: all 0.2s;       z-index: 1000;     }      .btn-subir:hover {       transform: translateY(-5px);       box-shadow: 0 8px 0 #0d47a1;     }   </style>
</head>
<body>

<div class="btn-subir" onclick="window.scrollTo({top: 0, behavior: 'smooth'});">
  <i class="fas fa-arrow-up"></i>
</div>

<div class="cabecera-auditivo">
  <h1>&#127911; LA TIERRA</h1>
  <p class="lead">Bloque I &middot; Nivel F&aacute;cil</p>
  <div class="badge-estilo">&#127925; Estilo Auditivo</div>
</div>

<div class="progreso-contenedor">
  <i class="fas fa-headphones fa-2x" style="color: #1976d2;"></i>
  <div class="puntos" id="puntosProgreso">
    <div class="punto activo">1</div>
    <div class="punto">2</div>
    <div class="punto">3</div>
    <div class="punto">4</div>
  </div>
  <span class="badge" style="background: #1976d2; color: white; padding: 8px 20px;">P&aacute;gina <span id="paginaActualNum">1</span>/4</span>
</div>

<audio id="audPregunta1" src="audios/01-pregunta.mp3"></audio>
<audio id="audPregunta2" src="audios/02-pregunta.mp3"></audio>
<audio id="audPregunta3" src="audios/03-pregunta.mp3"></audio>
<audio id="audPregunta4" src="audios/04-pregunta.mp3"></audio>

<div class="contenedor">

  <div class="pagina activa" id="pagina1">

    <div class="tarjeta-audio">
      <div class="audio-header">
        <div class="audio-icono"><i class="fas fa-globe-americas"></i></div>
        <div class="audio-titulo">Nuestro planeta</div>
      </div>
      <div class="audio-control">
        <audio controls><source src="audios/01-introduccion.mp3" type="audio/mpeg"></audio>
      </div>
      <div class="imagen-grande" onclick="ampliarImagen(this.querySelector('img'))">
        <img src="/contenidos/geografia/recursos/imagenes/libro/tierra-satelital.jpg" alt="Tierra" class="imagen-geo"
             onerror="this.src='https://eoimages.gsfc.nasa.gov/images/imagerecords/57000/57723/globe_west_2048.jpg'">
        <div class="pie-imagen">&#127757; Vista desde el espacio</div>
      </div>
    </div>

    <div class="tarjeta-audio">
      <div class="audio-header">
        <div class="audio-icono"><i class="fas fa-ruler"></i></div>
        <div class="audio-titulo">Forma de la Tierra</div>
      </div>
      <div class="imagen-grande" onclick="ampliarImagen(this.querySelector('img'))">
        <img src="/contenidos/geografia/recursos/imagenes/libro/forma-tierra.jpg" alt="Forma" class="imagen-geo"
             onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/4/4e/Earth_oblique.svg/800px-Earth_oblique.svg.png'">
        <div class="pie-imagen">&#128208; Achatada en los polos</div>
      </div>
    </div>

    <div class="reforzamiento-auditivo">
      <div class="ref-titulo"><i class="fas fa-headphones"></i> Contesta</div>
      <p class="ref-instruccion">Escucha la pregunta y elige la respuesta correcta.</p>
      <div style="text-align:center;">
        <button class="btn-play-pregunta" id="btnP1" onclick="reproducirPregunta(1)">
          <div class="icono-play"><i class="fas fa-play"></i></div>
          Escuchar pregunta
        </button>
      </div>
      <div class="opciones-respuesta">
        <button class="btn-respuesta" onclick="responder(1, false, this)">S&iacute;, es redonda perfecta</button>
        <button class="btn-respuesta" onclick="responder(1, true, this)">No, est&aacute; achatada en los polos</button>
      </div>
      <div class="feedback-auditivo" id="fb1"></div>
    </div>

  </div>

  <div class="pagina" id="pagina2">

    <div class="tarjeta-audio">
      <div class="audio-header">
        <div class="audio-icono"><i class="fas fa-map-marked-alt"></i></div>
        <div class="audio-titulo">L&iacute;neas imaginarias</div>
      </div>
      <div class="audio-control">
        <audio controls><source src="audios/02-lineas.mp3" type="audio/mpeg"></audio>
      </div>
      <div class="imagen-grande" onclick="ampliarImagen(this.querySelector('img'))">
        <img src="/contenidos/geografia/recursos/imagenes/libro/paralelos-meridianos.jpg" alt="Paralelos" class="imagen-geo"
             onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/6/6d/World_map_with_equator.jpg'">
        <div class="pie-imagen">&#128506; Paralelos y meridianos</div>
      </div>
      <div class="imagen-grande mt-3" onclick="ampliarImagen(this.querySelector('img'))">
        <img src="/contenidos/geografia/recursos/imagenes/libro/globo-lineas.jpg" alt="Globo" class="imagen-geo"
             onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/8/8d/Globo_terrestre.svg'">
        <div class="pie-imagen">&#127758; Globo terr&aacute;queo</div>
      </div>
    </div>

    <div class="reforzamiento-auditivo">
      <div class="ref-titulo"><i class="fas fa-headphones"></i> Contesta</div>
      <p class="ref-instruccion">Escucha la pregunta y elige la respuesta correcta.</p>
      <div style="text-align:center;">
        <button class="btn-play-pregunta" id="btnP2" onclick="reproducirPregunta(2)">
          <div class="icono-play"><i class="fas fa-play"></i></div>
          Escuchar pregunta
        </button>
      </div>
      <div class="opciones-respuesta">
        <button class="btn-respuesta" onclick="responder(2, true, this)">Norte y Sur</button>
        <button class="btn-respuesta" onclick="responder(2, false, this)">Este y Oeste</button>
      </div>
      <div class="feedback-auditivo" id="fb2"></div>
    </div>

  </div>

  <div class="pagina" id="pagina3">

    <div class="tarjeta-audio">
      <div class="audio-header">
        <div class="audio-icono"><i class="fas fa-compass"></i></div>
        <div class="audio-titulo">Puntos cardinales</div>
      </div>
      <div class="audio-control">
        <audio controls><source src="audios/03-orientacion.mp3" type="audio/mpeg"></audio>
      </div>
      <div class="imagen-grande" onclick="ampliarImagen(this.querySelector('img'))">
        <img src="/contenidos/geografia/recursos/imagenes/libro/rosa-nautica.png" alt="Rosa" class="imagen-geo"
             onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/3/3a/Compass_Rose_English_North.svg/800px-Compass_Rose_English_North.svg.png'">
        <div class="pie-imagen">&#129517; Rosa de los vientos</div>
      </div>
    </div>

    <div class="reforzamiento-auditivo">
      <div class="ref-titulo"><i class="fas fa-headphones"></i> Responde</div>
      <p class="ref-instruccion">Escucha la pregunta con atenci&oacute;n y selecciona la opci&oacute;n correcta.</p>
      <div style="text-align:center;">
        <button class="btn-play-pregunta" id="btnP3" onclick="reproducirPregunta(3)">
          <div class="icono-play"><i class="fas fa-play"></i></div>
          Escuchar pregunta
        </button>
      </div>
      <div class="opciones-respuesta">
        <button class="btn-respuesta" onclick="responder(3, true, this)">Este</button>
        <button class="btn-respuesta" onclick="responder(3, false, this)">Oeste</button>
        <button class="btn-respuesta" onclick="responder(3, false, this)">Norte</button>
      </div>
      <div class="feedback-auditivo" id="fb3"></div>
    </div>

  </div>

  <div class="pagina" id="pagina4">

    <div class="tarjeta-audio">
      <div class="audio-header">
        <div class="audio-icono"><i class="fas fa-temperature-high"></i></div>
        <div class="audio-titulo">Zonas t&eacute;rmicas</div>
      </div>
      <div class="audio-control">
        <audio controls><source src="audios/04-zonas.mp3" type="audio/mpeg"></audio>
      </div>
      <div class="imagen-grande" onclick="ampliarImagen(this.querySelector('img'))">
        <img src="/contenidos/geografia/recursos/imagenes/libro/zonas-termicas.jpg" alt="Zonas" class="imagen-geo"
             onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/0/0a/Climate_zones.svg/800px-Climate_zones.svg.png'">
        <div class="pie-imagen">&#127777; 5 zonas t&eacute;rmicas</div>
      </div>
      <div class="imagen-grande mt-3" onclick="ampliarImagen(this.querySelector('img'))">
        <img src="/contenidos/geografia/recursos/imagenes/libro/zona-fria.jpg" alt="Zona fr&iacute;a" class="imagen-geo"
             onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/f/f6/Arctic_ice.jpg'">
        <div class="pie-imagen">&#10052; Zona fr&iacute;a</div>
      </div>
    </div>

    <div class="tarjeta-audio" style="background: #ffd600; border-color: #01579b;">
      <div class="text-center">
        <i class="fas fa-map-pin fa-3x" style="color: #01579b;"></i>
        <h3 class="fw-bold" style="color: #01579b;">&#161;M&eacute;xico est&aacute; en la zona templada!</h3>
      </div>
    </div>

    <div class="reforzamiento-auditivo">
      <div class="ref-titulo"><i class="fas fa-headphones"></i> Contesta</div>
      <p class="ref-instruccion">Escucha la pregunta y elige en qu&eacute; zona t&eacute;rmica se encuentra M&eacute;xico.</p>
      <div style="text-align:center;">
        <button class="btn-play-pregunta" id="btnP4" onclick="reproducirPregunta(4)">
          <div class="icono-play"><i class="fas fa-play"></i></div>
          Escuchar pregunta
        </button>
      </div>
      <div class="opciones-respuesta">
        <button class="btn-respuesta" onclick="responder(4, false, this)">C&aacute;lida</button>
        <button class="btn-respuesta" onclick="responder(4, true, this)">Templada</button>
        <button class="btn-respuesta" onclick="responder(4, false, this)">Fr&iacute;a</button>
      </div>
      <div class="feedback-auditivo" id="fb4"></div>
    </div>

  </div>

  <div class="navegador">
    <button class="btn-nav" id="btnAnterior" onclick="cambiarPagina(-1)" disabled>&#8592; ANTERIOR</button>
    <span class="indicador" id="contadorPagina">1/4</span>
    <button class="btn-nav" id="btnSiguiente" onclick="cambiarPagina(1)">SIGUIENTE &#8594;</button>
  </div>

  <a href="quiz.html" class="btn-quiz" id="btnQuiz" style="display: none;"><i class="fas fa-puzzle-piece me-3"></i> IR AL QUIZ</a>

</div>




<script>   // ===== SISTEMA DE SONIDOS =====   const sonidos = {     pasarPagina: new Audio('/contenidos/geografia/recursos/sonidos/whoosh.mp3'),     click: new Audio('/contenidos/geografia/recursos/sonidos/click.mp3'),     completar: new Audio('/contenidos/geografia/recursos/sonidos/ding.mp3')   };    Object.values(sonidos).forEach(s => {     if (s.src) s.volume = 0.2;   });    function reproducirSonido(nombre) {     if (sonidos[nombre] && sonidos[nombre].src) {       sonidos[nombre].currentTime = 0;       sonidos[nombre].play().catch(() => {});     }   }    // ===== NAVEGACIÓN =====   let paginaActual = 1;   const totalPaginas = 4;    function cambiarPagina(direccion) {     reproducirSonido('pasarPagina');          document.getElementById(`pagina${paginaActual}`).classList.remove('activa');     paginaActual += direccion;     document.getElementById(`pagina${paginaActual}`).classList.add('activa');     actualizarUI();     window.scrollTo({ top: 0, behavior: 'smooth' });     localStorage.setItem('progreso_auditivo_facil', paginaActual);   }    function actualizarUI() {     document.querySelectorAll('.punto').forEach((punto, index) => {       punto.classList.remove('activo', 'completado');       if (index + 1 === paginaActual) punto.classList.add('activo');       else if (index + 1 < paginaActual) punto.classList.add('completado');     });          document.getElementById('paginaActualNum').innerText = paginaActual;     document.getElementById('contadorPagina').innerText = `${paginaActual}/${totalPaginas}`;     document.getElementById('btnAnterior').disabled = (paginaActual === 1);     document.getElementById('btnSiguiente').disabled = (paginaActual === totalPaginas);   }    // ===== MINI PREGUNTAS =====   function responderMini(boton, esCorrecto) {     reproducirSonido('click');          const opciones = boton.parentElement.querySelectorAll('.btn-mini');     opciones.forEach(opt => opt.classList.remove('correcto'));          if (esCorrecto) {       boton.classList.add('correcto');       reproducirSonido('completar');     } else {       boton.style.background = '#f44336';       boton.style.color = 'white';       setTimeout(() => {         boton.style.background = '#ffd600';         boton.style.color = '#01579b';       }, 500);     }   }    // ===== CONTROL DE AUDIOS =====   document.addEventListener('play', function(e) {     if (e.target.tagName === 'AUDIO') {       document.querySelectorAll('audio').forEach(audio => {         if (audio !== e.target && !audio.paused) audio.pause();       });     }   }, true);    // ===== CARGAR PROGRESO =====   window.addEventListener('DOMContentLoaded', () => {     const guardado = localStorage.getItem('progreso_auditivo_facil');     if (guardado) {       const pag = parseInt(guardado);       if (pag >= 1 && pag <= totalPaginas) {         document.getElementById(`pagina${paginaActual}`).classList.remove('activa');         paginaActual = pag;         document.getElementById(`pagina${paginaActual}`).classList.add('activa');       }     }     actualizarUI();   }); </script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
