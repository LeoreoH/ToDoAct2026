    <section class="tarjeta">
      <h2 class="titulo-pagina" id="tituloPagina"></h2>
      <div class="texto-destacado" id="leadPagina"></div>
      <div id="contenidoPagina"></div>
      <div class="audio-stack"><div class="audio-box"><button type="button" class="audio-btn" id="btnAudioIntro"><i class="fas fa-play"></i></button><div class="audio-label"><i class="fas fa-volume-up me-2"></i>Escucha la explicaci&oacute;n.</div></div></div>
      <div class="exercise-box">
        <h3>Actividad de reforzamiento</h3>
        <div class="audio-box"><button type="button" class="audio-btn" id="btnAudioEj"><i class="fas fa-play"></i></button><div class="audio-label">Escucha el reto y responde con el apoyo visual.</div></div>
        <div class="exercise-prompt" id="promptActividad">Escucha el reto y responde con el apoyo visual.</div>
        <div id="supportActividad"></div>
        <div id="rootActividad"></div>
        <div class="action-row"><button class="btn-accion" id="btnVerificar">Verificar</button><button class="btn-accion" id="btnBorrar">Borrar selecci&oacute;n</button></div>
        <div id="feedback" class="feedback"></div>
      </div>
      <div class="text-center" id="quizWrap"></div>
    </section>
    <div class="navegador"><button class="btn-nav" id="btnAnterior" disabled>&larr; Anterior</button><span class="contador" id="contadorPagina">1/6</span><button class="btn-nav" id="btnSiguiente">Siguiente &rarr;</button></div>
  </div>
  <script src="/contenidos/recursos/js/reforzamiento-tracker.js"></script>
  <script src="/contenidos/matematicas/equivalencias-numericas/recursos/js/auditivo-facil.js"></script>
