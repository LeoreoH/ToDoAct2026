<body>
  <header class="cabecera">
    <button class="btn-volver-menu" title="Volver al men&uacute;"><i class="fas fa-house"></i></button>
    <h1>DECIMALES AUDITIVOS</h1>
    <div class="subtitulo">Equivalencias num&eacute;ricas &middot; Nivel F&aacute;cil</div>
    <div class="badge-estilo">Auditivo</div>
  </header>
  <div class="barra-progreso"><span class="progreso-texto" id="progresoTexto">P&aacute;gina 1 de 6</span><div class="barra-fondo"><div class="barra-relleno" id="barraRelleno"></div></div><span class="progreso-num" id="progresoNum">17%</span></div>
