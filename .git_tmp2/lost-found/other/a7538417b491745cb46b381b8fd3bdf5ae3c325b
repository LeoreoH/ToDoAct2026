3e5f5);border:3px dashed #ba68c8;border-radius:24px;padding:22px;margin-top:24px}.exercise-box h3{text-align:center;color:#6a1b9a;font-size:1.35rem;font-weight:900;margin-bottom:10px}.exercise-prompt{text-align:center;font-weight:800;color:#6a1b9a;line-height:1.45;margin-bottom:6px}.support-box{background:#fff;border:3px solid #d1c4e9;border-radius:22px;padding:18px;margin:14px 0 18px}.support-box .value-chip,.support-box .line-wrap{margin-inline:auto}.options-grid{grid-template-columns:repeat(auto-fit,minmax(200px,1fr))}.option-card{background:#fff;border:3px solid #7b1fa2;border-radius:22px;padding:16px;box-shadow:0 5px 0 #d1c4e9;cursor:pointer;transition:.2s;display:flex;flex-direction:column;justify-content:center;align-items:center;gap:12px;min-height:170px}.option-card:hover{transform:translateY(-3px);background:#fcf9ff}.option-card.sel{border-color:#ab47bc;background:#f7ecff}.option-card.ok{border-color:#43a047;background:#e8f5e9;color:#2e7d32}.option-card.err{border-color:#e53935;background:#ffebee;color:#c62828}.sign-choice{font-size:2.25rem;font-weight:900;color:#6a1b9a;line-height:1}.feedback{display:none;margin-top:16px;padding:14px 16px;border-radius:16px;font-weight:800;text-align:center;line-height:1.45}.feedback.show{display:block}.feedback.ok{background:#e8f5e9;color:#2e7d32;border:2px solid #43a047}.feedback.err{background:#fff3e0;color:#ef6c00;border:2px solid #fb8c00}.sequence-wrap{display:grid;gap:16px}.sequence-slots{grid-template-columns:repeat(auto-fit,minmax(170px,1fr))}.slot{min-height:120px;background:#fff;border:3px dashed #ab47bc;border-radius:20px;box-shadow:0 5px 0 #e1bee7;padding:12px;display:flex;align-items:center;justify-content:center;text-align:center;cursor:pointer}.slot.has-card{border-style:solid}.slot-label{display:inline-flex;width:32px;height:32px;border-radius:50%;background:#7b1fa2;color:#fff;align-items:center;justify-content:center;font-weight:900;margin-bottom:10px}.bank-grid{grid-template-columns:repeat(auto-fit,minmax(160px,1fr))}.bank-card{background:#fff;border:3px solid #7b1fa2;border-radius:20px;box-shadow:0 5px 0 #d1c4e9;padding:14px;cursor:pointer;transition:.2s;text-align:center}.bank-card:hover{transform:translateY(-2px)}.bank-card.used{opacity:.35;pointer-events:none}.action-row{display:flex;justify-content:center;flex-wrap:wrap;gap:14px;margin-top:18px}.btn-accion{border:none;border-radius:999px;padding:12px 26px;font-weight:800;background:linear-gradient(135deg,#ab47bc,#7e57c2);color:#fff;box-shadow:0 5px 0 #5e35b1;transition:.2s}.btn-accion:hover:not(:disabled){transform:translateY(-2px)}.btn-accion:disabled{opacity:.5;cursor:not-allowed;box-shadow:none}.navegador{display:flex;justify-content:space-between;align-items:center;gap:15px;background:#fff;border:3px solid #7b1fa2;border-radius:999px;padding:12px 16px;margin-top:28px;box-shadow:0 8px 0 #d1c4e9;position:sticky;bottom:18px;z-index:20}.btn-nav{border:none;border-radius:999px;padding:12px 22px;font-weight:800;background:linear-gradient(135deg,#ab47bc,#7e57c2);color:#fff;box-shadow:0 5px 0 #5e35b1;transition:.2s}.btn-nav:hover:not(:disabled){transform:translateY(-2px)}.btn-nav:disabled{opacity:.45;cursor:not-allowed;box-shadow:none}.contador{font-weight:900;color:#6a1b9a;font-size:1.1rem}.quiz-link{display:inline-flex;align-items:center;gap:10px;margin:28px auto 0;text-decoration:none;background:#ffd54f;color:#4a148c;border:4px solid #7b1fa2;padding:16px 34px;border-radius:999px;font-weight:900;font-size:1.18rem;box-shadow:0 7px 0 #d39e00;transition:.2s}.quiz-link:hover{transform:translateY(-3px);background:#fff3c4;color:#4a148c}.quiz-link.bloqueado{opacity:.55;cursor:not-allowed;background:#e0e0e0;color:#7a7a7a;border-color:#bdbdbd;box-shadow:0 7px 0 #9e9e9e;pointer-events:none}@media (max-width:768px){.cabecera h1{font-size:2rem}.titulo-pagina{font-size:1.55rem}.btn-volver-menu{position:static;margin:0 auto 16px}.barra-progreso{margin-inline:16px}.navegador{flex-direction:column;border-radius:24px}.model-grid,.options-grid,.compare-board,.sequence-slots,.bank-grid{grid-template-columns:1fr}.option-card{min-height:150px}.strip10 .cell{height:54px}.bottle{height:158px}.audio-box{align-items:flex-start}}
  </style>
