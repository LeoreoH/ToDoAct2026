  <style>
    *{box-sizing:border-box}body{margin:0;font-family:'Nunito',sans-serif;background:linear-gradient(135deg,#f7f1ff,#ede7f6);color:#4a148c;min-height:100vh}.cabecera{background:linear-gradient(135deg,#8e24aa,#5e35b1);color:#fff;text-align:center;padding:28px 20px;border-bottom:6px solid #ffd54f;box-shadow:0 8px 20px rgba(0,0,0,.18);position:relative}.cabecera h1{margin:0;font-family:'Fredoka One',cursive;font-size:2.45rem;text-shadow:2px 2px 0 rgba(0,0,0,.15)}.cabecera .subtitulo{margin-top:10px;font-size:1.05rem;font-weight:700}.badge-estilo{display:inline-block;margin-top:14px;background:#ffd54f;color:#4a148c;border:3px solid #fff;border-radius:999px;padding:10px 24px;font-weight:800;box-shadow:0 4px 0 #d39e00}.btn-volver-menu{position:absolute;top:18px;left:18px;width:54px;height:54px;border-radius:50%;border:3px solid #fff;background:#ffd54f;color:#4a148c;font-size:1.35rem;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 4px 0 #d39e00;transition:.2s}.btn-volver-menu:hover{transform:translateY(-2px);background:#fff3c4}.barra-progreso{max-width:980px;margin:24px auto 0;background:#fff;border-radius:999px;border:3px solid #7b1fa2;box-shadow:0 6px 0 #d1c4e9;padding:12px 18px;display:flex;gap:14px;align-items:center;flex-wrap:wrap}.progreso-texto{font-weight:800;color:#6a1b9a;white-space:nowrap}.barra-fondo{flex:1;min-width:140px;height:14px;background:#ede7f6;border-radius:999px;overflow:hidden;border:2px solid #d1c4e9}.barra-relleno{width:0;height:100%;background:linear-gradient(90deg,#ab47bc,#7e57c2);transition:width .3s}.progreso-num{background:#7b1fa2;color:#fff;padding:7px 14px;border-radius:999px;font-weight:800}.contenedor{max-width:980px;margin:26px auto 42px;padding:0 16px}.tarjeta{background:#fff;border-radius:28px;border:3px solid #7b1fa2;box-shadow:0 10px 0 #d1c4e9;padding:26px}.titulo-pagina{font-family:'Fredoka One',cursive;font-size:2rem;color:#6a1b9a;margin-bottom:16px;border-left:8px solid #ffd54f;padding-left:18px}.texto-destacado{background:#faf5ff;border:2px dashed #ce93d8;border-radius:18px;padding:16px 18px;color:#5e35b1;font-weight:700;margin-bottom:18px;text-align:center;line-height:1.45}.audio-stack{display:grid;gap:12px;margin:18px 0}.audio-box{background:linear-gradient(135deg,#faf5ff,#f3e5f5);border:3px dashed #ba68c8;border-radius:24px;padding:14px 18px;display:flex;align-items:center;gap:16px;flex-wrap:wrap}.audio-btn{width:58px;height:58px;border-radius:50%;border:3px solid #ffd54f;background:#7b1fa2;color:#fff;display:flex;align-items:center;justify-content:center;font-size:1.35rem;cursor:pointer;flex-shrink:0;box-shadow:0 4px 0 #5e35b1;transition:.2s}.audio-btn:hover{transform:translateY(-2px)}.audio-btn.playing{animation:pulse 1s infinite}@keyframes pulse{50%{transform:scale(1.08);background:#ffd54f;color:#4a148c}}.audio-label{flex:1;min-width:220px;font-weight:800;color:#6a1b9a}.info-box{background:#f7f1ff;border-radius:22px;border-left:8px solid #ffd54f;padding:18px;margin:18px 0}.info-title{font-weight:900;color:#6a1b9a;margin-bottom:8px}.info-note{font-weight:700;color:#6a1b9a;line-height:1.45;text-align:center}.model-grid,.compare-board,.options-grid,.sequence-slots,.bank-grid{display:grid;gap:16px}.model-grid{grid-template-columns:repeat(auto-fit,minmax(220px,1fr));margin:18px 0}.compare-board{grid-template-columns:repeat(auto-fit,minmax(220px,1fr));align-items:start}.model-card,.compare-card{background:#fff;border:3px solid #ce93d8;border-radius:22px;padding:16px;box-shadow:0 5px 0 #e1bee7;text-align:center}.model-title,.compare-card h4,.support-title{font-weight:900;color:#6a1b9a;margin-bottom:12px}.model-note,.hint-line{margin-top:10px;font-weight:800;color:#7b1fa2;line-height:1.35;text-align:center}.value-chip{display:inline-flex;align-items:center;justify-content:center;min-width:92px;padding:10px 16px;border-radius:999px;background:#f3e5f5;border:3px solid #ab47bc;color:#6a1b9a;font-weight:900;box-shadow:0 4px 0 #d1c4e9}.value-chip.sky{background:#