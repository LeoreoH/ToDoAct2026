  <script src="/contenidos/recursos/js/reforzamiento-tracker.js"></script>
  <script>
    let paginaActual=1; const totalPaginas=7; let audioActual=null;
    const audioClick=document.getElementById('audioClick'),audioDing=document.getElementById('audioDing'),audioError=document.getElementById('audioError'),audioWhoosh=document.getElementById('audioWhoosh');
    [audioClick,audioDing,audioError,audioWhoosh].forEach(a=>{if(a)a.volume=0.4;});
    const tracker=window.createReforzamientoTracker?window.createReforzamientoTracker({trackTime:false,contenidoId:4,nivel:'facil',estilo:'auditivo',detalleBase:{bloque:'reconocer_fracciones',motor:'auditivo_facil'},apartados:{aud_facil_p1:{pagina:1,apartadoClave:'aud_facil_p1',tipoActividad:'reforzamiento'},aud_facil_p2:{pagina:2,apartadoClave:'aud_facil_p2',tipoActividad:'reforzamiento'},aud_facil_p3:{pagina:3,apartadoClave:'aud_facil_p3',tipoActividad:'reforzamiento'},aud_facil_p4:{pagina:4,apartadoClave:'aud_facil_p4',tipoActividad:'reforzamiento'},aud_facil_p5:{pagina:5,apartadoClave:'aud_facil_p5',tipoActividad:'reforzamiento'},aud_facil_p6:{pagina:6,apartadoClave:'aud_facil_p6',tipoActividad:'reforzamiento'},aud_facil_p7:{pagina:7,apartadoClave:'aud_facil_p7',tipoActividad:'reforzamiento'}}}):null;
    const session=window.createReforzamientoSessionTracker?window.createReforzamientoSessionTracker({contenidoId:4,nivel:'facil',estilo:'auditivo',detalleBase:{bloque:'reconocer_fracciones',motor:'auditivo_facil'}}):null;
    if(session)session.start();
    const pageState={1:{complete:false},2:{complete:false},3:{complete:false},4:{complete:false},5:{complete:false},6:{complete:false},7:{complete:false}};
    const pageExercises={1:['p1e1'],2:['p2e1'],3:['p3e1'],4:['p4e1'],5:['p5e1'],6:['p6e1'],7:['p7e1']};
    const exerciseState={p1e1:{type:'choice',correct:'unidad',selected:null,solved:false},p2e1:{type:'choice',correct:'iguales',selected:null,solved:false},p3e1:{type:'choice',correct:'2/4',selected:null,solved:false},p4e1:{type:'choice',correct:'denominador',selected:null,solved:false},p5e1:{type:'grid',correct:'2/5',selected:null,solved:false},p6e1:{type:'choice',correct:'3/4',selected:null,solved:false},p7e1:{type:'grid',correct:'3/4',selected:null,solved:false}};
    function safePlay(a){if(!a)return;try{a.currentTime=0;const r=a.play();if(r&&r.catch)r.catch(()=>{});}catch(_){}}
    function stopNarration(){if(audioActual){audioActual.pause();audioActual.currentTime=0;audioActual=null;}document.querySelectorAll('.audio-btn').forEach(b=>b.classList.remove('playing'));}
    function reproducirAudio(id,btn){const a=document.getElementById(id);if(!a)return;safePlay(audioClick);stopNarration();audioActual=a;btn.classList.add('playing');const r=a.play();if(r&&r.catch)r.catch(()=>{});a.onended=function(){btn.classList.remove('playing');if(audioActual===a)audioActual=null;};}
    document.querySelectorAll('.audio-btn[data-audio]').forEach(btn=>btn.addEventListener('click',()=>reproducirAudio(btn.dataset.audio,btn)));
    function sectionKey(p){return 'aud_facil_p'+p;}
    function noteVisible(p){if(tracker)tracker.markPageVisibleByNumber(p,{motor:'auditivo_facil'});}
    function note(p,ok,d){if(!tracker)return;if(ok)tracker.addCorrect(sectionKey(p),1,d);else tracker.addError(sectionKey(p),1,d);}
    async function completePageIfReady(p){if(pageState[p].complete)return;if(!pageExercises[p].every(id=>exerciseState[id].solved))return;pageState[p].complete=true;if(tracker)await tracker.complete(sectionKey(p),{detalle:{bloque:'reconocer_fracciones',motor:'auditivo_facil',pagina:p}});actualizarUI();}
    function allPagesSolved(){return Object.values(pageState).every(page=>page.complete);}
    function updateQuizLock(){const btnQuiz=document.getElementById('btnMiniQuiz');if(!btnQuiz)return;btnQuiz.classList.toggle('bloqueado',!allPagesSolved());}
    function setFeedback(id,ok,html){const el=document.getElementById(id);el.className='feedback show '+(ok?'ok':'err');el.innerHTML=html;}
    function clearFeedback(id){const el=document.getElementById(id);el.className='feedback';el.innerHTML='';}
    function bindChoice(cardId,stateKey,page,fbId,msg){
      const card=document.getElementById(cardId),btns=Array.from(card.querySelectorAll('.opt'));
      btns.forEach(btn=>btn.addEventListener('click',function(){if(exerciseState[stateKey].solved)return;exerciseState[stateKey].selected=btn.dataset.value;btns.forEach(b=>b.classList.remove('sel'));btn.classList.add('sel');clearFeedback(fbId);safePlay(audioClick);}));
      card.querySelector('[data-action="verify"]').addEventListener('click',async function(){if(exerciseState[stateKey].solved)return;const sel=exerciseState[stateKey].selected;if(!sel){setFeedback(fbId,false,'Primero escucha y elige una opci&oacute;n.');return;}const ok=sel===exerciseState[stateKey].correct;btns.forEach(b=>b.classList.remove('ok','err'));if(ok){btns.forEach(b=>{b.disabled=true;if(b.dataset.value===exerciseState[stateKey].correct)b.classList.add('ok');});exerciseState[stateKey].solved=true;safePlay(audioDing);setFeedback(fbId,true,msg.ok);note(page,true,{ejercicio:stateKey});await completePageIfReady(page);}else{btns.forEach(b=>{if(b.dataset.value===sel)b.classList.add('err');});safePlay(audioError);setFeedback(fbId,false,msg.err);note(page,false,{ejercicio:stateKey});}});
      card.querySelector('[data-action="clear"]').addEventListener('click',function(){if(exerciseState[stateKey].solved)return;exerciseState[stateKey].selected=null;btns.forEach(b=>b.classList.remove('sel','ok','err'));clearFeedback(fbId);safePlay(audioClick);});
    }
    function bindGrid(cardId,gridId,stateKey,page,fbId,msg){
      const card=document.getElementById(cardId),cells=Array.from(document.getElementById(gridId).querySelectorAll('.cell'));
      cells.forEach(cell=>cell.addEventListener('click',function(){if(exerciseState[stateKey].solved)return;exerciseState[stateKey].selected=cell.dataset.value;cells.forEach(c=>c.classList.remove('sel'));cell.classList.add('sel');clearFeedback(fbId);safePlay(audioClick);}));
      card.querySelector('[data-action="verify"]').addEventListener('click',async function(){if(exerciseState[stateKey].solved)return;if(!exerciseState[stateKey].selected){setFeedback(fbId,false,'Primero elige una casilla.');return;}const ok=exerciseState[stateKey].selected===exerciseState[stateKey].correct;cells.forEach(c=>c.classList.remove('ok','err'));if(ok){cells.forEach(c=>{c.disabled=true;if(c.dataset.value===exerciseState[stateKey].correct)c.classList.add('ok');});exerciseState[stateKey].solved=true;safePlay(audioDing);setFeedback(fbId,true,msg.ok);note(page,true,{ejercicio:stateKey});await completePageIfReady(page);}else{cells.forEach(c=>{if(c.dataset.value===exerciseState[stateKey].selected)c.classList.add('err');});safePlay(audioError);setFeedback(fbId,false,msg.err);note(page,false,{ejercicio:stateKey});}});
      card.querySelector('[data-action="clear"]').addEventListener('click',function(){if(exerciseState[stateKey].solved)return;exerciseState[stateKey].selected=null;cells.forEach(c=>{c.classList.remove('sel','ok','err');c.disabled=false;});clearFeedback(fbId);safePlay(audioClick);});
    }
    function actualizarUI(){document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));document.getElementById('pagina'+paginaActual).classList.add('active');document.getElementById('paginaActualNum').textContent=String(paginaActual);document.getElementById('contadorPagina').textContent=paginaActual+'/7';document.getElementById('btnAnterior').disabled=paginaActual===1;document.getElementById('btnSiguiente').disabled=paginaActual===totalPaginas;document.querySelectorAll('.dot').forEach((dot,i)=>{const p=i+1;dot.classList.remove('active','done');if(p===paginaActual)dot.classList.add('active');if(pageState[p].complete)dot.classList.add('done');});noteVisible(paginaActual);updateQuizLock();}
    function cambiarPagina(delta){const next=paginaActual+delta;if(next<1||next>totalPaginas)return;paginaActual=next;localStorage.setItem('progreso_facil_auditivo_fracciones',String(paginaActual));stopNarration();safePlay(audioWhoosh);actualizarUI();window.scrollTo({top:0,behavior:'smooth'});}
    document.getElementById('btnAnterior').addEventListener('click',()=>cambiarPagina(-1));
    document.getElementById('btnSiguiente').addEventListener('click',()=>cambiarPagina(1));
    document.getElementById('btnMiniQuiz').addEventListener('click',async function(event){if(!allPagesSolved()){event.preventDefault();return;}event.preventDefault();if(session)await session.complete({eventoCierre:'quiz'});window.location.href=this.getAttribute('href');});
    function initExercises(){
      bindChoice('card-p1e1','p1e1',1,'p1e1-feedback',{ok:'&iexcl;Correcto! Toda fracci&oacute;n sale de una unidad completa.',err:'Observa otra vez: primero necesitamos el entero completo.'});
      bindChoice('card-p2e1','p2e1',2,'p2e1-feedback',{ok:'&iexcl;Muy bien! Esa unidad qued&oacute; dividida en 4 partes iguales.',err:'F&iacute;jate en el tama&ntilde;o de cada parte: todas deben medir lo mismo.'});
      bindChoice('card-p3e1','p3e1',3,'p3e1-feedback',{ok:'&iexcl;Exacto! Ese modelo representa 2 de 4 partes tomadas.',err:'Cuenta cu&aacute;ntas partes est&aacute;n marcadas y cu&aacute;ntas hay en total.'});
      bindChoice('card-p4e1','p4e1',4,'p4e1-feedback',{ok:'&iexcl;Perfecto! El 5 va abajo porque indica el total de partes iguales.',err:'Recuerda: arriba va lo tomado y abajo va el total de partes.'});
      bindGrid('card-p5e1','p5e1-grid','p5e1',5,'p5e1-feedback',{ok:'&iexcl;Correcto! 2 partes marcadas de 5 totales = 2/5.',err:'Cuenta las partes marcadas (arriba) y las partes totales (abajo).'});
      bindChoice('card-p6e1','p6e1',6,'p6e1-feedback',{ok:'&iexcl;Muy bien! 3/4 tiene el numerador m&aacute;s grande, as&iacute; que es la mayor.',err:'Con el mismo denominador, compara solo los numeradores.'});
      bindGrid('card-p7e1','p7e1-grid','p7e1',7,'p7e1-feedback',{ok:'&iexcl;Excelente! El punto correcto est&aacute; en 3/4.',err:'Busca la opci&oacute;n donde el punto queda en el tercer salto entre 0 y 1.'});
    }
    window.addEventListener('DOMContentLoaded',function(){initExercises();const saved=parseInt(localStorage.getItem('progreso_facil_auditivo_fracciones')||'1',10);if(saved>=1&&saved<=totalPaginas)paginaActual=saved;actualizarUI();});
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
