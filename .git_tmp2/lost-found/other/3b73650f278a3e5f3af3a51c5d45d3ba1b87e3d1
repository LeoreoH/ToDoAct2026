  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Fredoka+One&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    *{box-sizing:border-box} :root{--morado:#7b1fa2;--lila:#ede7f6;--lila2:#faf5ff;--amarillo:#ffd54f;--verde:#43a047;--texto:#4a148c;--sombra:#d1c4e9;--borde:#ce93d8}
    body{margin:0;min-height:100vh;font-family:'Nunito',sans-serif;background:linear-gradient(135deg,#f7f1ff,#ede7f6);color:var(--texto)}
    .cabecera{position:relative;text-align:center;color:#fff;padding:28px 18px;background:linear-gradient(135deg,#8e24aa,#5e35b1);border-bottom:6px solid var(--amarillo);box-shadow:0 10px 24px rgba(0,0,0,.16)}
    .cabecera h1{margin:0;font-family:'Fredoka One',cursive;font-size:2.45rem;text-shadow:3px 3px 0 rgba(0,0,0,.14)} .subtitulo{margin-top:8px;font-size:1.08rem;font-weight:800}
    .badge-estilo{display:inline-block;margin-top:12px;padding:10px 22px;border-radius:999px;background:var(--amarillo);color:var(--texto);border:3px solid white;font-weight:800;box-shadow:0 4px 0 #d39e00}
    .btn-volver-menu{position:absolute;top:16px;left:16px;width:54px;height:54px;border:3px solid white;border-radius:50%;background:var(--amarillo);color:var(--texto);font-size:1.2rem;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 4px 0 #d39e00}
    .progreso{max-width:1040px;margin:22px auto 0;padding:12px 16px;display:flex;gap:14px;align-items:center;flex-wrap:wrap;background:white;border:3px solid var(--morado);border-radius:999px;box-shadow:0 6px 0 var(--sombra)}
    .progreso-texto{font-weight:800;color:#6a1b9a;white-space:nowrap}.barra-fondo{flex:1;min-width:160px;height:14px;background:var(--lila);border-radius:999px;overflow:hidden;border:2px solid var(--sombra)}
    .barra-relleno{width:14.28%;height:100%;background:linear-gradient(90deg,#ab47bc,#7e57c2);transition:width .3s}.progreso-num{padding:7px 14px;border-radius:999px;background:var(--morado);color:white;font-weight:800}
    .contenedor{max-width:1080px;margin:24px auto 42px;padding:0 16px}.tarjeta{background:white;border-radius:28px;border:3px solid var(--morado);box-shadow:0 10px 0 var(--sombra);padding:26px}
    .titulo-pagina{margin-bottom:14px;padding-left:18px;border-left:8px solid var(--amarillo);font-family:'Fredoka One',cursive;font-size:1.9rem;color:#6a1b9a}.texto-destacado{margin-bottom:18px;padding:16px 18px;border-radius:18px;background:var(--lila2);border:2px dashed var(--borde);color:#5e35b1;font-weight:700;line-height:1.66}
    .mini-etiqueta{display:inline-block;margin-bottom:16px;padding:7px 14px;border-radius:999px;background:var(--lila);border:2px solid var(--sombra);color:#6a1b9a;font-weight:800;font-size:.94rem}.modelo-box{background:white;border:2px solid var(--sombra);border-radius:24px;padding:18px;margin-bottom:20px}
    .modelo-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px}.model-card{background:var(--lila2);border:2px solid var(--borde);border-radius:22px;padding:16px;text-align:center;box-shadow:0 5px 0 #ead9f8}.model-label{margin-top:10px;font-weight:900;color:#6a1b9a}.model-note{margin-top:8px;color:#7b1fa2;font-size:.92rem;font-weight:700;line-height:1.5}
    .strip{display:grid;grid-template-columns:repeat(var(--parts),1fr);min-height:62px;overflow:hidden;border-radius:16px;border:3px solid var(--morado);background:white}.seg{border-right:3px solid var(--morado);background:white}.seg:last-child{border-right:none}.seg.fill{background:linear-gradient(135deg,#ba68c8,#7e57c2)}
    .fraction-big{display:inline-block;min-width:84px;font-size:2rem;font-weight:900;color:#5e35b1;line-height:1.05}.fraction-big .line{display:block;height:4px;background:#5e35b1;border-radius:2px;margin:6px 0}
    .line-box{position:relative;height:150px}.line-track{position:absolute;left:10%;right:10%;top:78px;height:6px;border-radius:999px;background:#7b1fa2}.tick{position:absolute;top:54px;width:0;height:42px;border-left:3px solid #7b1fa2;transform:translateX(-50%)}.tick span{position:absolute;top:44px;left:50%;transform:translateX(-50%);font-size:.85rem;font-weight:800;color:#6a1b9a;white-space:nowrap}.line-point{position:absolute;top:12px;transform:translateX(-50%);padding:10px 14px;border-radius:999px;background:var(--amarillo);border:3px solid var(--morado);font-weight:900;color:var(--texto);box-shadow:0 4px 0 #d39e00}
    .actividad{background:var(--lila2);border:3px dashed #ba68c8;border-radius:24px;padding:20px;margin-top:12px}.actividad h3{margin:0 0 12px;text-align:center;color:#6a1b9a;font-size:1.3rem;font-weight:900}.consigna{margin:0 0 16px;color:#6a1b9a;font-weight:700;line-height:1.6}
    .prompt-visual{margin:0 0 14px;padding:14px;border-radius:18px;background:white;border:2px solid var(--sombra)}.visual-chip-grid{display:flex;gap:12px;flex-wrap:wrap;justify-content:center}.mini-bar{min-width:92px;display:flex;flex-direction:column;align-items:center;gap:8px}.mini-strip{width:92px;height:20px;border-radius:999px;overflow:hidden;border:2px solid var(--morado);display:grid;background:white}.mini-strip span{border-right:2px solid var(--morado);background:white}.mini-strip span:last-child{border-right:none}.mini-strip span.fill{background:linear-gradient(135deg,#ba68c8,#7e57c2)}.mini-frac{min-width:74px;padding:8px 12px;border-radius:16px;background:#f7f1ff;border:2px solid var(--borde);text-align:center;font-weight:900;color:#6a1b9a}.mini-frac .line{display:block;height:3px;background:#6a1b9a;margin:4px 0;border-radius:2px}.mini-caption{font-size:.82rem;font-weight:800;color:#7b1fa2;text-align:center}.mini-line{position:relative;width:140px;height:42px}.mini-line-track{position:absolute;left:8px;right:8px;top:24px;height:4px;background:#7b1fa2;border-radius:999px}.mini-line-mark{position:absolute;top:12px;width:0;height:18px;border-left:2px solid #7b1fa2;transform:translateX(-50%)}.mini-line-dot{position:absolute;top:0;transform:translateX(-50%);padding:2px 8px;border-radius:999px;background:var(--amarillo);border:2px solid var(--morado);font-size:.72rem;font-weight:900;color:var(--texto)}.visual-clue{text-align:center;color:#7b1fa2;font-size:.88rem;font-weight:800;margin-top:8px;line-height:1.45}
    .option-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:14px}.opcion-card{width:100%;background:white;border:3px solid var(--morado);border-radius:18px;padding:16px;text-align:left;font-weight:800;color:#6a1b9a;box-shadow:0 5px 0 var(--sombra);cursor:pointer}.opcion-card.selected{background:#f3e5f5;border-color:#ab47bc}
    .fill-wrap{display:grid;gap:12px}.fill-line{background:white;border:2px solid var(--sombra);border-radius:18px;padding:14px 16px;color:#6a1b9a;font-weight:800;line-height:1.8}.blank{min-width:110px;padding:8px 12px;margin:0 4px;border-radius:12px;border:3px dashed #ab47bc;background:#fff;color:#7b1fa2;font-weight:900;cursor:pointer}.blank.active{background:#f3e5f5;border-style:solid}.blank.filled{border-style:solid}
    .bank,.order-bank{display:flex;gap:12px;flex-wrap:wrap;justify-content:center;margin-top:16px}.word-chip,.order-chip{padding:10px 16px;border-radius:999px;border:3px solid var(--morado);background:white;color:#6a1b9a;font-weight:900;box-shadow:0 5px 0 var(--sombra);cursor:pointer}.word-chip.used,.order-chip.used{opacity:.45;pointer-events:none}.answer-track{margin-top:16px;display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:12px}.answer-slot{min-height:64px;padding:12px;border-radius:18px;border:3px dashed #ba68c8;background:white;display:flex;align-items:center;justify-content:center;text-align:center;font-weight:900;color:#6a1b9a}.answer-slot span{opacity:.6}
    .acciones{display:flex;justify-content:center;gap:12px;flex-wrap:wrap;margin-top:18px}.btn-accion{padding:12px 22px;border-radius:999px;border:none;background:var(--morado);color:white;font-weight:900;box-shadow:0 5px 0 var(--sombra);cursor:pointer}.btn-accion.secundario{background:#9575cd}.feedback{display:none;margin-top:16px;padding:12px 16px;border-radius:16px;text-align:center;font-weight:800}.feedback.visible{display:block}.feedback.ok{background:#e8f5e9;border:2px solid var(--verde);color:#2e7d32}.feedback.warn{background:#fff8e1;border:2px solid var(--amarillo);color:#8d6e00}
    .quiz-wrap{text-align:center;margin-top:26px}.boton-quiz{display:inline-block;padding:16px 34px;text-decoration:none;border-radius:999px;background:var(--amarillo);color:var(--texto);border:4px solid var(--morado);font-weight:900;font-size:1.18rem;box-shadow:0 7px 0 #d39e00}.boton-quiz.bloqueado{opacity:.55;cursor:not-allowed;background:#e0e0e0;color:#777;border-color:#bdbdbd;box-shadow:0 7px 0 #9e9e9e}
    .navegador{margin-top:16px;padding:14px 20px;display:flex;justify-content:space-between;align-items:center;gap:15px;flex-wrap:wrap;background:white;border:3px solid var(--morado);border-radius:999px;box-shadow:0 6px 0 var(--sombra)}.btn-nav{padding:12px 24px;border:none;border-radius:999px;background:var(--morado);color:white;font-weight:900}.btn-nav:disabled{opacity:.55;cursor:not-allowed}.contador{padding:8px 16px;border-radius:999px;background:#f3e5f5;border:2px solid #ce93d8;color:#6a1b9a;font-weight:900}
  </style>
</head>
<body>
  <header class="cabecera"><button class="btn-volver-menu" onclick="volverAlMenu()" title="Volver al men&uacute;"><i class="fas fa-arrow-left"></i></button><h1><i class="fas fa-chart-pie me-2"></i>FRACCIONES</h1><div class="subtitulo">Reconocer fracciones &middot; Nivel f&aacute;cil</div><div class="badge-estilo"><i class="fas fa-book-open me-2"></i>Estilo visual verbal</div></header>
  <div class="progreso"><span class="progreso-texto" id="progresoTexto">P&aacute;gina 1 de 7</span><div class="barra-fondo"><div class="barra-relleno" id="barraRelleno"></div></div><span class="progreso-num" id="progresoNum">14%</span></div>
  <div class="contenedor"><div class="tarjeta" id="pageHost"></div><div class="navegador"><button class="btn-nav" id="btnAnterior" onclick="cambiarPagina(-1)" disabled>&larr; Anterior</button><span class="contador" id="contadorPagina">1/7</span><button class="btn-nav" id="btnSiguiente" onclick="cambiarPagina(1)" disabled>Siguiente &rarr;</button></div></div>
  <script src="/contenidos/recursos/js/reforzamiento-tracker.js"></script>
  <script>
    function strip(parts, filled, label, note, unequal) { return '<div class="model-card"><div class="strip" style="--parts:'+parts+(unequal?';grid-template-columns:'+unequal.join(' '):'')+'">'+Array.from({length:parts},(_,i)=>'<span class="seg'+(i<filled?' fill':'')+'"></span>').join('')+'</div><div class="model-label">'+label+'</div><div class="model-note">'+note+'</div></div>'; }
    function frac(num, den, label, note) { return '<div class="model-card"><div class="fraction-big"><span>'+num+'</span><span class="line"></span><span>'+den+'</span></div><div class="model-label">'+label+'</div><div class="model-note">'+note+'</div></div>'; }
    function line(parts, point, tag, note) { const ticks = Array.from({length:parts+1},(_,i)=>{ const left=10+(80*i/parts); const lbl=i===0?'0':i===parts?'1':(i+'/'+parts); return '<div class="tick" style="left:'+left+'%"><span>'+lbl+'</span></div>'; }).join(''); const left=10+(80*point/parts); return '<div class="model-card"><div class="line-box"><div class="line-track"></div>'+ticks+'<div class="line-point" style="left:'+left+'%">'+tag+'</div></div><div class="model-note">'+note+'</div></div>'; }
    function miniBar(parts, filled, label) { return '<div class="mini-bar"><div class="mini-strip" style="grid-template-columns:repeat('+parts+',1fr)">'+Array.from({length:parts},(_,i)=>'<span class="'+(i<filled?'fill':'')+'"></span>').join('')+'</div>'+(label?'<div class="mini-caption">'+label+'</div>':'')+'</div>'; }
    function miniFrac(num, den, label) { return '<div class="mini-bar"><div class="mini-frac"><span>'+num+'</span><span class="line"></span><span>'+den+'</span></div>'+(label?'<div class="mini-caption">'+label+'</div>':'')+'</div>'; }
    function miniLine(parts, point, label) { const marks = Array.from({length:parts+1},(_,i)=>'<span class="mini-line-mark" style="left:'+(8+(124*i/parts))+'px"></span>').join(''); const left = 8+(124*point/parts); return '<div class="mini-bar"><div class="mini-line"><div class="mini-line-track"></div>'+marks+'<div class="mini-line-dot" style="left:'+left+'px">P</div></div>'+(label?'<div class="mini-caption">'+label+'</div>':'')+'</div>'; }
    function visualRow(items, note) { return '<div class="prompt-visual"><div class="visual-chip-grid">'+items.join('')+'</div>'+(note?'<div class="visual-clue">'+note+'</div>':'')+'</div>'; }
    function shuffle(list) { const copy = list.slice(); for (let i = copy.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [copy[i], copy[j]] = [copy[j], copy[i]]; } return copy; }
    function shuffleAvoid(list, forbiddenValues) { let shuffled = shuffle(list); let guard = 0; const forbidden = forbiddenValues.join('|'); while (guard < 8 && shuffled.map(item => item[0]).join('|') === forbidden) { shuffled = shuffle(list); guard++; } return shuffled; }
    const PAGES = [
      { page:1, icon:'fas fa-cookie-bite', title:'Primero vemos la unidad', tag:'Idea clave: toda fracci&oacute;n sale de una unidad completa.', intro:'Antes de hablar de fracciones, primero reconocemos la unidad completa. Una fracci&oacute;n aparece cuando esa misma unidad se divide en partes iguales y despu&eacute;s se describen esas partes.', model:'<div class="modelo-grid">'+strip(1,1,'Unidad completa','La barra todav&iacute;a no est&aacute; partida: representa 1 entero.')+strip(4,4,'La misma unidad dividida','Sigue siendo la misma barra, solo que ahora est&aacute; separada en 4 partes iguales.')+'</div>', activity:{ visualPrompt: visualRow([miniBar(1,1,'Entero'), miniBar(4,4,'Mismo entero dividido')], '&iquest;Qu&eacute; idea explica mejor estos dos modelos?'), type:'choice', title:'Reto de lectura', prompt:'Lee las ideas y elige la que describe mejor lo que muestran los modelos.', options:[['unidad','La barra completa representa una unidad. Una fracci&oacute;n aparece cuando esa unidad se divide en partes iguales.'],['color','Una fracci&oacute;n depende solo del color de la figura.'],['forma','Solo los c&iacute;rculos pueden representar una unidad.'],['azar','No importa c&oacute;mo se parta la figura: cualquier divisi&oacute;n sirve.']], correct:'unidad', ok:'Muy bien. Primero se reconoce la unidad y despu&eacute;s se piensa en sus partes.', warn:'Vuelve a mirar los modelos: la unidad es el entero completo y las partes deben salir de esa misma figura.' } },
      { page:2, icon:'fas fa-cut', title:'La misma unidad se puede dividir', tag:'Idea clave: una fracci&oacute;n correcta usa partes iguales.', intro:'No basta con cortar una figura. Para representar bien una fracci&oacute;n, todas las partes deben medir lo mismo. Si una parte es m&aacute;s grande que otra, la fracci&oacute;n no se est&aacute; mostrando bien.', model:'<div class="modelo-grid">'+strip(4,0,'Divisi&oacute;n correcta','Las 4 partes tienen el mismo tama&ntilde;o.')+strip(4,0,'Divisi&oacute;n incorrecta','Las partes no son iguales, as&iacute; que no describen bien una fracci&oacute;n.',['1fr','1.5fr','.8fr','1.2fr'])+'</div>', activity:{ visualPrompt: visualRow([miniBar(4,0,'4 partes del mismo tama&ntilde;o')], 'La frase correcta debe explicar por qu&eacute; la divisi&oacute;n funciona.'), type:'fill', title:'Completa la idea', prompt:'Usa las palabras del banco para completar la regla de esta p&aacute;gina.', lines:['Una fracci&oacute;n se forma cuando la unidad se divide en {{b1}} {{b2}}.','Si las partes no son iguales, la fracci&oacute;n no est&aacute; bien representada.'], bank:[['partes','partes'],['iguales','iguales'],['colores','colores'],['grandes','grandes']], answers:{b1:'partes',b2:'iguales'}, ok:'Correcto. Las fracciones siempre se apoyan en partes iguales de una misma unidad.', warn:'Revisa la frase: las palabras correctas deben explicar c&oacute;mo se divide la unidad.' } },
      { page:3, icon:'fas fa-bread-slice', title:'Tomamos partes del todo', tag:'Idea clave: el numerador dice cu&aacute;ntas partes se toman.', intro:'Si la unidad ya est&aacute; dividida en partes iguales, podemos describir cu&aacute;ntas partes se tomaron. Esa lectura verbal ayuda a pasar del modelo a la fracci&oacute;n escrita.', model:'<div class="modelo-grid">'+strip(4,2,'Modelo principal','Hay 4 partes iguales y 2 est&aacute;n marcadas.')+frac(2,4,'Lectura','Se lee: dos cuartos.')+'</div>', activity:{ visualPrompt: visualRow([miniBar(4,2,'2 de 4 partes'), miniFrac(2,4,'2/4')], '&iquest;Cu&aacute;l frase describe exactamente este modelo?'), type:'choice', title:'Elige la frase correcta', prompt:'Observa el modelo y selecciona la afirmaci&oacute;n que s&iacute; lo describe.', options:[['correcta','Se tomaron 2 de 4 partes iguales, por eso la fracci&oacute;n es 2/4.'],['a','Se tomaron 4 de 2 partes, por eso la fracci&oacute;n es 4/2.'],['b','La figura representa 2/2 porque hay dos partes coloreadas.'],['c','No se puede leer una fracci&oacute;n si la unidad est&aacute; dividida en 4 partes.']], correct:'correcta', ok:'Bien. La frase correcta menciona cu&aacute;ntas partes se toman y cu&aacute;ntas partes iguales hay en total.', warn:'Busca la opci&oacute;n que dice cu&aacute;ntas partes est&aacute;n marcadas y cu&aacute;ntas partes iguales hay en total.' } },
      { page:4, icon:'fas fa-layer-group', title:'Arriba y abajo en la fracci&oacute;n', tag:'Idea clave: arriba est&aacute; el numerador y abajo el denominador.', intro:'En una fracci&oacute;n, el n&uacute;mero de arriba y el de abajo no hacen el mismo trabajo. Uno cuenta las partes tomadas y el otro indica en cu&aacute;ntas partes iguales se dividi&oacute; la unidad.', model:'<div class="modelo-grid">'+frac(2,5,'Fracci&oacute;n de ejemplo','En 2/5, el 2 est&aacute; arriba y el 5 est&aacute; abajo.')+'<div class="model-card"><div class="model-label">Lectura guiada</div><div class="model-note">Arriba: partes tomadas. Abajo: partes iguales de la unidad.</div></div></div>', activity:{ visualPrompt: visualRow([miniFrac(2,5,'2/5: arriba y abajo')], 'La pregunta usa la fracci&oacute;n 2/5: identifica el nombre del n&uacute;mero de arriba y del de abajo.'), type:'fill', title:'Completa la explicaci&oacute;n', prompt:'Coloca la palabra correcta en cada espacio.', lines:['En 2/5, el n&uacute;mero de arriba es el {{b1}}.','En 2/5, el n&uacute;mero de abajo es el {{b2}}.'], bank:[['numerador','numerador'],['denominador','denominador'],['entero','entero'],['modelo','modelo']], answers:{b1:'numerador',b2:'denominador'}, ok:'Exacto. El numerador va arriba y el denominador va abajo.', warn:'Recuerda: arriba se cuentan las partes tomadas y abajo las partes iguales de la unidad.' } },
      { page:5, icon:'fas fa-puzzle-piece', title:'Construimos la fracci&oacute;n', tag:'Idea clave: leer el modelo y escribir la fracci&oacute;n completa.', intro:'Para escribir una fracci&oacute;n completa, necesitamos dos datos: cu&aacute;ntas partes iguales tiene la unidad y cu&aacute;ntas de esas partes est&aacute;n se&ntilde;aladas o coloreadas.', model:'<div class="modelo-grid">'+strip(4,3,'Modelo principal','La unidad se dividi&oacute; en 4 partes iguales y 3 est&aacute;n coloreadas.')+frac(3,4,'Resultado esperado','La fracci&oacute;n que describe el modelo es 3/4.')+'</div>', activity:{ visualPrompt: visualRow([miniBar(4,3,'3 partes marcadas'), miniFrac(3,4,'3/4')], 'La explicaci&oacute;n correcta debe decir: 3 partes tomadas, 4 en total y fracci&oacute;n 3/4.'), type:'fill', title:'Arma la idea completa', prompt:'Usa el banco para completar la explicaci&oacute;n del modelo.', lines:['Se tomaron {{b1}} partes.','La unidad se dividi&oacute; en {{b2}} partes iguales.','La fracci&oacute;n que representa el modelo es {{b3}}.'], bank:[['3','3'],['4','4'],['3/4','3/4'],['2/4','2/4']], answers:{b1:'3',b2:'4',b3:'3/4'}, ok:'Muy bien. Le&iacute;ste el modelo y construiste la fracci&oacute;n completa.', warn:'Revisa otra vez el modelo: una respuesta dice cu&aacute;ntas partes se toman, otra cu&aacute;ntas hay en total y otra la fracci&oacute;n final.' } },
      { page:6, icon:'fas fa-sort-amount-down', title:'Comparamos con la misma unidad', tag:'Idea clave: con el mismo denominador, m&aacute;s numerador significa m&aacute;s cantidad.', intro:'Cuando varias fracciones vienen de la misma unidad y tienen el mismo denominador, comparar es m&aacute;s sencillo: la fracci&oacute;n mayor es la que toma m&aacute;s partes de ese mismo tama&ntilde;o.', model:'<div class="modelo-grid">'+strip(4,1,'1/4','Toma una parte de cuatro.')+strip(4,2,'2/4','Toma dos partes de cuatro.')+strip(4,3,'3/4','Toma tres partes de cuatro.')+'</div>', activity:{ visualPrompt: visualRow([miniBar(4,1,'1/4'), miniBar(4,2,'2/4'), miniBar(4,3,'3/4')], 'Haz el mismo orden que muestran las barras: de menos a m&aacute;s.'), type:'order', title:'Ordena de menor a mayor', prompt:'Haz clic en las fracciones en el orden correcto.', items:[['3/4','3/4'],['1/4','1/4'],['2/4','2/4']], correct:['1/4','2/4','3/4'], ok:'Correcto. Como las tres fracciones tienen el mismo denominador, basta comparar cu&aacute;ntas partes toma cada una.', warn:'Compara las barras: todas est&aacute;n divididas en 4 partes iguales. Ord&eacute;nalas desde la que toma menos hasta la que toma m&aacute;s.' } },
      { page:7, icon:'fas fa-road', title:'La fracci&oacute;n en la recta num&eacute;rica', tag:'Idea clave: una fracci&oacute;n tambi&eacute;n puede ubicarse como punto en una recta.', intro:'Una fracci&oacute;n no solo se ve en figuras. Tambi&eacute;n puede aparecer como un punto en la recta num&eacute;rica. Para ubicarla, observamos en cu&aacute;ntos saltos iguales se divide el tramo del 0 al 1.', model:'<div class="modelo-grid">'+line(4,3,'P','Desde el 0 hasta el punto P hay tres saltos de cuatro posibles.')+'<div class="model-card"><div class="model-label">Pista verbal</div><div class="model-note">P est&aacute; despu&eacute;s de 2/4 y antes de 1.</div></div></div>', activity:{ visualPrompt: visualRow([miniLine(4,3,'P')], '&iquest;Qu&eacute; opci&oacute;n nombra la posici&oacute;n de P?'), type:'choice', title:'Lee la recta', prompt:'&iquest;Qu&eacute; fracci&oacute;n representa el punto P?', options:[['1/4','1/4'],['2/4','2/4'],['3/4','3/4'],['4/4','4/4']], correct:'3/4', ok:'Muy bien. El punto est&aacute; en el tercer salto de cuatro, as&iacute; que representa 3/4.', warn:'Cuenta los saltos iguales desde el 0 hasta el punto marcado.' } }
    ];
    let paginaActual = 1; const totalPaginas = PAGES.length; const actividadesResueltas = Object.fromEntries(PAGES.map(p => [p.page,false])); const paginasRegistradas = {}; const state = {};
    const tracker = window.createReforzamientoTracker ? window.createReforzamientoTracker({ trackTime:false, contenidoId:4, nivel:'facil', estilo:'visual_verbal', detalleBase:{ bloque:'reconocer_fracciones', motor:'vv_facil' }, apartados:Object.fromEntries(PAGES.map(p => ['frac_vv_facil_p' + p.page, { pagina:p.page, apartadoClave:'frac_vv_facil_p' + p.page, tipoActividad:'reforzamiento' }])) }) : null;
    const session = window.createReforzamientoSessionTracker ? window.createReforzamientoSessionTracker({ contenidoId:4, nivel:'facil', estilo:'visual_verbal' }) : null;
    const sonidos = { pasarPagina:new Audio('/contenidos/matematicas/recursos/sonidos/whoosh.mp3'), click:new Audio('/contenidos/matematicas/recursos/sonidos/click.mp3'), correcto:new Audio('/contenidos/matematicas/recursos/sonidos/ding.mp3'), incorrecto:new Audio('/contenidos/matematicas/recursos/sonidos/error.mp3') }; Object.values(sonidos).forEach(s=>{ if(s&&s.src) s.volume=.2; });
    function volverAlMenu(){ window.location.href='../../menu.html'; } function reproducirSonido(n){ if(sonidos[n]&&sonidos[n].src){ sonidos[n].currentTime=0; sonidos[n].play().catch(()=>{}); } } function sectionKey(page){ return 'frac_vv_facil_p' + page; } function registrarVisible(){ if(tracker) tracker.markPageVisibleByNumber(paginaActual,{ motor:'vv_facil' }); }
    function registrarError(page,tipo){ reproducirSonido('incorrecto'); if(tracker) tracker.addError(sectionKey(page),1,{ ejercicio:tipo||'principal' }); }
    function registrarAcierto(page,tipo){ if(!tracker || paginasRegistradas[page]) return; paginasRegistradas[page]=true; tracker.addCorrect(sectionKey(page),1,{ ejercicio:tipo||'principal' }); tracker.complete(sectionKey(page),{ detalle:{ estado:'resuelto', ejercicio:tipo||'principal' } }); }
    function ensureState(page){ if(state[page]) return state[page]; const act = PAGES.find(p=>p.page===page).activity; state[page] = act.type==='choice' ? { selected:null, optionOrder:shuffleAvoid(act.options, act.options.map(item => item[0])) } : act.type==='fill' ? { values:{}, activeBlank:Object.keys(act.answers)[0], bankOrder:shuffleAvoid(act.bank, act.bank.map(item => item[0])) } : { sequence:[], itemOrder:shuffleAvoid(act.items, act.correct) }; return state[page]; }
    function fillLine(line, values, active){ return line.replace(/{{(.*?)}}/g, (_,key)=>{ const text = values[key] || '______'; const cls = ['blank']; if(values[key]) cls.push('filled'); if(active===key) cls.push('active'); return '<button type="button" class="'+cls.join(' ')+'" data-blank="'+key+'">'+text+'</button>'; }); }
    function renderCurrentPage(){ const page = PAGES[paginaActual-1]; const pageState = ensureState(page.page); const act = page.activity; let activityHtml=''; if(act.type==='choice'){ activityHtml = '<div class="option-grid">'+pageState.optionOrder.map(([value,label])=>'<button type="button" class="opcion-card'+(pageState.selected===value?' selected':'')+'" data-value="'+value+'">'+label+'</button>').join('')+'</div>'; }
      if(act.type==='fill'){ activityHtml = '<div class="fill-wrap">'+act.lines.map(line=>'<div class="fill-line">'+fillLine(line, pageState.values, pageState.activeBlank)+'</div>').join('')+'</div><div class="bank">'+pageState.bankOrder.map(([value,label])=>'<button type="button" class="word-chip" data-value="'+value+'">'+label+'</button>').join('')+'</div>'; }
      if(act.type==='order'){ activityHtml = '<div class="order-bank">'+pageState.itemOrder.map(([value,label])=>'<button type="button" class="order-chip'+(pageState.sequence.includes(value)?' used':'')+'" data-value="'+value+'">'+label+'</button>').join('')+'</div><div class="answer-track">'+act.items.map((_,index)=>'<div class="answer-slot">'+(pageState.sequence[index] ? pageState.sequence[index] : '<span>' + (index+1) + '</span>')+'</div>').join('')+'</div>'; }
      document.getElementById('pageHost').innerHTML = '<div class="titulo-pagina"><i class="'+page.icon+' me-2"></i>'+page.title+'</div><div class="texto-destacado">'+page.intro+'</div><div class="mini-etiqueta">'+page.tag+'</div><div class="modelo-box">'+page.model+'</div><div class="actividad"><h3>'+act.title+'</h3>'+(act.visualPrompt||'')+'<p class="consigna">'+act.prompt+'</p>'+activityHtml+'<div class="acciones"><button type="button" class="btn-accion" id="verifyBtn">Verificar</button><button type="button" class="btn-accion secundario" id="clearBtn">'+(act.type==='choice'?'Borrar selecci&oacute;n':'Borrar')+'</button></div><div class="feedback ok" id="okMsg">'+act.ok+'</div><div class="feedback warn" id="warnMsg">'+act.warn+'</div></div>'+(paginaActual===totalPaginas?'<div class="quiz-wrap"><a href="quiz.html" class="boton-quiz'+(actividadesResueltas[totalPaginas]?'':' bloqueado')+'" id="btnMiniQuiz" onclick="return validarMiniQuiz(event)"><i class="fas fa-puzzle-piece me-2"></i>Ir al Mini-Quiz</a></div>':'');
      wirePage(); }
    function showFeedback(ok){ document.getElementById('okMsg').classList.toggle('visible', ok); document.getElementById('warnMsg').classList.toggle('visible', !ok); }
    function clearFeedback(){ document.getElementById('okMsg').classList.remove('visible'); document.getElementById('warnMsg').classList.remove('visible'); }
    function wirePage(){ const page = PAGES[paginaActual-1]; const pageState = ensureState(page.page); const act = page.activity; if(act.type==='choice'){ [...document.querySelectorAll('.opcion-card')].forEach(btn=>btn.addEventListener('click',()=>{ if(actividadesResueltas[page.page]) return; reproducirSonido('click'); pageState.selected = btn.dataset.value; clearFeedback(); renderCurrentPage(); })); }
      if(act.type==='fill'){ [...document.querySelectorAll('.blank')].forEach(btn=>btn.addEventListener('click',()=>{ if(actividadesResueltas[page.page]) return; reproducirSonido('click'); pageState.activeBlank = btn.dataset.blank; clearFeedback(); renderCurrentPage(); })); [...document.querySelectorAll('.word-chip')].forEach(btn=>btn.addEventListener('click',()=>{ if(actividadesResueltas[page.page]) return; reproducirSonido('click'); pageState.values[pageState.activeBlank] = btn.dataset.value; const next = Object.keys(act.answers).find(key=>!pageState.values[key]); pageState.activeBlank = next || pageState.activeBlank; clearFeedback(); renderCurrentPage(); })); }
      if(act.type==='order'){ [...document.querySelectorAll('.order-chip')].forEach(btn=>btn.addEventListener('click',()=>{ if(actividadesResueltas[page.page] || pageState.sequence.includes(btn.dataset.value)) return; reproducirSonido('click'); pageState.sequence.push(btn.dataset.value); clearFeedback(); renderCurrentPage(); })); }
      document.getElementById('verifyBtn').addEventListener('click',()=>{ if(actividadesResueltas[page.page]) return; let ok=false; if(act.type==='choice') ok = pageState.selected===act.correct; if(act.type==='fill') ok = Object.entries(act.answers).every(([k,v])=>pageState.values[k]===v); if(act.type==='order') ok = pageState.sequence.join('|')===act.correct.join('|'); if(ok){ showFeedback(true); resolverPagina(page.page); if(paginaActual===totalPaginas) setTimeout(renderCurrentPage,0); } else { showFeedback(false); registrarError(page.page, act.type); } });
      document.getElementById('clearBtn').addEventListener('click',()=>{ if(actividadesResueltas[page.page]) return; if(act.type==='choice') pageState.selected=null; if(act.type==='fill'){ pageState.values={}; pageState.activeBlank = Object.keys(act.answers)[0]; } if(act.type==='order') pageState.sequence=[]; clearFeedback(); renderCurrentPage(); });
      const btnQuiz = document.getElementById('btnMiniQuiz'); if(btnQuiz && session){ btnQuiz.addEventListener('click', async (event)=>{ if(!actividadesResueltas[totalPaginas]) return; event.preventDefault(); await session.complete({ eventoCierre:'quiz' }); window.location.href = btnQuiz.getAttribute('href'); }); }
    }
    function cambiarPagina(dir){ paginaActual += dir; reproducirSonido('pasarPagina'); actualizarNavegacion(); registrarVisible(); renderCurrentPage(); window.scrollTo({top:0, behavior:'smooth'}); }
    function actualizarNavegacion(){ document.getElementById('progresoTexto').innerHTML = 'P&aacute;gina ' + paginaActual + ' de ' + totalPaginas; document.getElementById('contadorPagina').innerText = paginaActual + '/' + totalPaginas; const pct=(paginaActual/totalPaginas)*100; document.getElementById('barraRelleno').style.width = pct + '%'; document.getElementById('progresoNum').innerText = Math.round(pct) + '%'; document.getElementById('btnAnterior').disabled = paginaActual===1; document.getElementById('btnSiguiente').disabled = paginaActual===totalPaginas || !actividadesResueltas[paginaActual]; }
    function resolverPagina(page){ actividadesResueltas[page]=true; reproducirSonido('correcto'); registrarAcierto(page,'principal'); actualizarNavegacion(); }
    function validarMiniQuiz(event){ if(!actividadesResueltas[totalPaginas]){ event.preventDefault(); return false; } return true; }
    window.addEventListener('DOMContentLoaded',()=>{ if(session) session.start(); actualizarNavegacion(); registrarVisible(); renderCurrentPage(); });
  </script>
