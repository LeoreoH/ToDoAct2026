    <div class="page" id="pagina7">
      <div class="card-main">
        <h2 class="title"><i class="fas fa-road me-3"></i>La fracci&oacute;n en la recta num&eacute;rica</h2>
        <p class="frase-clave">Una fracci&oacute;n es un punto entre el 0 y el 1.</p>
        <div class="audio-box">
          <button type="button" class="audio-btn" data-audio="audio_p7_intro"><i class="fas fa-play"></i></button>
          <div class="audio-label"><i class="fas fa-volume-up me-2"></i>Escucha la explicaci&oacute;n</div>
        </div>
        <div class="recta-box">
          <div class="recta">
            <div class="recta-linea"></div>
            <div class="recta-mark" style="left:5%"><span>0</span></div>
            <div class="recta-mark" style="left:28%"><span>1/4</span></div>
            <div class="recta-mark" style="left:50%"><span>2/4</span></div>
            <div class="recta-mark" style="left:72%"><span>3/4</span></div>
            <div class="recta-mark" style="left:95%"><span>1</span></div>
