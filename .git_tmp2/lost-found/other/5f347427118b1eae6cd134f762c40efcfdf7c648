    .tarjeta { background: white; border-radius: 28px; border: 3px solid #7b1fa2; box-shadow: 0 10px 0 #d1c4e9; padding: 26px; }
    .titulo-pagina { font-family: 'Fredoka One', cursive; font-size: 1.95rem; color: #6a1b9a; margin-bottom: 16px; border-left: 8px solid #ffd54f; padding-left: 18px; }
    .texto-destacado { background: #faf5ff; border: 2px dashed #ce93d8; border-radius: 18px; padding: 16px 18px; color: #5e35b1; font-weight: 700; margin-bottom: 18px; text-align: center; line-height: 1.5; }
    .recuadro { background: #f7f1ff; border-radius: 20px; padding: 18px; border-left: 7px solid #ffd54f; margin: 18px 0; line-height: 1.55; }
    .caso-grid, .seleccion-grid, .column-board, .report-grid, .match-grid, .pair-preview { display: grid; gap: 16px; }
    .caso-grid, .seleccion-grid, .report-grid { grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); }
    .column-board { grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); }
    .match-grid { grid-template-columns: 1.1fr .8fr 1.1fr; align-items: start; }
    .panel, .option-card, .column-panel, .report-card, .match-card, .sequence-slot, .drop-card { background: white; border: 3px solid #d1a6ff; border-radius: 22px; padding: 16px; box-shadow: 0 5px 0 #e1bee7; }
    .panel-title, .column-title, .report-title, .match-title, .drop-title { font-weight: 900; color: #6a1b9a; margin-bottom: 12px; text-align: center; }
    .panel-note, .micro-copy, .poster-note { margin-top: 12px; color: #6a1b9a; font-weight: 700; line-height: 1.45; text-align: center; }
