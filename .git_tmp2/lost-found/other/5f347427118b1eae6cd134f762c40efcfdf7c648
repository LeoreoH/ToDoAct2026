    .cabecera { background: linear-gradient(135deg, #8e24aa, #5e35b1); color: white; text-align: center; padding: 28px 20px; border-bottom: 6px solid #ffd54f; box-shadow: 0 8px 20px rgba(0,0,0,.18); position: relative; }
