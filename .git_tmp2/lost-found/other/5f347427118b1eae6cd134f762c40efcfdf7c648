    function buildCard(value) { return `<div class="ficha" draggable="true" data-value="${value}">${cardMarkup[value]()}</div>`; }
    function renderStrictTray(id, values, forbidden) { const tray = document.getElementById(id); const shuffled = shuffleArray(values, forbidden ? [forbidden] : []); tray.innerHTML = shuffled.map((value) => buildCard(value)).join(''); }
    function setupStrictPage(page, sourceSelector, zoneIds, okId, warnId, errorKey) { document.querySelectorAll(sourceSelector).forEach(attachDragCard); zoneIds.forEach((id) => { const zone = document.getElementById(id); if (!zone) return; zone.addEventListener('dragover', (event) => { event.preventDefault(); handleGlobalDragOver(event); }); zone.addEventListener('drop', (event) => { event.preventDefault(); if (actividadesResueltas[page] || !fichaArrastrada || zone.querySelector('.ficha')) return; const accepted = (zone.dataset.acceptList || '').split('|').filter(Boolean); if (accepted.includes(fichaArrastrada.dataset.value)) { const oldParent = fichaArrastrada.parentElement; if (oldParent && oldParent.classList.contains('rank-slot')) { oldParent.classList.remove('has-card'); oldParent.innerHTML = '<span class="placeholder">Suelta aqu&iacute;</span>'; } const placeholder = zone.querySelector('.placeholder'); if (placeholder) placeholder.remove(); zone.classList.add('has-card'); zone.appendChild(fichaArrastrada); strictPageState[page][id] = fichaArrastrada.dataset.value; if (zoneIds.every((zoneId) => document.getElementById(zoneId).querySelector('.ficha'))) { zoneIds.forEach((zoneId) => document.getElementById(zoneId).classList.add('correcta')); showFeedback(page, true); resolverPagina(page); } } else { registrarError(page, errorKey); markIncorrect([zone]); showFeedback(page, false); } stopAutoScroll(); }); }); }
    function renderPage1() { document.getElementById('demoP1Pizza').innerHTML = buildPizza(4, 3); document.getElementById('caseP1Pizza').innerHTML = buildPizza(8, 5); renderStrictTray('trayP1', ['frac_5_8','dec_0625','pct_625','dec_0652','pct_58','frac_5_6'], 'frac_5_8|dec_0625|pct_625|dec_0652|pct_58|frac_5_6'); }
    function renderPage2() { document.getElementById('demoP2Grid').innerHTML = buildGrid(45); document.getElementById('caseP2Grid').innerHTML = buildGrid(68); renderStrictTray('trayP2', ['frac_17_25','dec_068','pct_68','frac_13_25','dec_086','pct_86'], 'frac_17_25|dec_068|pct_68|frac_13_25|dec_086|pct_86'); }
    function renderPage3() { const tray = document.getElementById('trayP3'); tray.innerHTML = [buildCard('good_pct375'), buildCard('wrong_pct38'), buildCard('wrong_pct30')].join(''); attachDragCard(document.getElementById('chipP3Bad')); document.querySelectorAll('#trayP3 .ficha').forEach(attachDragCard); }
    function renderPage4() { document.getElementById('demoP4Line').innerHTML = buildLine(4, 3); document.getElementById('caseP4Line').innerHTML = buildLine(10, 7); renderStrictTray('trayP4', ['frac_7_10','dec_070','pct_70','frac_7_8','dec_007','pct_17'], 'frac_7_10|dec_070|pct_70|frac_7_8|dec_007|pct_17'); }
    function renderPage5() { document.getElementById('caseP5Left').innerHTML = buildStrip(5, 3); document.getElementById('caseP5Right').innerHTML = buildGrid(58); renderStrictTray('trayP5', ['dec_060','sign_greater','dec_058','dec_065','sign_less','sign_equal'], 'dec_060|sign_greater|dec_058|dec_065|sign_less|sign_equal'); }
    function renderPage6() { renderStrictTray('trayP6', ['pct_35','frac_3_8','dec_040','frac_1_2'], 'pct_35|frac_3_8|dec_040|frac_1_2'); }
    function buildPosterCard(offer) { return `<div class="poster-card"><div><div class="poster-badge">${offer.badge}</div><div class="panel-title" style="margin-bottom:6px">${offer.title}</div></div><div class="panel-note">${offer.body}</div><div class="poster-note">${offer.note}</div></div>`; }
    function renderPage7() { const tray = document.getElementById('trayP7'); const offers = shuffleArray(p7Offers, ['offer_quarter|offer_30|offer_third|offer_040']); tray.innerHTML = offers.map((offer) => `<div class="ficha" draggable="true" data-value="${offer.value}">${buildPosterCard(offer)}</div>`).join(''); Object.keys(p7State).forEach((key) => p7State[key] = null); ['rankP7A','rankP7B','rankP7C','rankP7D'].forEach((id) => { const zone = document.getElementById(id); zone.innerHTML = '<span class="placeholder">Suelta aqu&iacute;</span>'; zone.classList.remove('has-card', 'correcta', 'incorrecta'); }); document.querySelectorAll('#trayP7 .ficha').forEach(attachDragCard); }
    function setupFreeSortPage() { ['trayP7','rankP7A','rankP7B','rankP7C','rankP7D'].forEach((id) => { const zone = document.getElementById(id); zone.addEventListener('dragover', (event) => { event.preventDefault(); handleGlobalDragOver(event); }); zone.addEventListener('drop', (event) => { event.preventDefault(); if (actividadesResueltas[7] || !fichaArrastrada) return; const from = fichaArrastrada.parentElement; if (zone.id !== 'trayP7' && zone.querySelector('.ficha')) return; if (from && from.classList.contains('rank-slot')) { from.classList.remove('has-card'); from.innerHTML = '<span class="placeholder">Suelta aqu&iacute;</span>'; p7State[from.id] = null; } if (zone.id !== 'trayP7') { const placeholder = zone.querySelector('.placeholder'); if (placeholder) placeholder.remove(); zone.classList.add('has-card'); p7State[zone.id] = fichaArrastrada.dataset.value; } zone.appendChild(fichaArrastrada); stopAutoScroll(); if (['rankP7A','rankP7B','rankP7C','rankP7D'].every((slot) => p7State[slot])) { const expected = ['offer_quarter','offer_30','offer_third','offer_040']; const ok = expected.every((value, index) => p7State[['rankP7A','rankP7B','rankP7C','rankP7D'][index]] === value); if (ok) { ['rankP7A','rankP7B','rankP7C','rankP7D'].forEach((slot) => document.getElementById(slot).classList.add('correcta')); showFeedback(7, true); resolverPagina(7); } else { registrarError(7, 'ordenar_descuentos'); const wrong = ['rankP7A','rankP7B','rankP7C','rankP7D'].filter((slot, index) => p7State[slot] !== expected[index]).map((slot) => document.getElementById(slot)); markIncorrect(wrong); showFeedback(7, false); } } }); }); }
    function reiniciarPagina7() { if (actividadesResueltas[7]) return; renderPage7(); }
    function renderPage8() { renderStrictTray('trayP8', ['pair_3_5','pair_125','pair_075','pair_35'], 'pair_3_5|pair_125|pair_075|pair_35'); }
    function bindMiniQuiz() { const btn = document.getElementById('btnMiniQuiz'); btn.addEventListener('click', async (event) => { event.preventDefault(); if (!actividadesResueltas[8]) return; if (session) await session.complete({ eventoCierre: 'quiz' }); window.location.href = 'quiz.html'; }); }
    window.addEventListener('dragover', handleGlobalDragOver); window.addEventListener('drop', stopAutoScroll);
    window.addEventListener('DOMContentLoaded', () => {
      renderPage1(); renderPage2(); renderPage3(); renderPage4(); renderPage5(); renderPage6(); renderPage7(); renderPage8();
      setupStrictPage(1, '#trayP1 .ficha', ['zoneP1Frac','zoneP1Dec','zoneP1Pct'], 'feedback1ok', 'feedback1warn', 'pedido_equivalente');
      setupStrictPage(2, '#trayP2 .ficha', ['zoneP2Frac','zoneP2Dec','zoneP2Pct'], 'feedback2ok', 'feedback2warn', 'registro_semillero');
      setupStrictPage(3, '#trayP3 .ficha, #chipP3Bad', ['zoneP3Trash','zoneP3Fix'], 'feedback3ok', 'feedback3warn', 'reparar_etiqueta');
      setupStrictPage(4, '#trayP4 .ficha', ['zoneP4Frac','zoneP4Dec','zoneP4Pct'], 'feedback4ok', 'feedback4warn', 'punto_recta');
      setupStrictPage(5, '#trayP5 .ficha', ['zoneP5Dec','zoneP5Sign'], 'feedback5ok', 'feedback5warn', 'comparar_jugos');
      setupStrictPage(6, '#trayP6 .ficha', ['zoneP6A','zoneP6B','zoneP6C','zoneP6D'], 'feedback6ok', 'feedback6warn', 'ordenar_laboratorio');
      setupFreeSortPage();
      setupStrictPage(8, '#trayP8 .ficha', ['zoneP8A','zoneP8B','zoneP8C','zoneP8D'], 'feedback8ok', 'feedback8warn', 'rescate_final');
      bindMiniQuiz(); if (session) session.start(); registrarVisible(); actualizarNavegacion();
    });
  </script>
