    .hint-badge { display: inline-block; background: #fff3c4; color: #7b1fa2; border: 2px solid #ffca28; border-radius: 999px; padding: 6px 12px; font-size: .95rem; font-weight: 900; margin-bottom: 10px; }
    .option-card, .column-option, .report-card, .sign-card, .match-card { cursor: pointer; transition: .18s ease; }
    .option-card:hover, .column-option:hover, .report-card:hover, .sign-card:hover, .match-card:hover { transform: translateY(-3px) scale(1.01); border-color: #8e24aa; }
    .option-card.selected, .column-option.selected, .report-card.selected, .sign-card.selected, .match-card.active { background: #efe0ff; border-color: #7b1fa2; box-shadow: 0 6px 0 #c7a4ea; }
    .option-card.correcta, .column-option.correcta, .report-card.correcta, .sign-card.correcta, .match-card.matched, .sequence-slot.correcta, .rank-slot.correcta { background: #e8f5e9; border-color: #43a047; color: #2e7d32; }
    .option-card.incorrecta, .column-option.incorrecta, .report-card.incorrecta, .sign-card.incorrecta, .match-card.incorrecta, .sequence-slot.incorrecta, .rank-slot.incorrecta, .tray-drop.incorrecta { background: #ffebee; border-color: #e53935; color: #c62828; }
    .choice-strip { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; }
    .column-option, .sign-card { border: 3px solid #d1a6ff; border-radius: 18px; background: white; box-shadow: 0 5px 0 #e1bee7; padding: 14px; text-align: center; font-weight: 800; color: #5e35b1; }
    .column-option { min-height: 86px; }
    .sequence-board { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 12px; margin-top: 14px; }
