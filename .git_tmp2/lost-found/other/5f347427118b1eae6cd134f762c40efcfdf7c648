    .sequence-slot.has-value { border-style: solid; }
    .bandeja { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; min-height: 92px; padding: 14px; border-radius: 20px; border: 3px solid #d1c4e9; background: white; margin-top: 12px; }
    .bandeja-sticky { position: sticky; top: 12px; z-index: 12; }
    .rank-board { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 14px; margin-top: 16px; }
    .rank-slot, .tray-drop { min-height: 150px; padding: 14px; border-radius: 22px; border: 3px dashed #ab47bc; background: #faf5ff; display: flex; align-items: center; justify-content: center; text-align: center; color: #8e24aa; font-weight: 800; }
    .rank-slot.has-card, .tray-drop.has-card { border-style: solid; background: #fff; }
    .ficha { min-width: 110px; padding: 14px 16px; border-radius: 18px; background: linear-gradient(135deg, #ffffff, #f7f1ff); border: 3px solid #7b1fa2; box-shadow: 0 5px 0 #d1c4e9; text-align: center; font-weight: 800; color: #5e35b1; cursor: grab; user-select: none; transition: .2s; }
    .ficha:hover { transform: translateY(-2px) scale(1.02); }
    .ficha.dragging { opacity: .65; transform: scale(1.04); }
    .story-tag { display: inline-flex; align-items: center; justify-content: center; min-width: 108px; padding: 10px 16px; border-radius: 999px; border: 3px solid #7b1fa2; background: #f3e5f5; color: #5e35b1; font-size: 1.2rem; font-weight: 900; box-shadow: 0 5px 0 #d1c4e9; margin: 0 auto; }
    .fraction-chip { min-width: 96px; padding: 8px 16px; border-radius: 20px; border: 3px solid #7b1fa2; background: #f3e5f5; box-shadow: 0 5px 0 #d1c4e9; display: inline-flex; align-items: center; justify-content: center; margin: 0 auto; }
    .fraction-stack { display: flex; flex-direction: column; align-items: center; justify-content: center; font-weight: 900; color: #5e35b1; line-height: 1; font-size: 1.15rem; }
    .fraction-bar { width: 34px; border-top: 3px solid #7b1fa2; margin: 4px 0; }
    .hundred-grid { display: grid; grid-template-columns: repeat(10, 1fr); gap: 4px; max-width: 300px; margin: 0 auto; padding: 10px; border-radius: 18px; background: white; border: 4px solid #7b1fa2; box-shadow: 0 6px 0 #d1c4e9; }
    .grid-cell { aspect-ratio: 1 / 1; border-radius: 6px; background: #f3e5f5; border: 1px solid #d1c4e9; }
    .grid-cell.fill { background: linear-gradient(135deg, #ba68c8, #7e57c2); border-color: #7b1fa2; }
    .strip-box { display: grid; grid-template-columns: repeat(var(--cols), 1fr); gap: 4px; max-width: 360px; margin: 0 auto; padding: 10px; border-radius: 18px; background: white; border: 4px solid #7b1fa2; box-shadow: 0 6px 0 #d1c4e9; }
    .strip-cell { aspect-ratio: 1.2 / 1; border-radius: 6px; background: #fff8e1; border: 1px solid #d1c4e9; }
    .strip-cell.fill { background: linear-gradient(135deg, #ffca28, #ff8f00); border-color: #ef6c00; }
    .pizza-wrap { display: flex; justify-content: center; margin: 4px auto 12px; }
    .pizza-disc { --total: 8; --fill: 4; width: 160px; height: 160px; border-radius: 50%; border: 8px solid #ffb74d; box-shadow: 0 6px 0 #d39e00; background: repeating-conic-gradient(from -90deg, rgba(255,255,255,.18) 0 calc(360deg / var(--total) - 2deg), rgba(123,31,162,.85) calc(360deg / var(--total) - 2deg) calc(360deg / var(--total))), conic-gradient(from -90deg, #ffe082 0 calc(360deg * var(--fill) / var(--total)), #f3e5f5 calc(360deg * var(--fill) / var(--total)) 360deg); position: relative; }
    .pizza-disc::after { content: ''; position: absolute; inset: 12px; border-radius: 50%; border: 2px dashed rgba(123,31,162,.28); }
    .line-wrap { width: min(690px, 100%); position: relative; height: 130px; margin: 0 auto; }
    .line-track { position: absolute; left: 6%; right: 6%; top: 58px; height: 6px; background: #7b1fa2; border-radius: 999px; }
    .line-mark { position: absolute; top: 28px; width: 0; height: 42px; border-left: 4px solid #7b1fa2; transform: translateX(-50%); }
    .line-mark span { position: absolute; top: 44px; left: 50%; transform: translateX(-50%); font-weight: 800; color: #6a1b9a; white-space: nowrap; font-size: .9rem; }
    .line-point { position: absolute; top: 8px; width: 36px; height: 36px; border-radius: 50%; background: #ffd54f; border: 3px solid #7b1fa2; transform: translateX(-50%); box-shadow: 0 4px 0 #d39e00; }
    .sign-options { display: flex; flex-wrap: wrap; gap: 14px; justify-content: center; margin-top: 14px; }
    .sign-card { min-width: 110px; min-height: 110px; display: flex; align-items: center; justify-content: center; font-size: 2rem; font-weight: 900; }
    .match-column { display: flex; flex-direction: column; gap: 12px; }
    .match-card.matched { cursor: default; box-shadow: 0 5px 0 #9ccc65; }
    .pair-preview { grid-template-columns: 1fr; min-height: 260px; align-content: start; }
    .pair-row { background: white; border: 3px solid #c8b0ff; border-radius: 18px; padding: 12px; box-shadow: 0 4px 0 #e1bee7; display: flex; align-items: center; justify-content: center; gap: 12px; flex-wrap: wrap; font-weight: 900; color: #6a1b9a; }
    .poster-card { min-height: 148px; display: flex; flex-direction: column; justify-content: space-between; }
    .poster-badge { display: inline-block; background: #fff3c4; border: 2px solid #ffca28; color: #8e24aa; font-weight: 900; border-radius: 999px; padding: 6px 12px; margin-bottom: 10px; }
    .action-row { display: flex; justify-content: center; flex-wrap: wrap; gap: 14px; margin-top: 16px; }
    .btn-accion { border: none; border-radius: 999px; padding: 12px 26px; font-weight: 800; background: linear-gradient(135deg, #ab47bc, #7e57c2); color: white; box-shadow: 0 5px 0 #5e35b1; transition: .2s; }
    .btn-accion:hover { transform: translateY(-2px); }
    .mensaje-feedback { margin-top: 16px; padding: 14px 16px; border-radius: 16px; font-weight: 800; text-align: center; display: none; line-height: 1.45; }
    .mensaje-ok { background: #e8f5e9; color: #2e7d32; border: 2px solid #43a047; }
    .mensaje-warn { background: #fff3e0; color: #ef6c00; border: 2px solid #fb8c00; }
    .navegador { display: flex; justify-content: space-between; align-items: center; gap: 15px; background: white; border: 3px solid #7b1fa2; border-radius: 999px; padding: 12px 16px; margin-top: 28px; box-shadow: 0 8px 0 #d1c4e9; position: sticky; bottom: 18px; z-index: 20; }
    .btn-nav { border: none; border-radius: 999px; padding: 12px 22px; font-weight: 800; background: linear-gradient(135deg, #ab47bc, #7e57c2); color: white; box-shadow: 0 5px 0 #5e35b1; transition: .2s; }
    .btn-nav:hover:not(:disabled) { transform: translateY(-2px); }
    .btn-nav:disabled { opacity: .45; cursor: not-allowed; box-shadow: none; }
    .contador { font-weight: 900; color: #6a1b9a; font-size: 1.1rem; }
    .boton-quiz { display: inline-block; margin: 28px auto 0; text-decoration: none; background: #ffd54f; color: #4a148c; border: 4px solid #7b1fa2; padding: 16px 34px; border-radius: 999px; font-weight: 800; font-size: 1.2rem; box-shadow: 0 7px 0 #d39e00; transition: .2s; }
    .boton-quiz:hover { transform: translateY(-3px); background: #fff3c4; color: #4a148c; }
    .boton-quiz.bloqueado { opacity: .55; cursor: not-allowed; background: #e0e0e0; color: #7a7a7a; border-color: #bdbdbd; box-shadow: 0 7px 0 #9e9e9e; pointer-events: none; }
    .boton-quiz.bloqueado:hover { transform: none; background: #e0e0e0; color: #7a7a7a; }
    @media (max-width: 860px) { .match-grid { grid-template-columns: 1fr; } .pair-preview { min-height: auto; } }
    @media (max-width: 768px) { .cabecera h1 { font-size: 2rem; } .titulo-pagina { font-size: 1.55rem; } .btn-volver-menu { position: static; margin: 0 auto 16px; } .barra-progreso { margin-inline: 16px; } .navegador { flex-direction: column; border-radius: 24px; } .pizza-disc { width: 140px; height: 140px; } }
