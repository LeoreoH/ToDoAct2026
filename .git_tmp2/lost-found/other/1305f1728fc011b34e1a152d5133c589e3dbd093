<style>     * { margin: 0; padding: 0; box-sizing: border-box; }      body {       font-family: 'Nunito', sans-serif;       background: linear-gradient(135deg, #0d47a1, #01579b);       color: white;       min-height: 100vh;     }      .cabecera-visual {       background: linear-gradient(135deg, #1565c0, #0d47a1);       padding: 25px 20px;       border-bottom: 6px solid #ffd600;       text-align: center;       box-shadow: 0 10px 20px rgba(0,0,0,0.3);     }      .cabecera-visual h1 {       font-family: 'Fredoka One', cursive;       font-size: 3rem;       color: #ffd600;       text-shadow: 4px 4px 0 #002171;     }      .badge-estilo {       background: #ffd600;       color: #0d47a1;       padding: 12px 35px;       border-radius: 50px;       font-weight: 800;       font-size: 1.3rem;       display: inline-block;       border: 4px solid white;       margin-top: 10px;       box-shadow: 0 4px 0 #b26a00;     }      .badge-nivel {       background: #002171;       color: white;       padding: 8px 25px;       border-radius: 40px;       font-weight: 700;       font-size: 1.1rem;       display: inline-block;       margin-left: 15px;       border: 2px solid #ffd600;     }      .progreso-contenedor {       background: #1a237e;       border-radius: 60px;       margin: 20px auto;       max-width: 700px;       padding: 12px 25px;       display: flex;       align-items: center;       gap: 15px;       border: 3px solid #ffd600;       box-shadow: 0 5px 0 #002171;     }      .puntos {       display: flex;       gap: 10px;       flex: 1;       justify-content: center;     }      .punto {       width: 35px;       height: 35px;       border-radius: 50%;       background: #283593;       border: 3px solid #ffd600;       display: flex;       align-items: center;       justify-content: center;       font-weight: 800;       color: white;       transition: all 0.3s;     }      .punto.activo {       background: #ffd600;       color: #0d47a1;       transform: scale(1.15);     }      .punto.completado {       background: #4caf50;       color: white;       border-color: white;     }      .contenedor {       max-width: 1100px;       margin: 0 auto 40px;       padding: 0 20px;     }      .pagina {       display: none;       animation: fadeIn 0.4s ease;     }      .pagina.activa {       display: block;     }      @keyframes fadeIn {       from { opacity: 0; transform: translateY(10px); }       to { opacity: 1; transform: translateY(0); }     }      .tarjeta-visual {       background: #1e3a8a;       border-radius: 30px;       padding: 30px;       margin-bottom: 20px;       border: 3px solid #ffd600;       box-shadow: 0 8px 0 #002171;     }      .titulo-pagina {       font-family: 'Fredoka One', cursive;       font-size: 2.5rem;       color: #ffd600;       margin-bottom: 25px;       text-align: center;       text-shadow: 2px 2px 0 #002171;     }      /* IMÁGENES GRANDES - SIN FONDO BLANCO */     .imagen-grande {       background: #283593;       border: 4px solid #ffd600;       border-radius: 25px;       padding: 15px;       transition: all 0.3s;       height: 100%;       display: flex;       flex-direction: column;     }      .imagen-grande:hover {       transform: scale(1.02) rotate(1deg);       box-shadow: 0 10px 20px rgba(255,214,0,0.3);     }      .imagen-geo {       width: 100%;       max-height: 280px;       object-fit: contain;       border-radius: 15px;     }      .pie-imagen {       text-align: center;       margin-top: 10px;       color: #ffd600;       font-weight: 700;       font-size: 1rem;     }      /* CONTENEDORES DE DATOS - SIN BLANCO */     .grid-2cols {       display: grid;       grid-template-columns: repeat(2, 1fr);       gap: 25px;       margin: 25px 0;     }      .grid-4cols {       display: grid;       grid-template-columns: repeat(4, 1fr);       gap: 20px;       margin: 25px 0;     }      .grid-3cols {       display: grid;       grid-template-columns: repeat(3, 1fr);       gap: 20px;       margin: 25px 0;     }      .caja-info {       background: #283593;       border: 3px solid #ffd600;       border-radius: 20px;       padding: 20px 10px;       text-align: center;       height: 100%;       box-shadow: 0 4px 0 #002171;     }      .caja-info i {       font-size: 2.5rem;       color: #ffd600;       margin-bottom: 10px;     }      .caja-info h4 {       color: #ffd600;       font-weight: 800;       font-size: 1.5rem;       margin-bottom: 5px;     }      .caja-info p {       margin-bottom: 0;       color: white;       font-size: 1rem;     }      /* CONTENEDOR DE HORAS (PÁGINA 1 Y 2) */     .contenedor-horas {       background: #283593;       border: 3px solid #ffd600;       border-radius: 20px;       padding: 20px;       margin-bottom: 20px;       text-align: center;     }      .contenedor-horas i {       font-size: 2.5rem;       color: #ffd600;       margin-bottom: 10px;     }      .contenedor-horas h4 {       color: #ffd600;       font-weight: 800;       font-size: 2rem;       margin-bottom: 5px;     }      .contenedor-horas p {       margin-bottom: 0;       color: white;       font-size: 1.1rem;     }      .fila-doble {       display: grid;       grid-template-columns: repeat(2, 1fr);       gap: 15px;       margin-top: 15px;     }      .estacion-card {       background: #283593;       border: 3px solid #ffd600;       border-radius: 15px;       padding: 15px 5px;       text-align: center;     }      .estacion-card i {       color: #ffd600;       font-size: 2rem;       margin-bottom: 8px;     }      .estacion-card h5 {       color: #ffd600;       font-weight: 700;       font-size: 1.2rem;       margin-bottom: 5px;     }      .estacion-card p {       margin-bottom: 0;       font-size: 0.9rem;       color: white;     }      .etiqueta {       background: #ffd600;       color: #0d47a1;       padding: 12px 30px;       border-radius: 50px;       font-weight: 800;       font-size: 1.2rem;       display: inline-block;       border: 3px solid white;       box-shadow: 0 4px 0 #b26a00;     }      /* MINI PREGUNTAS */     .mini-pregunta {       background: #283593;       border: 4px solid #ffd600;       border-radius: 30px;       padding: 25px;       margin: 30px 0 20px;       text-align: center;     }      .mini-pregunta p {       font-size: 1.4rem;       font-weight: 700;       color: #ffd600;       margin-bottom: 20px;     }      .opciones-mini {       display: flex;       justify-content: center;       gap: 20px;       flex-wrap: wrap;     }      .btn-mini {       background: #ffd600;       color: #0d47a1;       border: 4px solid white;       padding: 12px 30px;       border-radius: 50px;       font-weight: 800;       font-size: 1.2rem;       cursor: pointer;       transition: all 0.2s;       box-shadow: 0 4px 0 #b26a00;     }      .btn-mini:hover {       transform: scale(1.05);       background: white;     }      .btn-mini.correcto {       background: #4caf50;       color: white;       box-shadow: 0 4px 0 #1b5e20;     }      .navegador {       display: flex;       justify-content: space-between;       align-items: center;       background: #1a237e;       padding: 15px 25px;       border-radius: 60px;       border: 3px solid #ffd600;       box-shadow: 0 6px 0 #002171;       margin: 30px 0;     }      .btn-nav {       background: #ffd600;       color: #0d47a1;       border: none;       padding: 12px 30px;       border-radius: 40px;       font-weight: 800;       font-size: 1.2rem;       border: 3px solid white;       transition: all 0.2s;       box-shadow: 0 4px 0 #b26a00;     }      .btn-nav:hover:not(:disabled) {       background: white;       transform: translateY(-2px);     }      .btn-nav:disabled {       background: #546e7a;       opacity: 0.5;       box-shadow: none;     }      .indicador {       background: #283593;       color: #ffd600;       padding: 8px 30px;       border-radius: 40px;       font-weight: 800;       font-size: 1.3rem;       border: 3px solid #ffd600;     }      .btn-quiz {       display: block;       width: fit-content;       margin: 0 auto;       background: #ffd600;       color: #0d47a1;       border: none;       padding: 15px 45px;       border-radius: 60px;       font-weight: 800;       font-size: 1.5rem;       text-decoration: none;       border: 4px solid white;       box-shadow: 0 6px 0 #b26a00;       transition: all 0.2s;     }      .btn-quiz:hover {       transform: translateY(-4px);       box-shadow: 0 10px 0 #b26a00;       background: white;     }      .btn-subir {       position: fixed;       bottom: 80px;       right: 20px;       background: #ffd600;       color: #0d47a1;       width: 50px;       height: 50px;       border-radius: 50%;       display: flex;       align-items: center;       justify-content: center;       font-size: 1.5rem;       border: 3px solid white;       box-shadow: 0 4px 0 #b26a00;       cursor: pointer;       transition: all 0.2s;       z-index: 1000;     }      .btn-subir:hover {       transform: translateY(-5px);       box-shadow: 0 8px 0 #b26a00;     }   </style>
</head>
<body>

