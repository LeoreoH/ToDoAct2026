<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>La Tierra · Nivel Fácil · Visual/No Verbal</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Fredoka+One&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  
<style>     * { margin: 0; padding: 0; box-sizing: border-box; }      body {       font-family: 'Nunito', sans-serif;       background: linear-gradient(135deg, #0d47a1, #01579b);       color: white;       min-height: 100vh;     }      .cabecera-visual {       background: linear-gradient(135deg, #1565c0, #0d47a1);       padding: 25px 20px;       border-bottom: 6px solid #ffd600;       text-align: center;       box-shadow: 0 10px 20px rgba(0,0,0,0.3);     }      .cabecera-visual h1 {       font-family: 'Fredoka One', cursive;       font-size: 3rem;       color: #ffd600;       text-shadow: 4px 4px 0 #002171;     }      .badge-estilo {       background: #ffd600;       color: #0d47a1;       padding: 12px 35px;       border-radius: 50px;       font-weight: 800;       font-size: 1.3rem;       display: inline-block;       border: 4px solid white;       margin-top: 10px;     }      .progreso-contenedor {       background: #1a237e;       border-radius: 60px;       margin: 20px auto;       max-width: 700px;       padding: 12px 25px;       display: flex;       align-items: center;       gap: 15px;       border: 3px solid #ffd600;       box-shadow: 0 5px 0 #002171;     }      .puntos {       display: flex;       gap: 10px;       flex: 1;       justify-content: center;     }      .punto {       width: 35px;       height: 35px;       border-radius: 50%;       background: #283593;       border: 3px solid #ffd600;       display: flex;       align-items: center;       justify-content: center;       font-weight: 800;       color: white;       transition: all 0.3s;     }      .punto.activo {       background: #ffd600;       color: #0d47a1;       transform: scale(1.15);     }      .punto.completado {       background: #4caf50;       border-color: white;       color: white;     }      .contenedor {       max-width: 1000px;       margin: 0 auto 40px;       padding: 0 20px;     }      .pagina {       display: none;       animation: fadeIn 0.4s ease;     }      .pagina.activa {       display: block;     }      @keyframes fadeIn {       from { opacity: 0; transform: translateY(10px); }       to { opacity: 1; transform: translateY(0); }     }      .tarjeta-visual {       background: #1e3a8a;       border-radius: 30px;       padding: 30px;       margin-bottom: 20px;       border: 3px solid #ffd600;       box-shadow: 0 8px 0 #002171;     }      .titulo-pagina {       font-family: 'Fredoka One', cursive;       font-size: 2.2rem;       color: #ffd600;       margin-bottom: 20px;       text-align: center;     }      /* IMÁGENES GRANDES CON ANIMACIÓN */     .imagen-grande {       background: #283593;       border: 4px solid #ffd600;       border-radius: 30px;       padding: 20px;       text-align: center;       transition: all 0.3s ease;       margin-bottom: 20px;     }      .imagen-grande:hover {       transform: scale(1.02) rotate(1deg);       box-shadow: 0 15px 30px rgba(255,214,0,0.4);     }      .imagen-geo {       width: 100%;       max-height: 300px;       object-fit: contain;       background: white;       border-radius: 15px;       padding: 10px;     }      .pie-imagen {       text-align: center;       margin-top: 10px;       color: #ffd600;       font-weight: 700;       font-size: 1.1rem;     }      /* GRIDS PARA MÚLTIPLES IMÁGENES */     .grid-2cols {       display: grid;       grid-template-columns: repeat(2, 1fr);       gap: 20px;       margin: 20px 0;     }      .grid-4cols {       display: grid;       grid-template-columns: repeat(4, 1fr);       gap: 15px;       margin: 20px 0;     }      .grid-3cols {       display: grid;       grid-template-columns: repeat(3, 1fr);       gap: 15px;       margin: 20px 0;     }      /* TARJETAS VISUALES */     .card-visual {       background: #283593;       border: 3px solid #ffd600;       border-radius: 20px;       padding: 20px 10px;       text-align: center;       transition: all 0.3s;       cursor: pointer;     }      .card-visual:hover {       transform: translateY(-5px);       background: #3949ab;     }      .card-visual i {       font-size: 3rem;       color: #ffd600;       margin-bottom: 10px;     }      .card-visual span {       font-size: 1.2rem;       font-weight: 700;       display: block;       color: white;     }      /* MINI PREGUNTA VISUAL */     .mini-pregunta {       background: #283593;       border: 4px solid #ffd600;       border-radius: 30px;       padding: 25px;       margin: 30px 0 20px;       text-align: center;     }      .mini-pregunta p {       font-size: 1.4rem;       font-weight: 700;       color: #ffd600;       margin-bottom: 20px;     }      .opciones-mini {       display: flex;       justify-content: center;       gap: 20px;       flex-wrap: wrap;     }      .btn-mini {       background: #ffd600;       color: #0d47a1;       border: 4px solid white;       padding: 12px 35px;       border-radius: 50px;       font-weight: 800;       font-size: 1.2rem;       cursor: pointer;       transition: all 0.2s;     }      .btn-mini:hover {       transform: scale(1.05);       background: white;     }      .btn-mini.correcto {       background: #4caf50;       color: white;     }      .navegador {       display: flex;       justify-content: space-between;       align-items: center;       background: #1a237e;       padding: 15px 25px;       border-radius: 60px;       border: 3px solid #ffd600;       box-shadow: 0 5px 0 #002171;       margin: 30px 0;     }      .btn-nav {       background: #ffd600;       color: #0d47a1;       border: none;       padding: 10px 25px;       border-radius: 40px;       font-weight: 800;       border: 3px solid white;       transition: all 0.2s;     }      .btn-nav:hover:not(:disabled) {       background: white;       transform: translateY(-2px);     }      .btn-nav:disabled {       background: #546e7a;       opacity: 0.5;     }      .indicador {       background: #283593;       color: #ffd600;       padding: 8px 30px;       border-radius: 40px;       font-weight: 800;       font-size: 1.3rem;       border: 3px solid #ffd600;     }      .btn-quiz {       display: block;       width: fit-content;       margin: 0 auto;       background: #ffd600;       color: #0d47a1;       border: none;       padding: 15px 45px;       border-radius: 60px;       font-weight: 800;       font-size: 1.5rem;       text-decoration: none;       border: 4px solid white;       box-shadow: 0 6px 0 #b26a00;       transition: all 0.2s;     }      .btn-quiz:hover {       transform: translateY(-4px);       box-shadow: 0 10px 0 #b26a00;       background: white;     }      .btn-subir {       position: fixed;       bottom: 80px;       right: 20px;       background: #ffd600;       color: #0d47a1;       width: 50px;       height: 50px;       border-radius: 50%;       display: flex;       align-items: center;       justify-content: center;       font-size: 1.5rem;       border: 3px solid white;       box-shadow: 0 4px 0 #b26a00;       cursor: pointer;       transition: all 0.2s;       z-index: 1000;     }      .btn-subir:hover {       transform: translateY(-5px);       box-shadow: 0 8px 0 #b26a00;     }   </style>
</head>
<body>

<div class="btn-subir" onclick="window.scrollTo({top: 0, behavior: 'smooth'});">
  <i class="fas fa-arrow-up"></i>
</div>

<div class="cabecera-visual">
  <h1>🌍 LA TIERRA</h1>
  <p class="lead text-white">Bloque I · Nivel Fácil</p>
  <div class="badge-estilo">👁️ Visual / No Verbal</div>
</div>

<div class="progreso-contenedor">
  <i class="fas fa-eye fa-2x" style="color: #ffd600;"></i>
  <div class="puntos" id="puntosProgreso">
    <div class="punto activo">1</div>
    <div class="punto">2</div>
    <div class="punto">3</div>
    <div class="punto">4</div>
  </div>
  <span class="badge" style="background: #ffd600; color: #0d47a1; padding: 8px 20px;">Página <span id="paginaActualNum">1</span>/4</span>
</div>

<div class="contenedor">

  <div class="pagina activa" id="pagina1">
    <div class="tarjeta-visual">
      <h2 class="titulo-pagina"><i class="fas fa-globe-americas me-3"></i>Nuestro Planeta</h2>

      <div class="grid-2cols">
        <div class="imagen-grande" onclick="ampliarImagen(this.querySelector('img'))">
          <img src="/contenidos/geografia/recursos/imagenes/libro/tierra-satelital.jpg"
               alt="Tierra desde el espacio" class="imagen-geo"
               onerror="this.src='https://eoimages.gsfc.nasa.gov/images/imagerecords/57000/57723/globe_west_2048.jpg'">
          <div class="pie-imagen">🌍 Vista satelital</div>
        </div>
        <div class="imagen-grande" onclick="ampliarImagen(this.querySelector('img'))">
          <img src="/contenidos/geografia/recursos/imagenes/libro/forma-tierra.jpg"
               alt="Forma de la Tierra" class="imagen-geo"
               onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/4/4e/Earth_oblique.svg/800px-Earth_oblique.svg.png'">
          <div class="pie-imagen">📐 Forma achatada</div>
        </div>
      </div>

      <div class="grid-3cols">
        <div class="card-visual" onclick="reproducirSonido('click')">
          <i class="fas fa-ruler"></i>
          <span>12,742 km</span>
          <small>Diámetro</small>
        </div>
        <div class="card-visual" onclick="reproducirSonido('click')">
          <i class="fas fa-water"></i>
          <span>71%</span>
          <small>Agua</small>
        </div>
        <div class="card-visual" onclick="reproducirSonido('click')">
          <i class="fas fa-clock"></i>
          <span>4.5B</span>
          <small>Años</small>
        </div>
      </div>

      <div class="reforzamiento">
        <div class="reforzamiento-titulo"><i class="fas fa-hand-pointer"></i> Responde</div>
        <p class="reforzamiento-instruccion">
          Observa las dos figuras. Pasa el cursor sobre cada una y haz clic en la que representa la forma real de la Tierra.
        </p>
        <div class="opciones-svg">

          <div class="opcion-svg" id="op1A" onclick="responder1('A')">
            <svg width="150" height="150" viewBox="0 0 150 150">
              <defs>
                <radialGradient id="gA1" cx="38%" cy="35%" r="60%">
                  <stop offset="0%" stop-color="#5c9bd6"/>
                  <stop offset="100%" stop-color="#1a3a6e"/>
                </radialGradient>
              </defs>
              <circle cx="75" cy="75" r="65" fill="url(#gA1)" stroke="#4a6fa5" stroke-width="2.5"/>
              <ellipse cx="60" cy="50" rx="18" ry="24" fill="#3d7a3d" opacity="0.75"/>
              <ellipse cx="96" cy="72" rx="20" ry="16" fill="#3d7a3d" opacity="0.75"/>
              <ellipse cx="70" cy="98" rx="16" ry="10" fill="#3d7a3d" opacity="0.65"/>
              <ellipse cx="75" cy="75" rx="65" ry="20" fill="none" stroke="white" stroke-width="1" opacity="0.2"/>
              <ellipse cx="75" cy="75" rx="65" ry="50" fill="none" stroke="white" stroke-width="1" opacity="0.2"/>
            </svg>
            <span>Figura A</span>
          </div>

          <div class="opcion-svg" id="op1B" onclick="responder1('B')">
            <svg width="150" height="150" viewBox="0 0 150 150">
              <defs>
                <radialGradient id="gB1" cx="38%" cy="35%" r="60%">
                  <stop offset="0%" stop-color="#5c9bd6"/>
                  <stop offset="100%" stop-color="#1a3a6e"/>
                </radialGradient>
              </defs>
              <ellipse cx="75" cy="75" rx="68" ry="56" fill="url(#gB1)" stroke="#4a6fa5" stroke-width="2.5"/>
              <ellipse cx="60" cy="52" rx="18" ry="21" fill="#3d7a3d" opacity="0.75"/>
              <ellipse cx="96" cy="72" rx="20" ry="14" fill="#3d7a3d" opacity="0.75"/>
              <ellipse cx="70" cy="97" rx="16" ry="9" fill="#3d7a3d" opacity="0.65"/>
              <ellipse cx="75" cy="75" rx="68" ry="18" fill="none" stroke="white" stroke-width="1" opacity="0.2"/>
              <ellipse cx="75" cy="75" rx="68" ry="44" fill="none" stroke="white" stroke-width="1" opacity="0.2"/>
            </svg>
            <span>Figura B</span>
          </div>

        </div>
        <div class="feedback-ref" id="fb1"></div>
      </div>

    </div>
  </div>

  <div class="pagina" id="pagina2">
    <div class="tarjeta-visual">
      <h2 class="titulo-pagina"><i class="fas fa-map-marked-alt me-3"></i>Líneas Imaginarias</h2>

      <div class="imagen-grande" onclick="ampliarImagen(this.querySelector('img'))">
        <img src="/contenidos/geografia/recursos/imagenes/libro/paralelos-meridianos.jpg"
             alt="Paralelos y meridianos" class="imagen-geo"
             onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/6/6d/World_map_with_equator.jpg'">
        <div class="pie-imagen">🗺️ Paralelos y meridianos</div>
      </div>

      <div class="grid-2cols">
        <div class="card-visual">
          <i class="fas fa-circle-notch"></i>
          <span>PARALELOS</span>
          <small>Horizontales</small>
        </div>
        <div class="card-visual">
          <i class="fas fa-arrow-up"></i>
          <span>MERIDIANOS</span>
          <small>Verticales</small>
        </div>
      </div>

      <div class="imagen-grande mt-3" onclick="ampliarImagen(this.querySelector('img'))">
        <img src="/contenidos/geografia/recursos/imagenes/libro/globo-lineas.jpg"
             alt="Globo con líneas" class="imagen-geo"
             onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/8/8d/Globo_terrestre.svg'">
        <div class="pie-imagen">🌐 Ecuador (Norte-Sur) · Greenwich (Este-Oeste)</div>
      </div>

      <div class="reforzamiento">
        <div class="reforzamiento-titulo"><i class="fas fa-hand-pointer"></i> Responde</div>
        <p class="reforzamiento-instruccion">
          El Ecuador divide la Tierra en dos mitades. Haz clic en el globo que muestra como lo hace.
        </p>
        <div class="opciones-svg">

          <div class="opcion-svg" id="op2A" onclick="responder2('A')">
            <svg width="150" height="150" viewBox="0 0 150 150">
              <defs>
                <radialGradient id="gA2" cx="38%" cy="35%" r="60%">
                  <stop offset="0%" stop-color="#5c9bd6"/>
                  <stop offset="100%" stop-color="#1a3a6e"/>
                </radialGradient>
                <clipPath id="cA2"><circle cx="75" cy="75" r="62"/></clipPath>
              </defs>
              <circle cx="75" cy="75" r="62" fill="url(#gA2)" stroke="#4a6fa5" stroke-width="2"/>
              <ellipse cx="58" cy="50" rx="15" ry="20" fill="#3d7a3d" opacity="0.7" clip-path="url(#cA2)"/>
              <ellipse cx="94" cy="68" rx="17" ry="13" fill="#3d7a3d" opacity="0.7" clip-path="url(#cA2)"/>
              <ellipse cx="66" cy="98" rx="13" ry="8" fill="#3d7a3d" opacity="0.6" clip-path="url(#cA2)"/>
              <line x1="13" y1="75" x2="137" y2="75" stroke="#ffd600" stroke-width="3" clip-path="url(#cA2)"/>
            </svg>
            <span>Globo A</span>
          </div>

          <div class="opcion-svg" id="op2B" onclick="responder2('B')">
            <svg width="150" height="150" viewBox="0 0 150 150">
              <defs>
                <radialGradient id="gB2" cx="38%" cy="35%" r="60%">
                  <stop offset="0%" stop-color="#5c9bd6"/>
                  <stop offset="100%" stop-color="#1a3a6e"/>
                </radialGradient>
                <clipPath id="cB2"><circle cx="75" cy="75" r="62"/></clipPath>
              </defs>
              <circle cx="75" cy="75" r="62" fill="url(#gB2)" stroke="#4a6fa5" stroke-width="2"/>
              <ellipse cx="56" cy="52" rx="15" ry="20" fill="#3d7a3d" opacity="0.7" clip-path="url(#cB2)"/>
              <ellipse cx="96" cy="68" rx="17" ry="13" fill="#3d7a3d" opacity="0.7" clip-path="url(#cB2)"/>
              <ellipse cx="68" cy="99" rx="13" ry="8" fill="#3d7a3d" opacity="0.6" clip-path="url(#cB2)"/>
              <line x1="75" y1="13" x2="75" y2="137" stroke="#ffd600" stroke-width="3" clip-path="url(#cB2)"/>
            </svg>
            <span>Globo B</span>
          </div>

        </div>
        <div class="feedback-ref" id="fb2"></div>
      </div>

    </div>
  </div>

  <div class="pagina" id="pagina3">
    <div class="tarjeta-visual">
      <h2 class="titulo-pagina"><i class="fas fa-compass me-3"></i>Puntos Cardinales</h2>

      <div class="imagen-grande" onclick="ampliarImagen(this.querySelector('img'))">
        <img src="/contenidos/geografia/recursos/imagenes/libro/rosa-nautica.png"
             alt="Rosa de los vientos" class="imagen-geo"
             onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/3/3a/Compass_Rose_English_North.svg/800px-Compass_Rose_English_North.svg.png'">
        <div class="pie-imagen">🧭 Rosa de los vientos</div>
      </div>

      <div class="grid-4cols">
        <div class="card-visual">
          <i class="fas fa-arrow-up"></i>
          <span>NORTE</span>
        </div>
        <div class="card-visual">
          <i class="fas fa-arrow-down"></i>
          <span>SUR</span>
        </div>
        <div class="card-visual">
          <i class="fas fa-arrow-right"></i>
          <span>ESTE</span>
        </div>
        <div class="card-visual">
          <i class="fas fa-arrow-left"></i>
          <span>OESTE</span>
        </div>
      </div>

      <div class="grid-2cols">
        <div class="card-visual">
          <i class="fas fa-sun"></i>
          <span>SALE</span>
          <small>Por el Este</small>
        </div>
        <div class="card-visual">
          <i class="fas fa-moon"></i>
          <span>SE OCULTA</span>
          <small>Por el Oeste</small>
        </div>
      </div>

      <div class="reforzamiento">
        <div class="reforzamiento-titulo"><i class="fas fa-hand-pointer"></i> Responde</div>
        <p class="reforzamiento-instruccion">
          En la rosa de abajo pasa el cursor sobre cada punta y haz clic en la direccion por donde sale el Sol cada manana.
        </p>
        <div style="display:flex;justify-content:center;">
          <svg width="260" height="260" viewBox="0 0 260 260">
            <defs>
              <radialGradient id="gRosa" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#283593"/>
                <stop offset="100%" stop-color="#0d2b6e"/>
              </radialGradient>
            </defs>
            <circle cx="130" cy="130" r="122" fill="url(#gRosa)" stroke="#4a6fa5" stroke-width="2"/>
            <circle cx="130" cy="130" r="82"  fill="none" stroke="#4a6fa5" stroke-width="1" opacity="0.3"/>
            <circle cx="130" cy="130" r="46"  fill="none" stroke="#4a6fa5" stroke-width="1" opacity="0.3"/>
            <line x1="130" y1="8" x2="130" y2="252" stroke="#4a6fa5" stroke-width="1" opacity="0.22"/>
            <line x1="8" y1="130" x2="252" y2="130" stroke="#4a6fa5" stroke-width="1" opacity="0.22"/>

            <g class="punta-rosa" id="pN" onclick="responder3('N')">
              <polygon points="130,10 116,88 130,74 144,88" fill="#4a6fa5" stroke="#2d4f7c" stroke-width="1"/>
              <polygon points="130,74 116,88 144,88"          fill="#2d4f7c" stroke="#2d4f7c" stroke-width="1"/>
              <text x="130" y="8" text-anchor="middle" font-family="Fredoka One" font-size="17" fill="#7a9cc5">N</text>
            </g>

            <g class="punta-rosa" id="pS" onclick="responder3('S')">
              <polygon points="130,250 116,172 130,186 144,172" fill="#4a6fa5" stroke="#2d4f7c" stroke-width="1"/>
              <polygon points="130,186 116,172 144,172"          fill="#2d4f7c" stroke="#2d4f7c" stroke-width="1"/>
              <text x="130" y="260" text-anchor="middle" font-family="Fredoka One" font-size="17" fill="#7a9cc5">S</text>
            </g>

            <g class="punta-rosa" id="pE" onclick="responder3('E')">
              <polygon points="250,130 172,116 186,130 172,144" fill="#4a6fa5" stroke="#2d4f7c" stroke-width="1"/>
              <polygon points="186,130 172,116 172,144"          fill="#2d4f7c" stroke="#2d4f7c" stroke-width="1"/>
              <text x="258" y="135" text-anchor="middle" font-family="Fredoka One" font-size="17" fill="#7a9cc5">E</text>
            </g>

            <g class="punta-rosa" id="pO" onclick="responder3('O')">
              <polygon points="10,130 88,116 74,130 88,144" fill="#4a6fa5" stroke="#2d4f7c" stroke-width="1"/>
              <polygon points="74,130 88,116 88,144"         fill="#2d4f7c" stroke="#2d4f7c" stroke-width="1"/>
              <text x="2" y="135" text-anchor="middle" font-family="Fredoka One" font-size="17" fill="#7a9cc5">O</text>
            </g>

            <circle cx="130" cy="130" r="14" fill="#0d2b6e" stroke="#4a6fa5" stroke-width="2"/>
          </svg>
        </div>
        <div class="feedback-ref" id="fb3"></div>
      </div>

    </div>
  </div>

  <div class="pagina" id="pagina4">
    <div class="tarjeta-visual">
      <h2 class="titulo-pagina"><i class="fas fa-temperature-high me-3"></i>Zonas Térmicas</h2>

      <div class="imagen-grande" onclick="ampliarImagen(this.querySelector('img'))">
        <img src="/contenidos/geografia/recursos/imagenes/libro/zonas-termicas.jpg"
             alt="Zonas térmicas" class="imagen-geo"
             onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/0/0a/Climate_zones.svg/800px-Climate_zones.svg.png'">
        <div class="pie-imagen">🌡️ 5 zonas térmicas</div>
      </div>

      <div class="grid-3cols">
        <div class="card-visual" style="background: #ff8a65;">
          <i class="fas fa-sun"></i>
          <span>CÁLIDA</span>
          <small>Ecuador</small>
        </div>
        <div class="card-visual" style="background: #66bb6a;">
          <i class="fas fa-cloud-sun"></i>
          <span>TEMPLADA</span>
          <small>¡México!</small>
        </div>
        <div class="card-visual" style="background: #4fc3f7;">
          <i class="fas fa-snowflake"></i>
          <span>FRÍA</span>
          <small>Polos</small>
        </div>
